template<class T>
T make();

template<class T>
struct common_type {
  typedef decltype(make<T>() + make<T>()) type;
};

template<class Rep>
struct duration {
  typedef Rep rep;

  rep value;

  duration() : value(0) {}
  duration(rep value) : value(value) {}

  duration<typename common_type<rep>::type> operator+() const;
};

template<class Rep>
duration<typename common_type<Rep>::type> duration<Rep>::operator+() const
{
  return duration<typename common_type<Rep>::type>(value + 1);
}

int main()
{
  duration<long long> value(3);
  duration<long long> result = +value;
  return result.value == 4 ? 0 : 1;
}
