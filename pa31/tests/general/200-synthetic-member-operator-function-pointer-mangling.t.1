template<class T>
struct Sink {
  Sink & operator<<(Sink & (*pf)(Sink &));
};

template<class T>
Sink<T> & Sink<T>::operator<<(Sink<T> & (*pf)(Sink<T> &))
{
  return pf(*this);
}

template<class T>
Sink<T> & keep(Sink<T> & sink)
{
  return sink;
}

int main()
{
  Sink<int> sink;
  sink << keep<int>;
  return 0;
}
