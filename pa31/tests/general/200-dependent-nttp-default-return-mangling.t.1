struct Vec {
  typedef unsigned long storage_type;
};

template<class C, bool IsConst, typename C::storage_type = 0>
struct bit_iterator {};

template<class C, class Size>
bit_iterator<C, false> __fill_n(bit_iterator<C, false> first,
                                Size,
                                const bool&)
{
  return first;
}

template<class OutputIterator, class Size, class T>
OutputIterator __fill_n(OutputIterator first, Size, const T&)
{
  return first;
}

template<class OutputIterator, class Size, class T>
OutputIterator fill_n(OutputIterator first, Size n, const T& value)
{
  return __fill_n(first, n, value);
}

int main()
{
  bit_iterator<Vec, false> it;
  bit_iterator<Vec, false> result = fill_n(it, 4ul, true);
  (void)result;
  return 0;
}
