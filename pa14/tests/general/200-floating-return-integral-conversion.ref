function @f(%x : f64) -> i64 [binding=strong, object=_Z1fd] {
  slot $x : f64

  block ^entry:
    store f64 %x, $x
    %t1 = load f64 $x
    %t2 = convert fptoui i64 f64 %t1
    return i64 %t2
}
function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $cond__1 : i32

  block ^entry:
    %t1 = call i64 @f(1.0)
    %t2 = convert sext i64 i32 1
    %t3 = cmp eq i64 %t1, %t2
    branch %t3, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i32 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i32 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t4 = load i32 $cond__1
    return i32 %t4
}
