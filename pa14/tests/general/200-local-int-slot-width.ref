function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $count : i32
  slot $cond__1 : i32

  block ^entry:
    store i32 0, $count
    %t1 = load i32 $count
    %t2 = binary add i32 %t1, 1
    store i32 %t2, $count
    %t3 = load i32 $count
    %t4 = cmp eq i32 %t3, 1
    branch %t4, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i32 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i32 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t5 = load i32 $cond__1
    return i32 %t5
}
