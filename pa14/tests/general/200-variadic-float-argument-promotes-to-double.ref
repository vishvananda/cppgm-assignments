declare function @sink(%arg0 : ptr) -> i32 [arity=variadic, linkage=c, binding=strong]

global @__strlit__1 [binding=internal] = {
  i8 0
}

function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $value : f32

  block ^entry:
    store f32 1.25F, $value
    %t1 = addr @__strlit__1
    %t2 = load f32 $value
    %t3 = convert fpext f64 f32 %t2
    %t4 = call i32 @sink(%t1, %t3)
    return i32 %t4
}
