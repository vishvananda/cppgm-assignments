function @eq_char(%lhs : i8, %rhs : i8) -> u8 [binding=strong, object=_Z7eq_charcc] {
  slot $lhs : i8
  slot $rhs : i8

  block ^entry:
    store i8 %lhs, $lhs
    store i8 %rhs, $rhs
    %t1 = load i8 $lhs
    %t2 = load i8 $rhs
    %t3 = convert sext i32 i8 %t1
    %t4 = convert sext i32 i8 %t2
    %t5 = cmp eq i32 %t3, %t4
    return u8 %t5
}
function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $fn : ptr
  slot $cond__1 : i32

  block ^entry:
    %t1 = addr @eq_char
    store ptr %t1, $fn
    %t2 = load ptr $fn
    %t3 = unary decay ptr %t2
    %t4 = call u8 %t3(58, 58) as (%arg0 : i8, %arg1 : i8) -> u8
    branch %t4, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i32 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i32 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t5 = load i32 $cond__1
    return i32 %t5
}
