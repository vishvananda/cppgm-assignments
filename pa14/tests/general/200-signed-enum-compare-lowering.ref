function @f(%op : i32) -> i32 [binding=strong, object=_Z1f2Op] {
  slot $op : i32

  block ^entry:
    store i32 %op, $op
    %t1 = load i32 $op
    %t2 = cmp eq i32 %t1, 6
    branch %t2, ^if_then_1, ^if_else_2

  block ^if_then_1:
    return i32 1

  block ^if_else_2:
    jump ^if_end_3

  block ^if_end_3:
    %t3 = load i32 $op
    %t4 = cmp eq i32 %t3, 4
    branch %t4, ^if_then_4, ^if_else_5

  block ^if_then_4:
    return i32 2

  block ^if_else_5:
    jump ^if_end_6

  block ^if_end_6:
    %t5 = load i32 $op
    %t6 = cmp eq i32 %t5, 10
    branch %t6, ^if_then_7, ^if_else_8

  block ^if_then_7:
    return i32 3

  block ^if_else_8:
    jump ^if_end_9

  block ^if_end_9:
    return i32 0
}
function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  block ^entry:
    return i32 0
}
