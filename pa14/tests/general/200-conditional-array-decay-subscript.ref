function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $a : obj<4x4>
  slot $b : obj<4x4>
  slot $condaddr__1 : ptr

  block ^entry:
    %t1 = addr $a
    store i32 7, %t1
    %t2 = addr $b
    store i32 3, %t2
    branch 0, ^condaddr_then_1, ^condaddr_else_2

  block ^condaddr_then_1:
    %t3 = addr $a
    store ptr %t3, $condaddr__1
    jump ^condaddr_end_3

  block ^condaddr_else_2:
    %t4 = addr $b
    store ptr %t4, $condaddr__1
    jump ^condaddr_end_3

  block ^condaddr_end_3:
    %t5 = load ptr $condaddr__1
    %t6 = index i32 [projection=array_element] %t5, 0
    %t7 = load i32 %t6
    %t8 = binary sub i32 %t7, 3
    return i32 %t8
}
