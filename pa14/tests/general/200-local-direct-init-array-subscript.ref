function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $values : obj<8x4>
  slot $x : i32

  block ^entry:
    %t1 = addr $values
    store i32 1, %t1
    %t2 = index i8 %t1, 4
    store i32 2, %t2
    %t3 = addr $values
    %t4 = unary decay ptr %t3
    %t5 = index i32 [projection=array_element] %t4, 0
    %t6 = load i32 %t5
    store i32 %t6, $x
    %t7 = load i32 $x
    %t8 = binary sub i32 %t7, 1
    return i32 %t8
}
