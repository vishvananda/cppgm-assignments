function @g(%x : i32) -> i32 [binding=strong, object=_Z1gi] {
  slot $x : i32

  block ^entry:
    store i32 %x, $x
    %t1 = load i32 $x
    %t2 = binary add i32 %t1, 1
    return i32 %t2
}
function @call(%fp : ptr) -> i32 [binding=strong, object=_Z4callPFiiE] {
  slot $fp : ptr

  block ^entry:
    store ptr %fp, $fp
    %t1 = load ptr $fp
    %t2 = call i32 %t1(4) as (%arg0 : i32) -> i32
    return i32 %t2
}
function @invoke(%rf : ptr [pass=reference], %x : i32) -> i32 [binding=strong, object=_Z6invokeRFiiEi] {
  slot $rf : ptr
  slot $x : i32

  block ^entry:
    store ptr %rf, $rf
    store i32 %x, $x
    %t1 = load i32 $x
    %t2 = load ptr $rf
    %t3 = unary decay ptr %t2
    %t4 = call i32 %t3(%t1) as (%arg0 : i32) -> i32
    return i32 %t4
}
function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  block ^entry:
    %t1 = addr @g
    %t2 = unary decay ptr %t1
    %t3 = call i32 @call(%t2)
    %t4 = addr @g
    %t5 = call i32 @invoke(%t4, 1)
    %t6 = binary add i32 %t3, %t5
    return i32 %t6
}
