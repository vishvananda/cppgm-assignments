function @f() -> i32 [binding=strong, object=_Z1fv] {
  slot $sum : i32
  slot $i : i32

  block ^entry:
    store i32 0, $sum
    store i32 0, $i
    jump ^for_cond_1

  block ^for_cond_1:
    %t1 = load i32 $i
    %t2 = cmp lt i32 %t1, 3
    branch %t2, ^for_body_2, ^for_end_4

  block ^for_body_2:
    %t3 = load i32 $sum
    %t4 = load i32 $i
    %t5 = binary add i32 %t3, %t4
    store i32 %t5, $sum
    jump ^for_iter_3

  block ^for_iter_3:
    %t6 = load i32 $i
    %t7 = binary add i32 %t6, 1
    store i32 %t7, $i
    jump ^for_cond_1

  block ^for_end_4:
    %t8 = load i32 $sum
    return i32 %t8
}
function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  block ^entry:
    %t1 = call i32 @f()
    return i32 %t1
}
