function @widen_char() -> i64 [binding=strong, object=_Z10widen_charv] {
  block ^entry:
    return i64 97
}
function @widen_int() -> i64 [binding=strong, object=_Z9widen_intv] {
  block ^entry:
    return i64 1
}
function @widen_neg() -> i64 [binding=strong, object=_Z9widen_negv] {
  block ^entry:
    %t1 = unary neg i32 1
    %t2 = convert sext i64 i32 %t1
    return i64 %t2
}
function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  block ^entry:
    return i32 0
}
