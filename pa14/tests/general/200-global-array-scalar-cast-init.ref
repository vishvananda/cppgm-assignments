global @escaped [binding=internal, object=_Z7escaped] = {
  i8 40
  i8 63
}

function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $cond__1 : i32
  slot $land__2 : i64

  block ^entry:
    %t1 = addr @escaped
    %t2 = unary decay ptr %t1
    %t3 = index i8 [projection=array_element] %t2, 0
    %t4 = load i8 %t3
    %t5 = convert sext i32 i8 %t4
    %t6 = cmp eq i32 %t5, 40
    branch %t6, ^land_rhs_4, ^land_short_5

  block ^land_rhs_4:
    %t7 = addr @escaped
    %t8 = unary decay ptr %t7
    %t9 = index i8 [projection=array_element] %t8, 1
    %t10 = load i8 %t9
    %t11 = convert sext i32 i8 %t10
    %t12 = cmp eq i32 %t11, 63
    %t13 = cmp ne i64 %t12, 0
    store i64 %t13, $land__2
    jump ^land_end_6

  block ^land_short_5:
    store i64 0, $land__2
    jump ^land_end_6

  block ^land_end_6:
    %t14 = load i64 $land__2
    branch %t14, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i32 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i32 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t15 = load i32 $cond__1
    return i32 %t15
}
