function @sum5(%a : i32, %b : i32, %c : i32, %d : i32, %e : i32) -> i32 [binding=strong, object=_Z4sum5iiiii] {
  slot $a : i32
  slot $b : i32
  slot $c : i32
  slot $d : i32
  slot $e : i32

  block ^entry:
    store i32 %a, $a
    store i32 %b, $b
    store i32 %c, $c
    store i32 %d, $d
    store i32 %e, $e
    %t1 = load i32 $a
    %t2 = load i32 $b
    %t3 = binary add i32 %t1, %t2
    %t4 = load i32 $c
    %t5 = binary add i32 %t3, %t4
    %t6 = load i32 $d
    %t7 = binary add i32 %t5, %t6
    %t8 = load i32 $e
    %t9 = binary add i32 %t7, %t8
    return i32 %t9
}
function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  block ^entry:
    %t1 = call i32 @sum5(1, 2, 3, 4, 5)
    return i32 %t1
}
