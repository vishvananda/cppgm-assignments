start:
	move64 bp sp;
	call fn__main;
	syscall1 t64 60 x64;

fn__main:
	isub64 sp sp 8;
	move64 [sp] bp;
	move64 bp sp;
while_cond_1:
	move64 x64 1;
	ieq64 z8 x64 0;
	jumpif z8 while_end_2;
	move64 x64 0;
	jump fn__main__epilogue;
	jump while_cond_1;
while_end_2:
	move64 x64 0;
fn__main__epilogue:
	move64 sp bp;
	move64 bp [sp];
	iadd64 sp sp 8;
	ret;
