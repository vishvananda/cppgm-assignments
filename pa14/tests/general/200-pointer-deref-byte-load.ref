global @data [binding=internal, object=_Z4data] = {
  i8 49
  i8 10
  i8 0
}
global @p : ptr [binding=internal, object=_Z1p] = addr @data

function @take() -> i8 [binding=strong, object=_Z4takev] {
  block ^entry:
    %t1 = load ptr @p
    %t2 = index i8 %t1, 1
    store ptr %t2, @p
    %t3 = load i8 %t1
    return i8 %t3
}
function @peek() -> i8 [binding=strong, object=_Z4peekv] {
  block ^entry:
    %t1 = load ptr @p
    %t2 = load i8 %t1
    return i8 %t2
}
function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $cond__1 : i32
  slot $land__2 : i64

  block ^entry:
    %t1 = call i8 @take()
    %t2 = convert sext i32 i8 %t1
    %t3 = cmp eq i32 %t2, 49
    branch %t3, ^land_rhs_4, ^land_short_5

  block ^land_rhs_4:
    %t4 = call i8 @peek()
    %t5 = convert sext i32 i8 %t4
    %t6 = cmp eq i32 %t5, 10
    %t7 = cmp ne i64 %t6, 0
    store i64 %t7, $land__2
    jump ^land_end_6

  block ^land_short_5:
    store i64 0, $land__2
    jump ^land_end_6

  block ^land_end_6:
    %t8 = load i64 $land__2
    branch %t8, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i32 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i32 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t9 = load i32 $cond__1
    return i32 %t9
}
