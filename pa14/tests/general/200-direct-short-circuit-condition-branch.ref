function @f(%x : i32, %y : i32) -> i32 [binding=strong, object=_Z1fii] {
  slot $x : i32
  slot $y : i32

  block ^entry:
    store i32 %x, $x
    store i32 %y, $y
    %t1 = load i32 $x
    %t2 = cmp eq i32 %t1, 1
    branch %t2, ^if_then_1, ^lor_rhs_5

  block ^lor_rhs_5:
    %t3 = load i32 $x
    %t4 = cmp eq i32 %t3, 2
    branch %t4, ^if_then_1, ^lor_rhs_4

  block ^lor_rhs_4:
    %t5 = load i32 $x
    %t6 = cmp eq i32 %t5, 3
    branch %t6, ^if_then_1, ^if_else_2

  block ^if_then_1:
    return i32 1

  block ^if_else_2:
    jump ^if_end_3

  block ^if_end_3:
    %t7 = load i32 $x
    branch %t7, ^land_rhs_9, ^if_else_7

  block ^land_rhs_9:
    %t8 = load i32 $y
    branch %t8, ^if_then_6, ^if_else_7

  block ^if_then_6:
    return i32 2

  block ^if_else_7:
    jump ^if_end_8

  block ^if_end_8:
    return i32 0
}
function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  block ^entry:
    return i32 0
}
