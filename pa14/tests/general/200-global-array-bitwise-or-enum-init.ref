global @masks [binding=internal, object=_Z5masks] = {
  u32 0
  u32 1120
}

function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $cond__1 : i32

  block ^entry:
    %t1 = addr @masks
    %t2 = unary decay ptr %t1
    %t3 = index u32 [projection=array_element] %t2, 1
    %t4 = load u32 %t3
    %t5 = binary or i32 96, 1024
    %t6 = copy u32 %t5
    %t7 = cmp eq u32 %t4, %t6
    branch %t7, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i32 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i32 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t8 = load i32 $cond__1
    return i32 %t8
}
