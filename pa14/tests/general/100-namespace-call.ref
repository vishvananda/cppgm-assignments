function @N__g(%x : i32) -> i32 [binding=strong, object=_ZN1N1gEi] {
  slot $x : i32

  block ^entry:
    store i32 %x, $x
    %t1 = load i32 $x
    %t2 = binary add i32 %t1, 2
    return i32 %t2
}
function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  block ^entry:
    %t1 = call i32 @N__g(3)
    return i32 %t1
}
