function @f(%p : ptr) -> i32 [binding=strong, object=_Z1fPKh] {
  slot $p : ptr
  slot $n : i32
  slot $c : u8

  block ^entry:
    store ptr %p, $p
    store i32 0, $n
    jump ^while_cond_1

  block ^while_cond_1:
    %t1 = load ptr $p
    %t2 = index i8 %t1, 1
    store ptr %t2, $p
    %t3 = load u8 %t1
    store u8 %t3, $c
    %t4 = load u8 $c
    branch %t4, ^while_body_2, ^while_end_3

  block ^while_body_2:
    %t5 = load i32 $n
    %t6 = load u8 $c
    %t7 = binary add i32 %t5, %t6
    store i32 %t7, $n
    jump ^while_cond_1

  block ^while_end_3:
    %t8 = load i32 $n
    return i32 %t8
}
function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  block ^entry:
    return i32 0
}
