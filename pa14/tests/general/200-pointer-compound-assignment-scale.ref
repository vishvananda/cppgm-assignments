function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $xs : obj<12x4>
  slot $p : ptr

  block ^entry:
    %t1 = addr $xs
    %t2 = unary decay ptr %t1
    store ptr %t2, $p
    %t3 = load ptr $p
    %t4 = binary mul i64 2, 4
    %t5 = index i8 %t3, %t4
    store ptr %t5, $p
    %t6 = load ptr $p
    %t7 = binary mul i64 1, 4
    %t8 = binary sub i64 0, %t7
    %t9 = index i8 %t6, %t8
    store ptr %t9, $p
    return i32 0
}
