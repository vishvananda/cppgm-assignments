global @side : i32 [binding=strong, object=_Z4side] = zero

function @pick(%values : ptr, %index : i32) -> ptr [binding=strong, object=_Z4pickPii] {
  slot $values : ptr
  slot $index : i32

  block ^entry:
    store ptr %values, $values
    store i32 %index, $index
    %t1 = load i32 $index
    store i32 %t1, @side
    %t2 = load ptr $values
    %t3 = load i32 $index
    %t4 = index i32 [projection=array_element] %t2, %t3
    return ptr %t4
}
function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $values : obj<8x4>
  slot $cond__1 : i32
  slot $land__2 : i64
  slot $land__3 : i64

  block ^entry:
    %t1 = addr $values
    %t2 = unary decay ptr %t1
    %t3 = index i32 [projection=array_element] %t2, 0
    store i32 3, %t3
    %t4 = addr $values
    %t5 = unary decay ptr %t4
    %t6 = index i32 [projection=array_element] %t5, 1
    store i32 5, %t6
    %t7 = addr $values
    %t8 = unary decay ptr %t7
    %t9 = call ptr @pick(%t8, 1)
    store i32 9, %t9
    %t10 = addr $values
    %t11 = unary decay ptr %t10
    %t12 = index i32 [projection=array_element] %t11, 0
    %t13 = load i32 %t12
    %t14 = cmp eq i32 %t13, 3
    branch %t14, ^land_rhs_7, ^land_short_8

  block ^land_rhs_7:
    %t15 = addr $values
    %t16 = unary decay ptr %t15
    %t17 = index i32 [projection=array_element] %t16, 1
    %t18 = load i32 %t17
    %t19 = cmp eq i32 %t18, 9
    %t20 = cmp ne i64 %t19, 0
    store i64 %t20, $land__3
    jump ^land_end_9

  block ^land_short_8:
    store i64 0, $land__3
    jump ^land_end_9

  block ^land_end_9:
    %t21 = load i64 $land__3
    branch %t21, ^land_rhs_4, ^land_short_5

  block ^land_rhs_4:
    %t22 = load i32 @side
    %t23 = cmp eq i32 %t22, 1
    %t24 = cmp ne i64 %t23, 0
    store i64 %t24, $land__2
    jump ^land_end_6

  block ^land_short_5:
    store i64 0, $land__2
    jump ^land_end_6

  block ^land_end_6:
    %t25 = load i64 $land__2
    branch %t25, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i32 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i32 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t26 = load i32 $cond__1
    return i32 %t26
}
