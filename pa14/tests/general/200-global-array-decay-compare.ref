global @data [binding=internal, object=_Z4data] = {
  i8 49
  i8 10
  i8 0
}
global @p : ptr [binding=internal, object=_Z1p] = addr @data

function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $cond__1 : i32

  block ^entry:
    %t1 = load ptr @p
    %t2 = addr @data
    %t3 = unary decay ptr %t2
    %t4 = cmp eq ptr %t1, %t3
    branch %t4, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i32 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i32 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t5 = load i32 $cond__1
    return i32 %t5
}
