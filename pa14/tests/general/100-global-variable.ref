global @g : i32 [binding=strong, object=_Z1g] = 4

function @add() -> i32 [binding=strong, object=_Z3addv] {
  block ^entry:
    %t1 = load i32 @g
    %t2 = binary add i32 %t1, 3
    return i32 %t2
}
function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  block ^entry:
    %t1 = call i32 @add()
    return i32 %t1
}
