function @same(%t1 : ptr [pass=reference], %t2 : ptr [pass=reference]) -> u8 [binding=strong, object=_Z4sameRKiS0_] {
  slot $t1 : ptr
  slot $t2 : ptr

  block ^entry:
    store ptr %t1, $t1
    store ptr %t2, $t2
    %t3 = load ptr $t1
    %t4 = load i32 %t3
    %t5 = load ptr $t2
    %t6 = load i32 %t5
    %t7 = cmp eq i32 %t4, %t6
    return u8 %t7
}
function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $a : i32
  slot $b : i32
  slot $cond__1 : i32

  block ^entry:
    store i32 0, $a
    store i32 0, $b
    %t1 = addr $a
    %t2 = addr $b
    %t3 = call u8 @same(%t1, %t2)
    branch %t3, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i32 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i32 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t4 = load i32 $cond__1
    return i32 %t4
}
