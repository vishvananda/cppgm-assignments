function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $cond__1 : i32
  slot $land__2 : i64

  block ^entry:
    %t1 = call i32 @zdef(0)
    %t2 = call i32 @sum(1, 3, %t1)
    %t3 = cmp eq i32 %t2, 6
    branch %t3, ^land_rhs_4, ^land_short_5

  block ^land_rhs_4:
    %t4 = call i32 @sum(1, 3, 4)
    %t5 = cmp eq i32 %t4, 8
    %t6 = cmp ne i64 %t5, 0
    store i64 %t6, $land__2
    jump ^land_end_6

  block ^land_short_5:
    store i64 0, $land__2
    jump ^land_end_6

  block ^land_end_6:
    %t7 = load i64 $land__2
    branch %t7, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i32 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i32 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t8 = load i32 $cond__1
    return i32 %t8
}
function @zdef(%__param0 : i32) -> i32 [binding=weak, object=_Z4zdefIiET_S0_] {
  slot $__param0 : i32

  block ^entry:
    store i32 %__param0, $__param0
    return i32 2
}
function @sum(%x : i32, %y : i32, %z : i32) -> i32 [binding=weak, object=_Z3sumIiET_S0_S0_S0_] {
  slot $x : i32
  slot $y : i32
  slot $z : i32

  block ^entry:
    store i32 %x, $x
    store i32 %y, $y
    store i32 %z, $z
    %t1 = load i32 $x
    %t2 = load i32 $y
    %t3 = binary add i32 %t1, %t2
    %t4 = load i32 $z
    %t5 = binary add i32 %t3, %t4
    return i32 %t5
}
