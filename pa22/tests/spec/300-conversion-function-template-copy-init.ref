function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $x : obj<4x4>
  slot $y : i32

  block ^entry:
    %t1 = addr $x
    %t2 = addr $x
    %t3 = index i8 [projection=field] %t2, 0
    store i32 7, %t3
    %t4 = addr $x
    %t5 = call i32 @box__operatorT(%t4)
    store i32 %t5, $y
    %t6 = load i32 $y
    %t7 = binary sub i32 %t6, 7
    return i32 %t7
}
function @box__operatorT(%this : ptr) -> i32 [binding=weak, object=_ZNK3boxcvT_IiEET_v] {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    %t1 = load ptr $this
