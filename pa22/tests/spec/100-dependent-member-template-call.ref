function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $w : obj<1x1>
  slot $cond__1 : i32

  block ^entry:
    %t1 = addr $w
    %t2 = addr $w
    %t3 = call i32 @run(%t2)
    %t4 = cmp eq i32 %t3, 3
    branch %t4, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i32 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i32 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t5 = load i32 $cond__1
    return i32 %t5
}
function @run(%w : ptr [pass=reference]) -> i32 [binding=weak, object=_Z3runIiEiR7wrapperIT_E] {
  slot $w : ptr

  block ^entry:
    store ptr %w, $w
    %t1 = load ptr $w
    %t2 = call i32 @wrapper_int___cast(%t1, 3)
    return i32 %t2
}
function @wrapper_int___cast(%this : ptr, %value : i32) -> i32 [binding=weak, object=_ZN7wrapperIiE4castIiEET_S2_] {
  slot $this : ptr
  slot $value : i32

  block ^entry:
    store ptr %this, $this
    store i32 %value, $value
    %t1 = load i32 $value
    return i32 %t1
}
