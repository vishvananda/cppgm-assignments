function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $d : obj<1x1>
  slot $cond__1 : i32

  block ^entry:
    %t1 = addr $d
    %t2 = addr $d
    %t3 = call i32 @derived_int___run(%t2)
    %t4 = cmp eq i32 %t3, 7
    branch %t4, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i32 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i32 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t5 = load i32 $cond__1
    return i32 %t5
}
function @derived_int___run(%this : ptr) -> i32 [binding=weak, object=_ZNK7derivedIiE3runEv] {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    %t1 = load ptr $this
    %t2 = index i8 [projection=base_subobject] %t1, 0
    %t3 = call i32 @base_int___value(%t2)
    return i32 %t3
}
function @base_int___value(%this : ptr) -> i32 [binding=weak, object=_ZNK4baseIiE5valueEv] {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    return i32 7
}
