function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $cond__1 : i32

  block ^entry:
    %t1 = call i32 @pair_sum(2, 3.0)
    %t2 = cmp eq i32 %t1, 5
    branch %t2, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i32 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i32 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t3 = load i32 $cond__1
    return i32 %t3
}
function @pair_sum(%left : i32, %right : f64) -> i32 [binding=weak, object=_Z8pair_sumIidEiT_T0_] {
  slot $left : i32
  slot $right : f64

  block ^entry:
    store i32 %left, $left
    store f64 %right, $right
    %t1 = load i32 $left
    %t2 = load f64 $right
    %t3 = binary shl i64 %t1, 32
    %t4 = binary shr i64 %t3, 32
    %t5 = convert sitofp f64 i32 %t4
    %t6 = binary add f64 %t5, %t2
    %t7 = convert fptosi i32 f64 %t6
    return i32 %t7
}
