function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $cond__1 : i32
  slot $land__2 : i64

  block ^entry:
    branch 1, ^land_rhs_4, ^land_short_5

  block ^land_rhs_4:
    %t1 = cmp eq i64 0, 0
    %t2 = cmp ne i64 %t1, 0
    store i64 %t2, $land__2
    jump ^land_end_6

  block ^land_short_5:
    store i64 0, $land__2
    jump ^land_end_6

  block ^land_end_6:
    %t3 = load i64 $land__2
    branch %t3, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i32 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i32 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t4 = load i32 $cond__1
    return i32 %t4
}
