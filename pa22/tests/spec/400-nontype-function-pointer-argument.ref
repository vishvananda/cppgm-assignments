function @square(%x : i32) -> i32 [binding=strong, object=_Z6squarei] {
  slot $x : i32

  block ^entry:
    store i32 %x, $x
    %t1 = load i32 $x
    %t2 = load i32 $x
    %t3 = binary mul i32 %t1, %t2
    return i32 %t3
}
function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $cond__1 : i32

  block ^entry:
    %t1 = call i32 @evaluator_square___run(5)
    %t2 = cmp eq i32 %t1, 25
    branch %t2, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i32 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i32 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t3 = load i32 $cond__1
    return i32 %t3
}
function @evaluator_square___run(%x : i32) -> i32 [binding=weak, object=_ZN9evaluatorIXadL_Z6squareiEEE3runEi] {
  slot $x : i32

  block ^entry:
    store i32 %x, $x
    %t1 = load i32 $x
    %t2 = addr @square
    %t3 = unary decay ptr %t2
    %t4 = call i32 %t3(%t1) as (%arg0 : i32) -> i32
    return i32 %t4
}
