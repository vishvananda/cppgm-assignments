    return i8 0
}
function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $cond__1 : i32

  block ^entry:
    %t1 = addr @g
    %t2 = unary decay ptr %t1
    %t3 = call i32 @apply(%t2)
    %t4 = cmp eq i32 %t3, 4
    branch %t4, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i32 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i32 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t5 = load i32 $cond__1
    return i32 %t5
}
function @apply(%fn : ptr) -> i32 [binding=weak, object=_Z5applyIiEiPFT_S0_E] {
  slot $fn : ptr

  block ^entry:
    store ptr %fn, $fn
