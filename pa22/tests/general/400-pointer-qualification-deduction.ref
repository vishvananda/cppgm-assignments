function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $value : i32
  slot $cond__1 : i32

  block ^entry:
    store i32 0, $value
    %t1 = addr $value
    %t2 = call i32 @probe(%t1)
    %t3 = cmp eq i32 %t2, 1
    branch %t3, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i32 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i32 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t4 = load i32 $cond__1
    return i32 %t4
}
function @probe(%__param0 : ptr) -> i32 [binding=weak, object=_Z5probeIiEiPKT_] {
  slot $__param0 : ptr

  block ^entry:
    store ptr %__param0, $__param0
    return i32 1
}
