function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $h : obj<1x1>
  slot $cond__1 : i32

  block ^entry:
    %t1 = addr $h
    %t2 = addr $h
    %t3 = call i32 @N__Holder_int___run(%t2)
