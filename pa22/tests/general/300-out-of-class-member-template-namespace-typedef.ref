    store i32 %h, $h
    store ptr %args, $args
    store ptr %args__pack2, $args__pack2
    %t1 = load i32 $h
    %t2 = const i64 2
    %t3 = convert sext i64 i32 %t1
    %t4 = binary add i64 %t3, %t2
    %t5 = convert trunc i32 i64 %t4
