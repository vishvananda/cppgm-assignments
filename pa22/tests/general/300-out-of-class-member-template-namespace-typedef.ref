    store i32 2, $refarg__2
    %t3 = addr $refarg__2
    %t4 = call i32 @N__Holder_int___make(%t1, 3, %t2, %t3)
    return i32 %t4
}
function @N__Holder_int___make(%this : ptr, %h : i32, %args : ptr [pass=reference], %args__pack2 : ptr [pass=reference]) -> i32 [binding=weak, object=_ZN1N6HolderIiE4makeIJiiEEEiiDpOT_] {
