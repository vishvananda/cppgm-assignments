function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $h : obj<8x8>
  slot $cond__1 : i32

  block ^entry:
    %t1 = addr $h
    %t2 = addr $h
    %t3 = index i8 [projection=field] %t2, 0
    store ptr 0, %t3
    %t4 = addr $h
    %t5 = index i8 [projection=field] %t4, 0
    %t6 = load ptr %t5
    %t7 = cmp eq ptr %t6, 0
    branch %t7, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i32 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i32 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t8 = load i32 $cond__1
    return i32 %t8
}
