function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $cond__1 : i32

  block ^entry:
    branch 0, ^if_then_1, ^if_else_2

  block ^if_then_1:
    return i32 1

  block ^if_else_2:
    jump ^if_end_3

  block ^if_end_3:
    branch 1, ^cond_then_4, ^cond_else_5

  block ^cond_then_4:
    store i32 0, $cond__1
    jump ^cond_end_6

  block ^cond_else_5:
    store i32 2, $cond__1
    jump ^cond_end_6

  block ^cond_end_6:
    %t1 = load i32 $cond__1
    return i32 %t1
}
