  block ^entry:
    store i16 %__param0, $__param0
    store i64 %__param1, $__param1
    store f64 %__param2, $__param2
    return i32 7
}
function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $cond__1 : i32

  block ^entry:
    branch 1, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i32 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
