function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $cond__1 : i32

  block ^entry:
    %t1 = call u8 @f(0)
    branch %t1, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i32 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i32 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t2 = load i32 $cond__1
    return i32 %t2
}
function @f(%x : i32) -> u8 [binding=weak, object=_Z1fIiEbT_] {
  slot $x : i32

  block ^entry:
    store i32 %x, $x
    return u8 1
}
