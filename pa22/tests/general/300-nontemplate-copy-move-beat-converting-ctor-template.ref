declare function @h(%ret : ptr [pass=indirect_result]) -> void [binding=strong, object=_Z1hv]

global @which : i32 [binding=strong, object=_Z5which] = zero

function @g() -> i32 [binding=strong, object=_Z1gv] {
  slot $a : obj<1x1>

  block ^entry:
    %t1 = addr $a
    call void @h(%t1)
    %t2 = load i32 @which
    return i32 %t2
}
