function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $value : obj<1x1>
  slot $cond__1 : i32

  block ^entry:
    %t1 = addr $value
    %t2 = addr $value
    %t3 = index i8 [projection=base_subobject] %t2, 0
    %t4 = call i32 @probe(%t3)
    %t5 = cmp eq i32 %t4, 1
    branch %t5, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i32 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i32 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t6 = load i32 $cond__1
    return i32 %t6
}
function @probe(%__param0 : ptr [pass=reference]) -> i32 [binding=weak, object=_Z5probeIiEiR1BIT_E] {
