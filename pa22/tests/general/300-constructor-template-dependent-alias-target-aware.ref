function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $p : ptr
  slot $g : obj<1x1>

  block ^entry:
    store ptr 0, $p
    %t1 = addr $g
    %t2 = load ptr $p
    %t3 = convert sext i64 i32 1
    call void @G_int_____G(%t1, %t2, %t3)
    return i32 0
}
function @G_int_____G(%this : ptr, %b : ptr, %n : i64) -> void [binding=weak, object=_ZN1GIPiEC1IS0_EET_m] {
  slot $this : ptr
  slot $b : ptr
  slot $n : i64

  block ^entry:
    store ptr %this, $this
    store ptr %b, $b
    store i64 %n, $n
    return void
}
