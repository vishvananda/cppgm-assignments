function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  block ^entry:
    %t1 = call i32 @g(1, 2)
    %t2 = cmp ne i32 %t1, 3
    %t3 = convert zext i32 u8 %t2
    return i32 %t3
}
function @g(%t : i32, %u : i32) -> i32 [binding=weak, object=_Z1gIiiEDTcl1fIT_Efp_fp0_EES0_T0_] {
  slot $t : i32
  slot $u : i32

  block ^entry:
    store i32 %t, $t
    store i32 %u, $u
    %t1 = load i32 $t
    %t2 = load i32 $u
    %t3 = call i32 @f__ov2(%t1, %t2)
    return i32 %t3
}
function @f__ov2(%t : i32, %u : i32) -> i32 [binding=weak, object=_Z1fIiiEiT_T0_] {
  slot $t : i32
  slot $u : i32

  block ^entry:
    store i32 %t, $t
    store i32 %u, $u
    %t1 = load i32 $t
    %t2 = load i32 $u
    %t3 = binary add i32 %t1, %t2
    return i32 %t3
}
