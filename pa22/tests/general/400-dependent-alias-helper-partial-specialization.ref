function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $h : obj<1x1>
  slot $cond__1 : i32

  block ^entry:
    %t1 = addr $h
    %t2 = addr $h
    %t3 = cmp eq i32 1, 1
    branch %t3, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i32 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i32 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t4 = load i32 $cond__1
    return i32 %t4
}
