function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $value : i32
  slot $p : ptr
  slot $pp : ptr

  block ^entry:
    store i32 7, $value
    %t1 = addr $value
    store ptr %t1, $p
    %t2 = addr $p
    store ptr %t2, $pp
    %t3 = addr $pp
    %t4 = call ptr @Outer_int_____mv(%t3)
    %t5 = load ptr %t4
    %t6 = load ptr %t5
    %t7 = load i32 %t6
    %t8 = binary sub i32 %t7, 7
    return i32 %t8
}
function @Outer_int_____mv(%t : ptr [pass=reference]) -> ptr [binding=weak, object=_ZN5OuterIPiE2mvIRPS0_EEON10remove_refIT_E4typeEOS6_] {
  slot $t : ptr

  block ^entry:
