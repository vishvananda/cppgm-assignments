function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $d : obj<1x1>

  block ^entry:
    %t1 = addr $d
    %t2 = addr $d
    %t3 = call i32 @Derived__f(%t2, 0)
    return i32 %t3
}
function @Derived__f(%this : ptr, %x : i32) -> i32 [binding=weak, object=_ZN7Derived1fEi] {
  slot $this : ptr
  slot $x : i32

  block ^entry:
    store ptr %this, $this
    store i32 %x, $x
    %t1 = load i32 $x
    return i32 %t1
}
