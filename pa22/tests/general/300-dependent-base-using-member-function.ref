function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $s : obj<1x1>

  block ^entry:
    %t1 = addr $s
    %t2 = addr $s
    %t3 = call i32 @split_int___spare(%t2)
    %t4 = binary sub i32 %t3, 7
    return i32 %t4
}
function @split_int___spare(%this : ptr) -> i32 [binding=weak, object=_ZNK5splitIiE5spareEv] {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    %t1 = load ptr $this
    %t2 = index i8 [projection=base_subobject] %t1, 0
    %t3 = call i32 @layout_split_int___int_____back_spare(%t2)
    return i32 %t3
}
function @layout_split_int___int_____back_spare(%this : ptr) -> i32 [binding=weak, object=_ZNK6layoutI5splitIiEiE12__back_spareEv] {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    return i32 7
}
