  slot $first : i32
  slot $last : i32

  block ^entry:
    store i32 %first, $first
    store i32 %last, $last
    %t1 = load i32 $last
    %t2 = load i32 $first
    %t3 = binary sub i32 %t1, %t2
    %t4 = convert sext i64 i32 %t3
    return i64 %t4
}
