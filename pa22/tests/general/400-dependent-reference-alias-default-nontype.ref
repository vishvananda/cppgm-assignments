global @Box_int___count : i64 [binding=weak, object=_ZN3BoxIiE5countE] = 4

function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $box : obj<1x1>

  block ^entry:
    %t1 = addr $box
    %t2 = addr $box
    %t3 = call i64 @Box_int___get(%t2)
    %t4 = convert sext i64 i32 8
    %t5 = binary sub i64 %t3, %t4
    %t6 = convert trunc i32 i64 %t5
    return i32 %t6
}
function @Box_int___get(%this : ptr) -> i64 [binding=weak, object=_ZNK3BoxIiE3getEv] {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    %t1 = binary add i64 4, 4
    return i64 %t1
}
