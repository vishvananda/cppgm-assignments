function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $p : ptr
  slot $box : obj<4x4>
  slot $cond__1 : i32

  block ^entry:
    store ptr 0, $p
    %t1 = addr $box
    %t2 = addr $box
    %t3 = index i8 [projection=field] %t2, 0
    store i32 5, %t3
    %t4 = load ptr $p
    %t5 = cmp eq ptr %t4, 0
    branch %t5, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    %t6 = addr $box
    %t7 = index i8 [projection=field] %t6, 0
    %t8 = load i32 %t7
    store i32 %t8, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i32 0, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t9 = load i32 $cond__1
    return i32 %t9
}
