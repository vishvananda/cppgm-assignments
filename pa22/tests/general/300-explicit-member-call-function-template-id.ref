function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $s : obj<1x1>

  block ^entry:
    %t1 = addr $s
    %t2 = addr $s
    %t3 = addr @manip
    %t4 = unary decay ptr %t3
    %t5 = call ptr @Sink__operator__(%t2, %t4)
