}
function @manip(%x : ptr [pass=reference]) -> ptr [binding=weak, object=_Z5manipI4SinkERT_S2_] {
  slot $x : ptr

  block ^entry:
    store ptr %x, $x
    %t1 = load ptr $x
    return ptr %t1
}
function @Sink__operator__(%this : ptr, %pf : ptr) -> ptr [binding=weak, object=_ZN4SinklsEPFRS_S0_E] {
  slot $this : ptr
  slot $pf : ptr

  block ^entry:
    store ptr %this, $this
    store ptr %pf, $pf
