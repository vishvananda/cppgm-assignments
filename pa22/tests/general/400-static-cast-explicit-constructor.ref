function @read(%b : obj<4x4>) -> i32 [binding=strong, object=_Z4read3box] {
  slot $b : obj<4x4>

  block ^entry:
    %t1 = addr $b
    copyobj 4x4 %b, %t1
    %t2 = addr $b
    %t3 = index i8 [projection=field] %t2, 0
    %t4 = load i32 %t3
    return i32 %t4
}
function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $argobj__1 : obj<4x4>

  block ^entry:
    %t1 = addr $argobj__1
    call void @box__box(%t1, 7)
    %t2 = call i32 @read($argobj__1)
    %t3 = binary sub i32 %t2, 7
    return i32 %t3
}
function @box__box(%this : ptr, %x : i32) -> void [binding=weak, object=_ZN3boxC1Ei] {
  slot $this : ptr
  slot $x : i32

  block ^entry:
    store ptr %this, $this
    store i32 %x, $x
    %t1 = load i32 $x
    %t2 = load ptr $this
    %t3 = index i8 [projection=field] %t2, 0
    store i32 %t1, %t3
    return void
}
