machine_ir x86_64 linux

startup
    call @main
    mov rdi, rax
    exit

function @id
  abi
    param %x -> rdi : i64
    return i64 -> rax
  frame
    stack_size 16
    scratch_bytes 0

  block ^entry
    ret rdi

function @main
  abi
    return i64 -> rax
  frame
    stack_size 0
    scratch_bytes 0

  block ^entry
    mov r8, 20
    mov rdi, 20
    call @id
    ret rax
