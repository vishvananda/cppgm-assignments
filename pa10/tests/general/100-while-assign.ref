1 translation units
start translation unit 1
translation-unit
  function-definition
    decl-specifier-seq
      decl-specifier KW_INT:int
    declarator
      identifier main
      parameter-clause
    compound-statement
      while-statement
        condition
          binary-expression OP_LAND:&&
            id-expression x
            id-expression y
        expression-statement
          assignment-expression OP_ASS:=
            id-expression x
            binary-expression OP_MINUS:-
              id-expression x
              literal 1
end translation unit
