1 translation units
start translation unit 1
translation-unit
  function-definition
    decl-specifier-seq
      decl-specifier KW_INT:int
    declarator
      identifier main
      parameter-clause
    compound-statement
      expression-statement
        binary-expression OP_LSHIFT:<<
          id-expression a
          id-expression b
      expression-statement
        binary-expression OP_BOR:|
          binary-expression OP_AMP:&
            id-expression a
            id-expression b
          binary-expression OP_XOR:^
            id-expression c
            id-expression d
      expression-statement
        binary-expression OP_ARROWSTAR:->*
          id-expression p
          id-expression m
      expression-statement
        binary-expression OP_DOTSTAR:.*
          id-expression q
          id-expression n
end translation unit
