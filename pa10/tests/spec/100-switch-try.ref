1 translation units
start translation unit 1
translation-unit
  function-definition
    decl-specifier-seq
      decl-specifier KW_INT:int
    declarator
      identifier main
      parameter-clause
    compound-statement
      switch-statement
        condition
          id-expression x
        compound-statement
          case-statement
            literal 1
            break-statement
          default-statement
            goto-statement done
      do-statement
        expression-statement
          assignment-expression OP_ASS:=
            id-expression x
            binary-expression OP_MINUS:-
              id-expression x
              literal 1
        condition
          id-expression x
      try-block
        compound-statement
          throw-statement
            id-expression x
        handler
          exception-declaration
            ellipsis ...
          compound-statement
            continue-statement
      labeled-statement done
        return-statement
          literal 0
end translation unit
