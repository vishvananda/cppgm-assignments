function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $base_ptr : i128
  slot $derived_ptr : i128
  slot $d : obj<1x1>
  slot $cond__1 : i32

  block ^entry:
    %t1 = addr @Base__f
    %t2 = copy i64 %t1
    %t3 = convert zext i128 i64 %t2
    store i128 %t3, $base_ptr
    %t4 = load i128 $base_ptr
    store i128 %t4, $derived_ptr
    %t5 = addr $d
    %t6 = addr $d
    %t7 = load i128 $derived_ptr
    %t8 = convert trunc i64 i128 %t7
    %t9 = copy ptr %t8
    %t10 = call i32 %t9(%t6) as (%arg0 : ptr) -> i32
    %t11 = cmp eq i32 %t10, 5
    branch %t11, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i32 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i32 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t12 = load i32 $cond__1
    return i32 %t12
}
function @Base__f(%this : ptr) -> i32 [binding=weak, object=_ZN4Base1fEv] {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    return i32 5
}
