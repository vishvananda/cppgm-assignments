function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $s : obj<4x4>
  slot $data : i64
  slot $method : i128
  slot $cond__1 : i32
  slot $land__2 : i64

  block ^entry:
    %t1 = addr $s
    %t2 = addr $s
    %t3 = index i8 [projection=field] %t2, 0
    store i32 4, %t3
    %t4 = const i64 1
    store i64 %t4, $data
    %t5 = addr @S__twice
    %t6 = copy i64 %t5
    %t7 = convert zext i128 i64 %t6
    store i128 %t7, $method
    %t8 = addr $s
    %t9 = load i64 $data
    %t10 = binary sub i64 %t9, 1
    %t11 = index i8 [projection=field] %t8, %t10
    %t12 = load i32 %t11
    %t13 = cmp eq i32 %t12, 4
    branch %t13, ^land_rhs_4, ^land_short_5

  block ^land_rhs_4:
    %t14 = addr $s
    %t15 = load i128 $method
    %t16 = convert trunc i64 i128 %t15
    %t17 = copy ptr %t16
    %t18 = call i32 %t17(%t14) as (%arg0 : ptr) -> i32
    %t19 = cmp eq i32 %t18, 8
    %t20 = cmp ne i64 %t19, 0
    store i64 %t20, $land__2
    jump ^land_end_6

  block ^land_short_5:
    store i64 0, $land__2
    jump ^land_end_6

  block ^land_end_6:
    %t21 = load i64 $land__2
    branch %t21, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i32 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i32 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t22 = load i32 $cond__1
    return i32 %t22
}
function @S__twice(%this : ptr) -> i32 [binding=weak, object=_ZN1S5twiceEv] {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    %t1 = load ptr $this
    %t2 = index i8 [projection=field] %t1, 0
    %t3 = load i32 %t2
    %t4 = binary mul i32 %t3, 2
    return i32 %t4
}
