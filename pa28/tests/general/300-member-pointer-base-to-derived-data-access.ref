function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $base_ptr : i64
  slot $derived_ptr : i64
  slot $d : obj<4x4>
  slot $cond__1 : i32

  block ^entry:
    %t1 = const i64 1
    store i64 %t1, $base_ptr
    %t2 = load i64 $base_ptr
    store i64 %t2, $derived_ptr
    %t3 = addr $d
    %t4 = addr $d
    %t5 = index i8 [projection=base_subobject] %t4, 0
    %t6 = index i8 [projection=field] %t5, 0
    store i32 5, %t6
    %t7 = addr $d
    %t8 = load i64 $derived_ptr
    %t9 = binary sub i64 %t8, 1
    %t10 = index i8 [projection=field] %t7, %t9
    %t11 = load i32 %t10
    %t12 = cmp eq i32 %t11, 5
    branch %t12, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i32 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i32 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t13 = load i32 $cond__1
    return i32 %t13
}
