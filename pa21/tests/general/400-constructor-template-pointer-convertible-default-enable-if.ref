function @main() -> i64 {
  slot $x : i32
  slot $p : ptr
  slot $pp : ptr
  slot $b__0 : i64

  block ^entry:
    store i32 0, $x
    %t1 = addr $x
    store ptr %t1, $p
    %t2 = addr $p
    store ptr %t2, $pp
    %t3 = addr $b__0
    %t4 = addr $pp
    call void @box_int___const_____box__ov2(%t3, %t4)
    %t5 = addr $b__0
    %t6 = load ptr %t5
    %t7 = cmp eq ptr %t6, 0
    %t8 = addr $b__0
    call void @box_int___const______box(%t8)
    return i64 %t7
}
function @box_int___const______box(%this : ptr) -> void {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    return void
}
function @box_int___const_____box__ov2(%this : ptr, %r : ptr) -> void {
  slot $this : ptr
  slot $r : ptr

  block ^entry:
    store ptr %this, $this
    store ptr %r, $r
    %t1 = load ptr $r
    %t2 = load ptr %t1
    %t3 = load ptr $this
    store ptr %t2, %t3
    return void
}
