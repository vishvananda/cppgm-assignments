function @main() -> i64 {
  block ^entry:
    %t1 = call i64 @distance_like(0, 0)
    return i64 %t1
}
function @distance_like(%first : i64, %last : i64) -> i64 {
  slot $first : i32
  slot $last : i32

  block ^entry:
    store i32 %first, $first
    store i32 %last, $last
    %t1 = load i32 $last
    %t2 = load i32 $first
    %t3 = binary sub i64 %t1, %t2
    return i64 %t3
}
