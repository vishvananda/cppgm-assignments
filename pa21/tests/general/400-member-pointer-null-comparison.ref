function @main() -> i64 {
  slot $fn : ptr
  slot $field : i64
  slot $cond__1 : i64
  slot $land__2 : i64

  block ^entry:
    store ptr nullptr, $fn
    store i64 nullptr, $field
    %t1 = load ptr $fn
    %t2 = copy ptr nullptr
    %t3 = cmp eq ptr %t1, %t2
    branch %t3, ^land_rhs_4, ^land_short_5

  block ^land_rhs_4:
    %t4 = load i64 $field
    %t5 = cmp eq i64 %t4, nullptr
    %t6 = cmp ne i64 %t5, 0
    store i64 %t6, $land__2
    jump ^land_end_6

  block ^land_short_5:
    store i64 0, $land__2
    jump ^land_end_6

  block ^land_end_6:
    %t7 = load i64 $land__2
    branch %t7, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i64 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i64 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t8 = load i64 $cond__1
    return i64 %t8
}
