function @main() -> i64 {
  slot $cond__1 : i64
  slot $land__2 : i64

  block ^entry:
    %t1 = cmp eq i64 1, 1
    branch %t1, ^land_rhs_4, ^land_short_5

  block ^land_rhs_4:
    %t2 = cmp eq i64 2, 2
    %t3 = cmp ne i64 %t2, 0
    store i64 %t3, $land__2
    jump ^land_end_6

  block ^land_short_5:
    store i64 0, $land__2
    jump ^land_end_6

  block ^land_end_6:
    %t4 = load i64 $land__2
    branch %t4, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i64 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i64 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t5 = load i64 $cond__1
    return i64 %t5
}
