function @main() -> i64 {
  slot $h__0 : i64

  block ^entry:
    %t1 = addr $h__0
    call void @holder_unsigned_int__int___holder(%t1)
    %t2 = addr $h__0
    %t3 = load u32 %t2
    %t4 = addr $h__0
    call void @holder_unsigned_int__int____holder(%t4)
    return i64 %t3
}
function @holder_unsigned_int__int____holder(%this : ptr) -> void {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    return void
}
function @holder_unsigned_int__int___holder(%this : ptr) -> void {
  slot $this : ptr
  slot $mask : u32
  slot $cond__1 : i64
  slot $cond__2 : i64

  block ^entry:
    store ptr %this, $this
    %t1 = load ptr $this
    %t2 = load u32 %t1
    %t3 = binary sub i64 8, 1
    %t4 = binary shl i64 %t3, 32
    %t5 = binary shr i64 %t4, 32
    %t6 = binary and i64 %t5, 4294967295
    %t7 = cmp ult i64 %t2, %t6
    branch %t7, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    %t8 = unary bitnot i64 0
    %t9 = load ptr $this
    %t10 = load u32 %t9
    %t11 = binary shl i64 1, 32
    %t12 = binary shr i64 %t11, 32
    %t13 = binary and i64 %t12, 4294967295
    %t14 = binary add i64 %t10, %t13
    %t15 = binary shl i64 8, 32
    %t16 = binary shr i64 %t15, 32
    %t17 = binary and i64 %t16, 4294967295
    %t18 = binary sub i64 %t17, %t14
    %t19 = binary ushr i64 %t8, %t18
    store i64 %t19, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    %t20 = unary bitnot i64 0
    store i64 %t20, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t21 = load i64 $cond__1
    store u32 %t21, $mask
    %t22 = load u32 $mask
    %t23 = binary shl i64 0, 32
    %t24 = binary shr i64 %t23, 32
    %t25 = binary and i64 %t24, 4294967295
    %t26 = cmp ne i64 %t22, %t25
    branch %t26, ^cond_then_4, ^cond_else_5

  block ^cond_then_4:
    store i64 1, $cond__2
    jump ^cond_end_6

  block ^cond_else_5:
    store i64 0, $cond__2
    jump ^cond_end_6

  block ^cond_end_6:
    %t27 = load i64 $cond__2
    %t28 = load ptr $this
    store u32 %t27, %t28
    return void
}
