function @main() -> i64 {
  slot $s__0 : i64

  block ^entry:
    %t1 = addr $s__0
    call void @Sink__Sink(%t1)
    %t2 = addr $s__0
    %t3 = addr @manip
    %t4 = call ptr @Sink__operator__(%t2, %t3)
    %t5 = addr $s__0
    call void @Sink___Sink(%t5)
    return i64 0
}
function @manip(%x : ptr) -> ptr {
  slot $x : ptr

  block ^entry:
    store ptr %x, $x
    %t1 = load ptr $x
    return ptr %t1
}
function @Sink__Sink(%this : ptr) -> void {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    return void
}
function @Sink__operator__(%this : ptr, %pf : ptr) -> ptr {
  slot $this : ptr
  slot $pf : ptr

  block ^entry:
    store ptr %this, $this
    store ptr %pf, $pf
    %t1 = load ptr $this
    %t2 = load ptr $pf
    %t3 = call ptr %t2(%t1)
    return ptr %t3
}
function @Sink___Sink(%this : ptr) -> void {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    return void
}
