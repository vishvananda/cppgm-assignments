function @main() -> i64 {
  slot $value : i32
  slot $cond__1 : i64

  block ^entry:
    store i32 0, $value
    %t1 = addr $value
    %t2 = call i64 @probe(%t1)
    %t3 = cmp eq i64 %t2, 1
    branch %t3, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i64 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i64 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t4 = load i64 $cond__1
    return i64 %t4
}
function @probe(%__param0 : ptr) -> i64 {
  slot $__param0 : ptr

  block ^entry:
    store ptr %__param0, $__param0
    return i64 1
}
