function @main() -> i64 {
  block ^entry:
    %t1 = call i64 @add(3, 4)
    return i64 %t1
}
function @add(%lhs : i64, %rhs : i64) -> i64 {
  slot $lhs : i32
  slot $rhs : i32

  block ^entry:
    store i32 %lhs, $lhs
    store i32 %rhs, $rhs
    %t1 = load i32 $lhs
    %t2 = load i32 $rhs
    %t3 = binary add i64 %t1, %t2
    return i64 %t3
}
