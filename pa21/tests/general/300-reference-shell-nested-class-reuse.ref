function @main() -> i64 {
  slot $p : ptr
  slot $box__0 : i64
  slot $cond__1 : i64

  block ^entry:
    store ptr 0, $p
    %t1 = addr $box__0
    call void @Box_int___Box(%t1)
    %t2 = addr $box__0
    store i32 5, %t2
    %t3 = load ptr $p
    %t4 = cmp eq ptr %t3, 0
    branch %t4, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    %t5 = addr $box__0
    %t6 = load i32 %t5
    store i64 %t6, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i64 0, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t7 = load i64 $cond__1
    %t8 = addr $box__0
    call void @Box_int____Box(%t8)
    return i64 %t7
}
function @Box_int___Box(%this : ptr) -> void {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    return void
}
function @Box_int____Box(%this : ptr) -> void {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    return void
}
