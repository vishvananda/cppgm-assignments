function @main() -> i64 {
  slot $value__0 : i64
  slot $cond__1 : i64

  block ^entry:
    %t1 = addr $value__0
    call void @D_int___D(%t1)
    %t2 = addr $value__0
    %t3 = call i64 @probe(%t2)
    %t4 = cmp eq i64 %t3, 1
    branch %t4, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i64 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i64 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t5 = load i64 $cond__1
    %t6 = addr $value__0
    call void @D_int____D(%t6)
    return i64 %t5
}
function @D_int___D(%this : ptr) -> void {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    %t1 = load ptr $this
    call void @B_int___B(%t1)
    return void
}
function @D_int____D(%this : ptr) -> void {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    %t1 = load ptr $this
    call void @B_int____B(%t1)
