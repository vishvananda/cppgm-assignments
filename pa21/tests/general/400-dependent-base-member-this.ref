function @main() -> i64 {
  slot $d__0 : i64
  slot $cond__1 : i64

  block ^entry:
    %t1 = addr $d__0
    call void @Derived_int___Derived(%t1)
    %t2 = addr $d__0
    %t3 = call i64 @Derived_int___run(%t2)
    %t4 = cmp eq i64 %t3, 7
    branch %t4, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i64 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i64 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t5 = load i64 $cond__1
    %t6 = addr $d__0
    call void @Derived_int____Derived(%t6)
    return i64 %t5
}
function @Derived_int___run(%this : ptr) -> i64 {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    %t1 = load ptr $this
    %t2 = call i64 @Base_int___value(%t1)
    return i64 %t2
}
function @Derived_int___Derived(%this : ptr) -> void {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    %t1 = load ptr $this
    call void @Base_int___Base(%t1)
    return void
