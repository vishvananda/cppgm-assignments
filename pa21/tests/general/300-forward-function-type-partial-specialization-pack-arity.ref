function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $lor__1 : i64

  block ^entry:
    %t1 = cmp ne i32 0, 0
    branch %t1, ^lor_short_2, ^lor_rhs_1

  block ^lor_rhs_1:
    %t2 = cmp ne i32 2, 2
    %t3 = cmp ne i64 %t2, 0
    store i64 %t3, $lor__1
    jump ^lor_end_3

  block ^lor_short_2:
    store i64 1, $lor__1
    jump ^lor_end_3

  block ^lor_end_3:
    %t4 = load i64 $lor__1
    %t5 = convert zext i32 u8 %t4
    return i32 %t5
}
