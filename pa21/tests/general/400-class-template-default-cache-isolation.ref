function @pick(%__param0 : ptr) -> i64 {
  slot $__param0 : ptr

  block ^entry:
    store ptr %__param0, $__param0
    return i64 1
}
function @pick__ov2(%__param0 : ptr) -> i64 {
  slot $__param0 : ptr

  block ^entry:
    store ptr %__param0, $__param0
    return i64 2
}
function @main() -> i64 {
  slot $a : ptr
  slot $b : ptr

  block ^entry:
    store ptr 0, $a
    store ptr 0, $b
    %t1 = load ptr $a
    %t2 = call i64 @pick(%t1)
    %t3 = binary mul i64 %t2, 10
    %t4 = load ptr $b
    %t5 = call i64 @pick__ov2(%t4)
    %t6 = binary add i64 %t3, %t5
    return i64 %t6
}
