function @g(%x : i64) -> i64 {
  slot $x : i32

  block ^entry:
    store i32 %x, $x
    %t1 = load i32 $x
    %t2 = binary add i64 %t1, 1
    return i64 %t2
}
function @g__ov2(%__param0 : i64, %__param1 : i64) -> i64 {
  slot $__param0 : u8
  slot $__param1 : u8

  block ^entry:
    store u8 %__param0, $__param0
    store u8 %__param1, $__param1
    return i64 0
}
function @main() -> i64 {
  slot $cond__1 : i64

  block ^entry:
    %t1 = addr @g
    %t2 = call i64 @apply(%t1)
    %t3 = cmp eq i64 %t2, 4
    branch %t3, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i64 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i64 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t4 = load i64 $cond__1
    return i64 %t4
}
function @apply(%fn : ptr) -> i64 {
  slot $fn : ptr

  block ^entry:
    store ptr %fn, $fn
    %t1 = load ptr $fn
    %t2 = call i64 %t1(3)
    return i64 %t2
}
