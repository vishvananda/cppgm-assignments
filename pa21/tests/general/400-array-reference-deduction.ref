function @main() -> i64 {
  slot $values__3 : i32
  slot $values__2 : i32
  slot $values__1 : i32
  slot $values__0 : i32
  slot $cond__1 : i64

  block ^entry:
    store i32 0, $values__0
    store i32 1, $values__1
    store i32 2, $values__2
    store i32 3, $values__3
    %t1 = addr $values__0
    %t2 = call i64 @length(%t1)
    %t3 = cmp eq i64 %t2, 4
    branch %t3, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i64 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i64 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t4 = load i64 $cond__1
    return i64 %t4
}
function @length(%__param0 : ptr) -> i64 {
  slot $__param0 : ptr

  block ^entry:
    store ptr %__param0, $__param0
    return i64 4
}
