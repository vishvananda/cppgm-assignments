function @main() -> i64 {
  slot $box__0 : i64
  slot $cond__1 : i64

  block ^entry:
    %t1 = addr $box__0
    call void @Box_int___Box(%t1, 11)
    %t2 = addr $box__0
    %t3 = call i64 @read(%t2)
    %t4 = cmp eq i64 %t3, 11
    branch %t4, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i64 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i64 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t5 = load i64 $cond__1
    %t6 = addr $box__0
    call void @Box_int____Box(%t6)
    return i64 %t5
}
function @Box_int___Box(%this : ptr, %value : i64) -> void {
  slot $this : ptr
  slot $value : i32

  block ^entry:
    store ptr %this, $this
    store i32 %value, $value
    %t1 = load i32 $value
    %t2 = load ptr $this
    store i32 %t1, %t2
    return void
}
function @Box_int____Box(%this : ptr) -> void {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    return void
}
function @read(%box : ptr) -> i64 {
  slot $box__0 : i64

  block ^entry:
    %t1 = addr $box__0
    call void @Box_int___Box__ov2(%t1, %box)
    %t2 = addr $box__0
    %t3 = load i32 %t2
    %t4 = addr $box__0
    call void @Box_int____Box(%t4)
    return i64 %t3
}
function @Box_int___Box__ov2(%this : ptr, %other : ptr) -> void {
  slot $this : ptr
  slot $other : ptr

  block ^entry:
    store ptr %this, $this
    store ptr %other, $other
    %t1 = load ptr $other
    %t2 = load i32 %t1
    %t3 = load ptr $this
    store i32 %t2, %t3
    return void
}
