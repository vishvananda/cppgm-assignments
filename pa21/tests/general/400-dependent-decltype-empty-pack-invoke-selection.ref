function @Nat__Nat(%this : ptr) -> void {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    return void
}
function @Nat___Nat(%this : ptr) -> void {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    return void
}
function @h() -> i64 {
  block ^entry:
    return i64 1
}
function @main() -> i64 {
  slot $r : i64

  block ^entry:
    %t1 = call i64 @h()
    store i64 %t1, $r
    %t2 = load i64 $r
    %t3 = binary sub i64 %t2, 1
    return i64 %t3
}