function @main() -> i64 {
  slot $h__0 : i64
  slot $cond__1 : i64

  block ^entry:
    %t1 = addr $h__0
    call void @Holder_int___Holder__ov2(%t1)
    %t2 = addr $h__0
    %t3 = load i32 %t2
    %t4 = cmp eq i64 %t3, 3
    branch %t4, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i64 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i64 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t5 = load i64 $cond__1
    %t6 = addr $h__0
    call void @Holder_int____Holder(%t6)
    return i64 %t5
}
function @Holder_int___Holder__ov2(%this : ptr) -> void {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    %t1 = load ptr $this
    store i32 3, %t1
    return void
}
function @Holder_int____Holder(%this : ptr) -> void {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    return void
}
