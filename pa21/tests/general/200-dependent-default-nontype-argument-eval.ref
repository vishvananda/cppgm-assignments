function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $value : i64
  slot $cond__1 : i32

  block ^entry:
    %t1 = convert sext i64 i32 7
    store i64 %t1, $value
    %t2 = load i64 $value
    %t3 = convert sext i64 i32 7
    %t4 = cmp eq i64 %t2, %t3
    branch %t4, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i32 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i32 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t5 = load i32 $cond__1
    return i32 %t5
}
