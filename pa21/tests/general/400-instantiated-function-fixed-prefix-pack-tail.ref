function @main() -> i64 {
  slot $cond__1 : i64
  slot $land__2 : i64

  block ^entry:
    %t1 = call i64 @Box____f(7)
    %t2 = cmp eq i64 %t1, 7
    branch %t2, ^land_rhs_4, ^land_short_5

  block ^land_rhs_4:
    %t3 = call i64 @Box_int__float___f(5, 1, 2.0f)
    %t4 = cmp eq i64 %t3, 7
    %t5 = cmp ne i64 %t4, 0
    store i64 %t5, $land__2
    jump ^land_end_6

  block ^land_short_5:
    store i64 0, $land__2
    jump ^land_end_6

  block ^land_end_6:
    %t6 = load i64 $land__2
    branch %t6, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i64 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i64 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t7 = load i64 $cond__1
    return i64 %t7
}
