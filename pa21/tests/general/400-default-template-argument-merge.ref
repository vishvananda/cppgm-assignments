function @main() -> i64 {
  slot $b__0 : i64
  slot $cond__1 : i64

  block ^entry:
    %t1 = addr $b__0
    call void @box_int___box(%t1)
    %t2 = load i8 $b__0
    %t3 = cmp eq i64 1, 1
    branch %t3, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i64 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i64 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t4 = load i64 $cond__1
    %t5 = addr $b__0
    call void @box_int____box(%t5)
    return i64 %t4
}
function @box_int___box(%this : ptr) -> void {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    return void
}
function @box_int____box(%this : ptr) -> void {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    return void
}
