function @main() -> i64 {
  slot $lhs__0 : i64
  slot $rhs__0 : i64
  slot $cond__1 : i64

  block ^entry:
    %t1 = addr $lhs__0
    call void @Foo__Foo__ov3(%t1, 7)
    %t2 = addr $rhs__0
    call void @Foo__Foo__ov3(%t2, 3)
    %t3 = addr $lhs__0
    %t4 = addr $rhs__0
    %t5 = call ptr @pick_first(%t3, %t4)
    %t6 = load i32 %t5
    %t7 = cmp eq i64 %t6, 7
    branch %t7, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i64 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i64 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t8 = load i64 $cond__1
    %t9 = addr $rhs__0
    call void @Foo___Foo(%t9)
    %t10 = addr $lhs__0
    call void @Foo___Foo(%t10)
    return i64 %t8
}
function @pick_first(%lhs : ptr, %rhs : ptr) -> ptr {
  slot $lhs : ptr
  slot $rhs : ptr
  slot $condaddr__1 : ptr

  block ^entry:
    store ptr %lhs, $lhs
    store ptr %rhs, $rhs
    %t1 = load ptr $lhs
    %t2 = load i32 %t1
    branch %t2, ^condaddr_then_1, ^condaddr_else_2

  block ^condaddr_then_1:
    %t3 = load ptr $lhs
    store ptr %t3, $condaddr__1
    jump ^condaddr_end_3

  block ^condaddr_else_2:
    %t4 = load ptr $rhs
    store ptr %t4, $condaddr__1
    jump ^condaddr_end_3

  block ^condaddr_end_3:
    %t5 = load ptr $condaddr__1
    return ptr %t5
}
function @Foo__Foo__ov3(%this : ptr, %value : i64) -> void {
  slot $this : ptr
  slot $value : i32

  block ^entry:
    store ptr %this, $this
    store i32 %value, $value
    %t1 = load i32 $value
    %t2 = load ptr $this
    store i32 %t1, %t2
    return void
}
function @Foo___Foo(%this : ptr) -> void {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    return void
}
