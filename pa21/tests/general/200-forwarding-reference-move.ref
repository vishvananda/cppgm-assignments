function @f(%p : ptr) -> ptr {
  slot $p : ptr

  block ^entry:
    store ptr %p, $p
    %t1 = addr $p
    %t2 = call ptr @mv(%t1)
    %t3 = load ptr %t2
    return ptr %t3
}
function @main() -> i64 {
  block ^entry:
    return i64 0
}
function @mv(%t : ptr) -> ptr {
  slot $t : ptr

  block ^entry:
    store ptr %t, $t
    %t1 = load ptr $t
    return ptr %t1
}
