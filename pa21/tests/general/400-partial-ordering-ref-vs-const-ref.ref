function @main() -> i64 {
  slot $x : i32
  slot $y : i32
  slot $cond__1 : i64
  slot $land__2 : i64
  slot $land__3 : i64
  slot $refarg__4 : i32
  slot $refarg__5 : i32

  block ^entry:
    store i32 0, $x
    store i32 0, $y
    %t1 = addr $x
    %t2 = call i64 @pick(%t1)
    %t3 = cmp eq i64 %t2, 1
    branch %t3, ^land_rhs_7, ^land_short_8

  block ^land_rhs_7:
    store i32 0, $refarg__4
    %t4 = addr $refarg__4
    %t5 = call i64 @pick__ov2(%t4)
    %t6 = cmp eq i64 %t5, 2
    %t7 = cmp ne i64 %t6, 0
    store i64 %t7, $land__3
    jump ^land_end_9

  block ^land_short_8:
    store i64 0, $land__3
    jump ^land_end_9

  block ^land_end_9:
    %t8 = load i64 $land__3
    branch %t8, ^land_rhs_4, ^land_short_5

  block ^land_rhs_4:
    store i32 3, $refarg__5
    %t9 = addr $refarg__5
    %t10 = call i64 @pick__ov2(%t9)
    %t11 = cmp eq i64 %t10, 2
    %t12 = cmp ne i64 %t11, 0
    store i64 %t12, $land__2
    jump ^land_end_6

  block ^land_short_5:
    store i64 0, $land__2
    jump ^land_end_6

  block ^land_end_6:
    %t13 = load i64 $land__2
    branch %t13, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i64 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i64 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t14 = load i64 $cond__1
    return i64 %t14
}
function @pick(%__param0 : ptr) -> i64 {
  slot $__param0 : ptr

  block ^entry:
    store ptr %__param0, $__param0
    return i64 1
}
function @pick__ov2(%__param0 : ptr) -> i64 {
  slot $__param0 : ptr

  block ^entry:
    store ptr %__param0, $__param0
    return i64 2
}
