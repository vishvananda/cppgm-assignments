function @main() -> i64 {
  slot $h__0 : i64
  slot $cond__1 : i64

  block ^entry:
    %t1 = addr $h__0
    call void @Holder_1___Holder(%t1)
    %t2 = addr $h__0
    store ptr 0, %t2
    %t3 = addr $h__0
    %t4 = load ptr %t3
    %t5 = cmp eq ptr %t4, 0
    branch %t5, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i64 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i64 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t6 = load i64 $cond__1
    %t7 = addr $h__0
    call void @Holder_1____Holder(%t7)
    return i64 %t6
}
function @Holder_1___Holder(%this : ptr) -> void {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    return void
}
function @Holder_1____Holder(%this : ptr) -> void {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    return void
}
