function @main() -> i64 {
  slot $b__0 : i64
  slot $cond__1 : i64

  block ^entry:
    %t1 = addr $b__0
    call void @Box_int___Box__ov3(%t1, 9)
    %t2 = addr $b__0
    %t3 = call i64 @get(%t2)
    %t4 = cmp eq i64 %t3, 9
    branch %t4, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i64 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i64 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t5 = load i64 $cond__1
    %t6 = addr $b__0
    call void @Box_int____Box(%t6)
    return i64 %t5
}
function @get(%b : ptr) -> i64 {
  slot $b__0 : i64

  block ^entry:
    %t1 = addr $b__0
    copyobj 4 %t1, %b
    %t2 = addr $b__0
    %t3 = load i32 %t2
    %t4 = addr $b__0
    call void @Box_int____Box(%t4)
    return i64 %t3
}
function @Box_int___Box__ov3(%this : ptr, %value : i64) -> void {
  slot $this : ptr
  slot $value : i32

  block ^entry:
    store ptr %this, $this
    store i32 %value, $value
    %t1 = load i32 $value
    %t2 = load ptr $this
    store i32 %t1, %t2
    return void
}
function @Box_int____Box(%this : ptr) -> void {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    return void
}
