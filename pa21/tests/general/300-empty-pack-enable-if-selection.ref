function @main() -> i64 {
  slot $alloc : i32
  slot $value : i32

  block ^entry:
    store i32 0, $alloc
    store i32 0, $value
    %t1 = addr $alloc
    %t2 = addr $value
    %t3 = call i64 @traits_int___construct(%t1, %t2)
    return i64 %t3
}
function @traits_int___construct(%__param0 : ptr, %__param1 : ptr) -> i64 {
  slot $__param0 : ptr
  slot $__param1 : ptr

  block ^entry:
    store ptr %__param0, $__param0
    store ptr %__param1, $__param1
    return i64 1
}
