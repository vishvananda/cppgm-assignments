function @main() -> i64 {
  slot $p : ptr
  slot $g__0 : i64

  block ^entry:
    store ptr 0, $p
    %t1 = addr $g__0
    %t2 = load ptr $p
    %t3 = binary shl i64 1, 32
    %t4 = binary shr i64 %t3, 32
    call void @G_int_____G(%t1, %t2, %t4)
    %t5 = addr $g__0
    call void @G_int______G(%t5)
    return i64 0
}
function @G_int______G(%this : ptr) -> void {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    return void
}
function @G_int_____G(%this : ptr, %b : ptr, %n : i64) -> void {
  slot $this : ptr
  slot $b : ptr
  slot $n : i64

  block ^entry:
    store ptr %this, $this
    store ptr %b, $b
    store i64 %n, $n
    return void
}
