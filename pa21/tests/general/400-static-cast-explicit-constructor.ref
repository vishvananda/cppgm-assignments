function @read(%b : ptr) -> i64 {
  slot $b__0 : i64

  block ^entry:
    %t1 = addr $b__0
    copyobj 4 %t1, %b
    %t2 = addr $b__0
    %t3 = load i32 %t2
    return i64 %t3
}
function @main() -> i64 {
  slot $tmpobj__1 : i64

  block ^entry:
    %t1 = addr $tmpobj__1
    call void @box__box(%t1, 7)
    %t2 = call i64 @read(%t1)
    %t3 = binary sub i64 %t2, 7
    return i64 %t3
}
function @box__box(%this : ptr, %x : i64) -> void {
  slot $this : ptr
  slot $x : i32

  block ^entry:
    store ptr %this, $this
    store i32 %x, $x
    %t1 = load i32 $x
    %t2 = load ptr $this
    store i32 %t1, %t2
    return void
}
