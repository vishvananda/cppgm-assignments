function @main() -> i64 {
  block ^entry:
    %t1 = binary shl i64 1, 32
    %t2 = binary shr i64 %t1, 32
    %t3 = call i64 @f(0, %t2)
    return i64 %t3
}
function @f(%__param0 : ptr, %__param1 : i64) -> i64 {
  slot $__param0 : ptr
  slot $__param1 : i64

  block ^entry:
    store ptr %__param0, $__param0
    store i64 %__param1, $__param1
    return i64 7
}
