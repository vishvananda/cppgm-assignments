function @main() -> i64 {
  slot $cond__1 : i64

  block ^entry:
    %t1 = call i64 @f(0)
    branch %t1, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i64 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i64 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t2 = load i64 $cond__1
    return i64 %t2
}
function @f(%x : i64) -> i64 {
  slot $x : i32
  slot $b : u8

  block ^entry:
    store i32 %x, $x
    store u8 1, $b
    %t1 = load u8 $b
    return i64 %t1
}
