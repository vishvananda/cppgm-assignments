function @g() -> i64 {
  block ^entry:
    %t1 = call i64 @f(1)
    return i64 %t1
}
function @f(%t : i64) -> i64 {
  slot $t : i32
  slot $x : i32

  block ^entry:
    store i32 %t, $t
    branch 1, ^if_then_1, ^if_else_2

  block ^if_then_1:
    %t1 = load i32 $t
    store i32 %t1, $x
    %t2 = load i32 $x
    return i64 %t2

  block ^if_else_2:
    jump ^if_end_3

  block ^if_end_3:
    return i64 0
}
