global @which : i32 = zero

function @g() -> i64 {
  slot $a__0 : i64

  block ^entry:
    %t1 = addr $a__0
    call void @h(%t1)
    %t2 = load i32 @which
    %t3 = addr $a__0
    call void @A_int____A(%t3)
    return i64 %t2
}
function @A_int___A__ov2(%this : ptr, %__param1 : ptr) -> void {
  slot $this : ptr
  slot $__param1 : ptr

  block ^entry:
    store ptr %this, $this
    store ptr %__param1, $__param1
    store i32 2, @which
    return void
}
function @A_int____A(%this : ptr) -> void {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
