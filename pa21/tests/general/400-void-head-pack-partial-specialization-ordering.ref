declare function @expect(%arg0 : ptr) -> i32 [binding=strong, object=_Z6expectPc]

function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $p : ptr
  slot $q : ptr

  block ^entry:
    store ptr 0, $p
    store ptr 0, $q
    %t1 = load ptr $p
    %t2 = call i32 @expect(%t1)
    %t3 = load ptr $q
    %t4 = call i32 @expect(%t3)
    %t5 = binary add i32 %t2, %t4
    return i32 %t5
}
