function @main() -> i64 {
  slot $w__0 : i64
  slot $cond__1 : i64

  block ^entry:
    %t1 = addr $w__0
    call void @wrapper_int___wrapper(%t1)
    %t2 = addr $w__0
    %t3 = call i64 @run(%t2)
    %t4 = cmp eq i64 %t3, 3
    branch %t4, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i64 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i64 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t5 = load i64 $cond__1
    %t6 = addr $w__0
    call void @wrapper_int____wrapper(%t6)
    return i64 %t5
}
function @wrapper_int___wrapper(%this : ptr) -> void {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    return void
}
function @wrapper_int____wrapper(%this : ptr) -> void {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    return void
}
function @run(%w : ptr) -> i64 {
  slot $w : ptr

  block ^entry:
    store ptr %w, $w
    %t1 = load ptr $w
    %t2 = call i64 @wrapper_int___cast(%t1, 3)
    return i64 %t2
}
function @wrapper_int___cast(%this : ptr, %value : i64) -> i64 {
  slot $this : ptr
  slot $value : i32

  block ^entry:
    store ptr %this, $this
    store i32 %value, $value
    %t1 = load i32 $value
    return i64 %t1
}
