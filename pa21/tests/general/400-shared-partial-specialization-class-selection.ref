function @make() -> obj<8x8> [binding=strong, object=_Z4makev] {
  slot $p : obj<8x8>
  slot $retobj__1 : obj<8x8>

  block ^entry:
    %t1 = addr $p
    %t2 = addr $p
    %t3 = index i8 [projection=field] %t2, 0
    store i64 7, %t3
    %t4 = addr $retobj__1
    %t5 = addr $p
    copyobj 8x8 %t5, %t4
    return obj<8x8> $retobj__1
}
function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $tmpobj__1 : obj<8x8>

  block ^entry:
    %t1 = addr $tmpobj__1
    %t2 = call obj<8x8> @make()
    copyobj 8x8 %t2, %t1
    %t3 = index i8 [projection=field] %t1, 0
    %t4 = load i64 %t3
    %t5 = convert trunc i32 i64 %t4
    return i32 %t5
}
