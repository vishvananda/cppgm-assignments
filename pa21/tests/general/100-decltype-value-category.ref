global @global_value : i32 [binding=strong, object=_Z12global_value] = 0

function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $a : i32
  slot $b : ptr
  slot $cond__1 : i32

  block ^entry:
    store i32 0, $a
    %t1 = addr @global_value
    store ptr %t1, $b
    %t2 = load ptr $b
    store i32 5, %t2
    %t3 = load i32 @global_value
    %t4 = cmp eq i32 %t3, 5
    branch %t4, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i32 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i32 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t5 = load i32 $cond__1
    return i32 %t5
}
