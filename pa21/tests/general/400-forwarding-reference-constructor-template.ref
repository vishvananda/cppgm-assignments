function @main() -> i64 {
  slot $x : i32
  slot $box__0 : i64

  block ^entry:
    store i32 7, $x
    %t1 = addr $box__0
    %t2 = addr $x
    call void @RefBox_int_____RefBox__ov2(%t1, %t2)
    %t3 = addr $box__0
    %t4 = load ptr %t3
    %t5 = load i32 %t4
    %t6 = addr $box__0
    call void @RefBox_int______RefBox(%t6)
    return i64 %t5
}
function @RefBox_int______RefBox(%this : ptr) -> void {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    return void
}
function @RefBox_int_____RefBox__ov2(%this : ptr, %input : ptr) -> void {
  slot $this : ptr
  slot $input : ptr

  block ^entry:
    store ptr %this, $this
    store ptr %input, $input
    %t1 = load ptr $input
    %t2 = load ptr $this
    store ptr %t1, %t2
    return void
}
