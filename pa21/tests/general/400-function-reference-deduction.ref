function @square(%x : i64) -> i64 {
  slot $x : i32

  block ^entry:
    store i32 %x, $x
    %t1 = load i32 $x
    %t2 = load i32 $x
    %t3 = binary mul i64 %t1, %t2
    return i64 %t3
}
function @main() -> i64 {
  slot $cond__1 : i64

  block ^entry:
    %t1 = addr @square
    %t2 = call i64 @apply(%t1, 3)
    %t3 = cmp eq i64 %t2, 9
    branch %t3, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i64 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i64 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t4 = load i64 $cond__1
    return i64 %t4
}
function @apply(%fn : ptr, %value : i64) -> i64 {
  slot $fn : ptr
  slot $value : i32

  block ^entry:
    store ptr %fn, $fn
    store i32 %value, $value
    %t1 = load i32 $value
    %t2 = load ptr $fn
    %t3 = call i64 %t2(%t1)
    return i64 %t3
}
