function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $x : i32
  slot $cond__1 : i32

  block ^entry:
    store i32 7, $x
    %t1 = load i32 $x
    %t2 = cmp eq i32 %t1, 7
    branch %t2, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i32 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i32 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t3 = load i32 $cond__1
    return i32 %t3
}
