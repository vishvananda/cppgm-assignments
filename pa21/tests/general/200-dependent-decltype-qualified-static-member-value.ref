function @main() -> i64 {
  slot $cond__1 : i64

  block ^entry:
    branch 1, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i64 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i64 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t1 = load i64 $cond__1
    return i64 %t1
}
