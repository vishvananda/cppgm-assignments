function @f(%x : i64) -> i64 {
  slot $x : i32

  block ^entry:
    store i32 %x, $x
    %t1 = load i32 $x
    return i64 %t1
}
function @main() -> i64 {
  slot $x__0 : i64

  block ^entry:
    %t1 = addr $x__0
    call void @From_int___From__ov3(%t1, 0)
    %t2 = addr $x__0
    %t3 = call i64 @From_int___operatorT(%t2)
    %t4 = call i64 @f(%t3)
    %t5 = addr $x__0
    call void @From_int____From(%t5)
    return i64 %t4
}
function @From_int___operatorT(%this : ptr) -> i64 {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    %t1 = load ptr $this
    %t2 = load i32 %t1
    return i64 %t2
}
function @From_int___From__ov3(%this : ptr, %value : i64) -> void {
  slot $this : ptr
  slot $value : i32

  block ^entry:
    store ptr %this, $this
    store i32 %value, $value
    %t1 = load i32 $value
    %t2 = load ptr $this
    store i32 %t1, %t2
    return void
}
function @From_int____From(%this : ptr) -> void {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    return void
}
