function @main() -> i64 {
  block ^entry:
    %t1 = call i64 @distance_like(0, 0)
    return i64 %t1
}
function @distance_like(%__param0 : ptr, %__param1 : ptr) -> i64 {
  slot $__param0 : ptr
  slot $__param1 : ptr

  block ^entry:
    store ptr %__param0, $__param0
    store ptr %__param1, $__param1
    return i64 0
}
