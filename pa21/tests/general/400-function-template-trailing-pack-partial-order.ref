function @g() -> i64 {
  block ^entry:
    return i64 7
}
function @main() -> i64 {
  slot $fp : ptr

  block ^entry:
    %t1 = addr @g
    store ptr %t1, $fp
    %t2 = addr $fp
    %t3 = call i64 @invoke__ov2(%t2)
    %t4 = cmp ne i64 %t3, 7
    return i64 %t4
}
function @invoke__ov2(%f : ptr) -> i64 {
  slot $f : ptr

  block ^entry:
    store ptr %f, $f
    %t1 = load ptr $f
    %t2 = load ptr %t1
    %t3 = call i64 %t2()
    return i64 %t3
}
