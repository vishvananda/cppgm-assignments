function @main() -> i64 {
  block ^entry:
    %t1 = binary shl i64 1, 32
    %t2 = binary shr i64 %t1, 32
    %t3 = call i64 @std____1____copy_n(0, %t2, 0)
    return i64 %t3
}
function @std____1____copy_n(%__param0 : ptr, %__param1 : i64, %__param2 : ptr) -> i64 {
  slot $__param0 : ptr
  slot $__param1 : i64
  slot $__param2 : ptr

  block ^entry:
    store ptr %__param0, $__param0
    store i64 %__param1, $__param1
    store ptr %__param2, $__param2
    return i64 7
}
