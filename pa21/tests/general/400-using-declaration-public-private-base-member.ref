function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $value : obj<1x1>
  slot $cond__1 : i32

  block ^entry:
    %t1 = addr $value
    %t2 = addr $value
    %t3 = call ptr @owner__call_begin(%t2)
    %t4 = cmp eq ptr %t3, 0
    branch %t4, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i32 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i32 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t5 = load i32 $cond__1
    return i32 %t5
}
function @owner__call_begin(%this : ptr) -> ptr [binding=weak, object=_ZN5owner10call_beginEv] {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    %t1 = load ptr $this
    %t2 = index i8 [projection=field] %t1, 0
    %t3 = index i8 [projection=base_subobject] %t2, 0
    %t4 = call ptr @layout__begin(%t3)
    return ptr %t4
}
function @layout__begin(%this : ptr) -> ptr [binding=weak, object=_ZN6layout5beginEv] {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    return ptr 0
}
