function @main() -> i64 {
  slot $a__3 : i32
  slot $a__2 : i32
  slot $a__1 : i32
  slot $a__0 : i32
  slot $b__3 : i32
  slot $b__2 : i32
  slot $b__1 : i32
  slot $b__0 : i32

  block ^entry:
    store i32 0, $a__0
    store i32 1, $a__1
    store i32 2, $a__2
    store i32 3, $a__3
    store i32 4, $b__0
    store i32 5, $b__1
    store i32 6, $b__2
    store i32 7, $b__3
    %t1 = addr $a__0
    %t2 = addr $b__0
    %t3 = call i64 @same_extent(%t1, %t2)
    %t4 = binary sub i64 %t3, 4
    return i64 %t4
}
function @same_extent(%__param0 : ptr, %__param1 : ptr) -> i64 {
  slot $__param0 : ptr
  slot $__param1 : ptr

  block ^entry:
    store ptr %__param0, $__param0
    store ptr %__param1, $__param1
    return i64 4
}
