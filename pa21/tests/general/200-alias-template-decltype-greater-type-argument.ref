function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $x : u8
  slot $cond__1 : i32

  block ^entry:
    store u8 1, $x
    %t1 = load u8 $x
    branch %t1, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i32 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i32 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t2 = load i32 $cond__1
    return i32 %t2
}
