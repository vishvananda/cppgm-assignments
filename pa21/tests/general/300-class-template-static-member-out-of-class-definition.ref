global @D_int___k : i64 = 7

function @main() -> i64 {
  slot $tmpobj__1 : i64

  block ^entry:
    %t1 = addr $tmpobj__1
    call void @D_int___R__R(%t1)
    %t2 = call i64 @D_int___R__f(%t1)
    %t3 = binary shl i64 7, 32
    %t4 = binary shr i64 %t3, 32
    %t5 = binary sub i64 %t2, %t4
    return i64 %t5
}
function @D_int___R__f(%this : ptr) -> i64 {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    return i64 7
}
function @D_int___R__R(%this : ptr) -> void {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    return void
}
