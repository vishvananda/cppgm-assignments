function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  block ^entry:
    %t1 = call i32 @f()
    %t2 = binary sub i32 %t1, 1
    return i32 %t2
}
function @f() -> i32 [binding=weak, object=_Z1fIiiEiv] {
  slot $cond__1 : i32

  block ^entry:
    branch 1, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i32 1, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i32 0, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t1 = load i32 $cond__1
    return i32 %t1
}
