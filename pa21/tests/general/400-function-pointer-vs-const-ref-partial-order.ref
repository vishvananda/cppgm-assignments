  block ^entry:
    %t1 = addr @f
    %t2 = call i64 @pick__ov2(%t1)
    %t3 = binary sub i64 %t2, 2
    return i64 %t3
}
function @pick__ov2(%__param0 : ptr) -> i64 {
  slot $__param0 : ptr

  block ^entry:
    store ptr %__param0, $__param0
    return i64 2
}
