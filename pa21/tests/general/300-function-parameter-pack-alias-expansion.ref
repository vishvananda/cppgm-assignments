function @main() -> i64 {
  slot $lor__1 : i64

  block ^entry:
    %t1 = call i64 @Box____f()
    %t2 = cmp ne i64 %t1, 0
    branch %t2, ^lor_short_2, ^lor_rhs_1

  block ^lor_rhs_1:
    %t3 = call i64 @Box_int__float___f(1, 2.0f)
    %t4 = cmp ne i64 %t3, 2
    %t5 = cmp ne i64 %t4, 0
    store i64 %t5, $lor__1
    jump ^lor_end_3

  block ^lor_short_2:
    store i64 1, $lor__1
    jump ^lor_end_3

  block ^lor_end_3:
    %t6 = load i64 $lor__1
    return i64 %t6
}
