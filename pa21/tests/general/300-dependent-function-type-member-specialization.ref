function @main() -> i64 {
  slot $tmpobj__1 : i64

  block ^entry:
    %t1 = addr $tmpobj__1
    call void @Function_void_____Function(%t1)
    %t2 = call i64 @Function_void_____get(%t1)
    %t3 = binary sub i64 %t2, 7
    return i64 %t3
}
function @Function_void_____get(%this : ptr) -> i64 {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    %t1 = load ptr $this
    %t2 = load i32 %t1
    return i64 %t2
}
function @Function_void_____Function(%this : ptr) -> void {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    %t1 = load ptr $this
    call void @Value_void_____Value(%t1)
    return void
}
function @Value_void_____Value(%this : ptr) -> void {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    %t1 = load ptr $this
    store i32 7, %t1
    return void
}
