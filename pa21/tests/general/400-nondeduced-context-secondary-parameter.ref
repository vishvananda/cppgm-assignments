function @main() -> i64 {
  slot $cond__1 : i64

  block ^entry:
    %t1 = call i64 @choose(1, 2)
    %t2 = cmp eq i64 %t1, 1
    branch %t2, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i64 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i64 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t3 = load i64 $cond__1
    return i64 %t3
}
function @choose(%__param0 : i64, %__param1 : i64) -> i64 {
  slot $__param0 : i32
  slot $__param1 : i32

  block ^entry:
    store i32 %__param0, $__param0
    store i32 %__param1, $__param1
    return i64 1
}
