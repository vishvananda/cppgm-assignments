function @main() -> i64 {
  slot $arg__0 : i64
  slot $cond__1 : i64

  block ^entry:
    %t1 = addr $arg__0
    %t2 = binary shl i64 7, 32
    %t3 = binary shr i64 %t2, 32
    call void @Box_long_int__int___Box__ov3(%t1, %t3)
    %t4 = addr $arg__0
    %t5 = call i64 @unwrap(%t4)
    %t6 = binary shl i64 7, 32
    %t7 = binary shr i64 %t6, 32
    %t8 = cmp eq i64 %t5, %t7
    branch %t8, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i64 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i64 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t9 = load i64 $cond__1
    %t10 = addr $arg__0
    call void @Box_long_int__int____Box(%t10)
    return i64 %t9
}
function @Box_long_int__int___Box__ov3(%this : ptr, %value : i64) -> void {
  slot $this : ptr
  slot $value : i64

  block ^entry:
    store ptr %this, $this
    store i64 %value, $value
    %t1 = load i64 $value
    %t2 = load ptr $this
    store i64 %t1, %t2
    return void
}
function @Box_long_int__int____Box(%this : ptr) -> void {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    return void
}
function @unwrap(%arg : ptr) -> i64 {
  slot $arg__0 : i64

  block ^entry:
    %t1 = addr $arg__0
    call void @Box_long_int__int___Box__ov2(%t1, %arg)
    %t2 = addr $arg__0
    %t3 = load i64 %t2
    %t4 = addr $arg__0
    call void @Box_long_int__int____Box(%t4)
    return i64 %t3
}
function @Box_long_int__int___Box__ov2(%this : ptr, %other : ptr) -> void {
  slot $this : ptr
  slot $other : ptr

  block ^entry:
    store ptr %this, $this
    store ptr %other, $other
    %t1 = load ptr $other
    %t2 = load i64 %t1
    %t3 = load ptr $this
    store i64 %t2, %t3
