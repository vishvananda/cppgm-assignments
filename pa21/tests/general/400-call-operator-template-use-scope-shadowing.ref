function @main() -> i64 {
  slot $cond__1 : i64

  block ^entry:
    %t1 = call i64 @N__copy_move_unwrap_iters(1, 2, 3)
    %t2 = cmp eq i64 %t1, 7
    branch %t2, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i64 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i64 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t3 = load i64 $cond__1
    return i64 %t3
}
function @N__copy_move_unwrap_iters(%first : i64, %last : i64, %out : i64) -> i64 {
  slot $first : i32
  slot $last : i32
  slot $out : i32
  slot $tmpobj__1 : i64

  block ^entry:
    store i32 %first, $first
    store i32 %last, $last
    store i32 %out, $out
    %t1 = addr $tmpobj__1
    call void @N____copy_impl____copy_impl(%t1)
    %t2 = load i32 $first
    %t3 = load i32 $last
    %t4 = load i32 $out
    %t5 = call i64 @N____copy_impl__operator__(%t1, %t2, %t3, %t4)
    return i64 %t5
}
function @N____copy_impl__operator__(%this : ptr, %__param1 : i64, %__param2 : i64, %__param3 : i64) -> i64 {
  slot $this : ptr
  slot $__param1 : i32
  slot $__param2 : i32
  slot $__param3 : i32

  block ^entry:
    store ptr %this, $this
    store i32 %__param1, $__param1
    store i32 %__param2, $__param2
    store i32 %__param3, $__param3
    return i64 7
}
function @N____copy_impl____copy_impl(%this : ptr) -> void {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    return void
}
