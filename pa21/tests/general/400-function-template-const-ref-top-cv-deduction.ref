function @f(%current : i64) -> i64 {
  slot $current : i64
  slot $refarg__1 : i64

  block ^entry:
    store i64 %current, $current
    %t1 = addr $current
    %t2 = load i64 $current
    %t3 = binary shl i64 2, 32
    %t4 = binary shr i64 %t3, 32
    %t5 = binary mul i64 %t4, %t2
    store i64 %t5, $refarg__1
    %t6 = addr $refarg__1
    %t7 = call ptr @max_like(%t1, %t6)
    %t8 = load i64 %t7
    return i64 %t8
}
function @main() -> i64 {
  slot $cond__1 : i64

  block ^entry:
    %t1 = binary shl i64 3, 32
    %t2 = binary shr i64 %t1, 32
    %t3 = call i64 @f(%t2)
    %t4 = binary shl i64 6, 32
    %t5 = binary shr i64 %t4, 32
    %t6 = cmp eq i64 %t3, %t5
    branch %t6, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i64 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i64 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t7 = load i64 $cond__1
    return i64 %t7
}
function @max_like(%a : ptr, %b : ptr) -> ptr {
  slot $a : ptr
  slot $b : ptr
  slot $condaddr__1 : ptr

  block ^entry:
    store ptr %a, $a
    store ptr %b, $b
    %t1 = load ptr $a
    %t2 = load i64 %t1
    %t3 = load ptr $b
    %t4 = load i64 %t3
    %t5 = cmp ult i64 %t2, %t4
    branch %t5, ^condaddr_then_1, ^condaddr_else_2

  block ^condaddr_then_1:
    %t6 = load ptr $b
    store ptr %t6, $condaddr__1
    jump ^condaddr_end_3

  block ^condaddr_else_2:
    %t7 = load ptr $a
    store ptr %t7, $condaddr__1
    jump ^condaddr_end_3

  block ^condaddr_end_3:
    %t8 = load ptr $condaddr__1
    return ptr %t8
}
