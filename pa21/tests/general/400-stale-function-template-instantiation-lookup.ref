function @main() -> i64 {
  slot $n__1 : i64
  slot $n__0 : i64
  slot $cond__1 : i64

  block ^entry:
    %t1 = addr $n__0
    call void @node_int___node(%t1)
    %t2 = addr $n__0
    store ptr 0, %t2
    %t3 = addr $n__0
    %t4 = call ptr @descend(%t3)
    %t5 = addr $n__0
    %t6 = cmp eq ptr %t4, %t5
    branch %t6, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i64 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i64 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t7 = load i64 $cond__1
    %t8 = addr $n__0
    call void @node_int____node(%t8)
    return i64 %t7
}
function @node_int___node(%this : ptr) -> void {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    %t1 = load ptr $this
    call void @base__base(%t1)
    return void
}
function @node_int____node(%this : ptr) -> void {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    %t1 = load ptr $this
    call void @base___base(%t1)
    return void
}
function @descend(%nd : ptr) -> ptr {
  slot $nd : ptr

  block ^entry:
    store ptr %nd, $nd
    %t1 = load ptr $nd
    %t2 = call ptr @addrof(%t1)
    %t3 = load ptr $nd
    %t4 = call ptr @addrof__ov2(%t3)
    return ptr %t4
}
function @addrof(%x : ptr) -> ptr {
  slot $x : ptr

  block ^entry:
    store ptr %x, $x
    %t1 = load ptr $x
    return ptr %t1
}
function @addrof__ov2(%x : ptr) -> ptr {
  slot $x : ptr

  block ^entry:
    store ptr %x, $x
    %t1 = load ptr $x
    return ptr %t1
}
function @base__base(%this : ptr) -> void {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    return void
}
function @base___base(%this : ptr) -> void {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    return void
}
