function @main() -> i64 {
  slot $a__0 : i64

  block ^entry:
    %t1 = addr $a__0
    call void @Alloc__Alloc(%t1)
    %t2 = addr $a__0
    %t3 = call i64 @max_size_select(%t2)
    %t4 = addr $a__0
    call void @Alloc___Alloc(%t4)
    return i64 %t3
}
function @max_size_select(%a : ptr) -> i64 {
  slot $a : ptr

