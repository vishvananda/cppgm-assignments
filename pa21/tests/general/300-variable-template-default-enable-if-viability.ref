    store ptr %a, $a
    %t1 = load ptr $a
    %t2 = call i64 @Alloc__max_size(%t1)
    return i64 %t2
}
function @Alloc__Alloc(%this : ptr) -> void {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    return void
}
function @Alloc__max_size(%this : ptr) -> i64 {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    return i64 7
}
