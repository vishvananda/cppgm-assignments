function @f() -> i64 {
  slot $tmpobj__1 : i64

  block ^entry:
    %t1 = addr $tmpobj__1
    call void @make(%t1)
    %t2 = call i64 @P_int___get(%t1)
    return i64 %t2
}
function @P_int___get(%this : ptr) -> i64 {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    %t1 = load ptr $this
    %t2 = load i32 %t1
    return i64 %t2
}
