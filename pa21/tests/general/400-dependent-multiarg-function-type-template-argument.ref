function @main() -> i64 {
  slot $lor__1 : i64

  block ^entry:
    %t1 = cmp ne i64 1, 1
    branch %t1, ^lor_short_2, ^lor_rhs_1

  block ^lor_rhs_1:
    %t2 = cmp ne i64 0, 0
    %t3 = cmp ne i64 %t2, 0
    store i64 %t3, $lor__1
    jump ^lor_end_3

  block ^lor_short_2:
    store i64 1, $lor__1
    jump ^lor_end_3

  block ^lor_end_3:
    %t4 = load i64 $lor__1
    return i64 %t4
}
