    store i32 %current, $current
    %t1 = addr $next
    copyobj 8x8 %next, %t1
    %t2 = load i32 $current
    %t3 = cmp eq i32 %t2, 1
    branch %t3, ^land_rhs_4, ^land_short_5

  block ^land_rhs_4:
    %t4 = addr $next
    %t5 = index i8 [projection=field] %t4, 0
    %t6 = load i64 %t5
    %t7 = convert sext i64 i32 10
