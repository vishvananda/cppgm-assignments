function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $cond__1 : i32
  slot $argobj__2 : obj<8x8>

  block ^entry:
    %t1 = addr $argobj__2
    %t2 = convert sext i64 i32 10
    call void @known_digits_10__false___known_digits__ov2(%t1, %t2)
    %t3 = call u8 @accepts_known_digits(1, $argobj__2)
    branch %t3, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i32 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i32 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t4 = load i32 $cond__1
