global @before : ptr [binding=strong, object=_Z6before] = 0

function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $x : i8
  slot $refarg__1 : i8
  slot $cond__2 : i32

  block ^entry:
    store i8 0, $x
    %t1 = addr $x
    store i8 97, $refarg__1
    %t2 = addr $refarg__1
    call void @s_char___assign(%t1, %t2)
    %t3 = load i8 $x
    %t4 = convert sext i32 i8 %t3
    %t5 = cmp eq i32 %t4, 97
    branch %t5, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i32 0, $cond__2
    jump ^cond_end_3

  block ^cond_else_2:
    store i32 1, $cond__2
    jump ^cond_end_3

  block ^cond_end_3:
    %t6 = load i32 $cond__2
    return i32 %t6
}
function @s_char___assign(%a : ptr [pass=reference], %b : ptr [pass=reference]) -> void [binding=weak, object=_ZN1sIcE6assignERcRKc] {
  slot $a : ptr
  slot $b : ptr

  block ^entry:
    store ptr %a, $a
    store ptr %b, $b
    %t1 = load ptr $b
    %t2 = load i8 %t1
    %t3 = load ptr $a
    store i8 %t2, %t3
    return void
}
