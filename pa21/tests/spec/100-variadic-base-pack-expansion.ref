function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $value : obj<1x1>
  slot $cond__1 : i32

  block ^entry:
    %t1 = addr $value
    %t2 = addr $value
    %t3 = call i32 @sum_bases_one__two___sum(%t2)
    %t4 = cmp eq i32 %t3, 3
    branch %t4, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i32 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i32 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t5 = load i32 $cond__1
    return i32 %t5
}
function @sum_bases_one__two___sum(%this : ptr) -> i32 [binding=weak, object=_ZNK9sum_basesIJ3one3twoEE3sumEv] {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    %t1 = load ptr $this
    %t2 = index i8 [projection=base_subobject] %t1, 0
    %t3 = call i32 @sum_bases_two___sum(%t2)
    %t4 = binary add i32 1, %t3
    return i32 %t4
}
function @sum_bases_two___sum(%this : ptr) -> i32 [binding=weak, object=_ZNK9sum_basesIJ3twoEE3sumEv] {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    %t1 = load ptr $this
    %t2 = index i8 [projection=base_subobject] %t1, 0
    %t3 = call i32 @sum_bases____sum(%t2)
    %t4 = binary add i32 2, %t3
    return i32 %t4
}
function @sum_bases____sum(%this : ptr) -> i32 [binding=weak, object=_ZNK9sum_bases3sumEv] {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    return i32 0
}
