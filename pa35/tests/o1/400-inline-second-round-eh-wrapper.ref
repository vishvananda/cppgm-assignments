function @caller(%p : ptr) -> ptr {
  block ^entry:
    eh_try ^dispatch
    eh_end
    return ptr %p

  block ^dispatch:
    resume
}
function @mid(%p : ptr) -> ptr {
  block ^entry:
    return ptr %p
}
function @leaf(%p : ptr) -> ptr {
  slot $p : ptr

  block ^entry:
    store ptr %p, $p
    %t1 = load ptr $p
    return ptr %t1
}
