function @f(%i : i32) -> i32 [binding=strong, object=_Z1fi] {
  slot $i : i32
  slot $ascii : obj<4x1>

  block ^entry:
    store i32 %i, $i
    %t1 = addr $ascii
    store i8 0, %t1
    %t2 = index i8 %t1, 1
    store i8 0, %t2
    %t3 = index i8 %t1, 2
    store i8 0, %t3
    %t4 = index i8 %t1, 3
    store i8 0, %t4
    %t7 = load i32 $i
    %t8 = index i8 [projection=array_element] %t1, %t7
    store i8 42, %t8
    %t11 = load i32 $i
    %t12 = index i8 [projection=array_element] %t1, %t11
    %t13 = load i8 %t12
    %t14 = convert sext i32 i8 %t13
    return i32 %t14
}
