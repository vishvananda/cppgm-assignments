function @f(%s : ptr, %v : i32) -> i32 [binding=strong, object=_Z1fP1Si] {
  slot $s : ptr
  slot $v : i32

  block ^entry:
    store ptr %s, $s
    store i32 %v, $v
    %t1 = load i32 $v
    %t2 = load ptr $s
    %t3 = index i8 [projection=field] %t2, 8
    store i32 %t1, %t3
    %t4 = load ptr $s
    %t5 = index i8 [projection=field] %t4, 8
    %t6 = load i64 %t5
    %t7 = convert trunc i32 i64 %t6
    return i32 %t7
}
