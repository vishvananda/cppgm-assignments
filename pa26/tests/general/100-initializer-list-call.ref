function @sum(%xs : ptr) -> i64 {
  slot $xs__1 : i64
  slot $xs__0 : i64
  slot $s : i32
  slot $__idx1 : i32
  slot $x : i32

  block ^entry:
    %t1 = addr $xs__0
    copyobj 16 %t1, %xs
    store i32 0, $s
    store i32 0, $__idx1
    jump ^for_cond_1

  block ^for_cond_1:
    %t2 = load i32 $__idx1
    %t3 = addr $xs__0
    %t4 = index i8 %t3, 8
    %t5 = load i64 %t4
    %t6 = binary shl i64 %t2, 32
    %t7 = binary shr i64 %t6, 32
    %t8 = cmp lt i64 %t7, %t5
    branch %t8, ^for_body_2, ^for_end_4

  block ^for_body_2:
    %t9 = addr $xs__0
    %t10 = load ptr %t9
    %t11 = load i32 $__idx1
    %t12 = index i32 %t10, %t11
    %t13 = load i32 %t12
    store i32 %t13, $x
    %t14 = load i32 $s
    %t15 = load i32 $x
    %t16 = binary add i64 %t14, %t15
    store i32 %t16, $s
    jump ^for_iter_3

  block ^for_iter_3:
    %t17 = load i32 $__idx1
    %t18 = binary add i32 %t17, 1
    store i32 %t18, $__idx1
    jump ^for_cond_1

  block ^for_end_4:
    %t19 = load i32 $s
    return i64 %t19
}
function @main() -> i64 {
  slot $arg__2 : i64
  slot $arg__1 : i64
  slot $initlist__5 : i64
  slot $initlist__4 : i64
  slot $initlist__3 : i64

  block ^entry:
    %t1 = addr $arg__1
    store i64 1, $initlist__3
    store i64 2, $initlist__4
    store i64 3, $initlist__5
    %t2 = addr $initlist__3
    store ptr %t2, %t1
    %t3 = index i8 %t1, 8
    store i64 3, %t3
    %t4 = call i64 @sum(%t1)
    return i64 %t4
}
