function @take_direct(%direct : obj<4x4>) -> i32 [binding=strong, object=_Z11take_direct6Direct] {
  slot $direct : obj<4x4>

  block ^entry:
    %t1 = addr $direct
    copyobj 4x4 %direct, %t1
    %t2 = addr $direct
    %t3 = index i8 [projection=base_subobject] %t2, 0
    %t4 = index i8 [projection=field] %t3, 0
    %t5 = load i32 %t4
    return i32 %t5
}
