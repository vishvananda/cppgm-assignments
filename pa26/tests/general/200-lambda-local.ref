function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $f : ptr

  block ^entry:
    %t1 = addr @__lambda_main_t10_16
    %t2 = unary decay ptr %t1
    store ptr %t2, $f
    %t3 = load ptr $f
    %t4 = call i32 %t3(4) as (%arg0 : i32) -> i32
    return i32 %t4
}
function @__lambda_main_t10_16(%x : i32) -> i32 [binding=internal] {
  slot $x : i32

  block ^entry:
    store i32 %x, $x
    %t1 = load i32 $x
    %t2 = binary add i32 %t1, 1
    return i32 %t2
}
