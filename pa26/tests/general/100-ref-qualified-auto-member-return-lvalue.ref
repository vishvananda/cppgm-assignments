function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $x : obj<4x4>

  block ^entry:
    %t1 = addr $x
    %t2 = addr $x
    %t3 = call ptr @X__base(%t2)
    %t4 = index i8 [projection=field] %t3, 0
    store i32 3, %t4
    %t5 = addr $x
    %t6 = index i8 [projection=field] %t5, 0
    %t7 = load i32 %t6
    %t8 = binary sub i32 %t7, 3
    return i32 %t8
}
function @X__base(%this : ptr) -> ptr [binding=weak, object=_ZNR1X4baseEv] {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    %t1 = load ptr $this
    return ptr %t1
}
