function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $value : obj<2x1>
  slot $cond__1 : i32

  block ^entry:
    %t1 = addr $value
    store i8 97, %t1
    %t2 = index i8 %t1, 1
    store i8 0, %t2
    %t3 = addr $value
    %t4 = unary decay ptr %t3
    %t5 = index i8 [projection=array_element] %t4, 0
    %t6 = load i8 %t5
    %t7 = convert sext i32 i8 %t6
    %t8 = cmp eq i32 %t7, 97
    branch %t8, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i32 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i32 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t9 = load i32 $cond__1
    return i32 %t9
}
