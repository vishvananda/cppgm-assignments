function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $a : obj<12x4>

  block ^entry:
    %t1 = addr $a
    store i32 1, %t1
    %t2 = index i8 %t1, 4
    store i32 2, %t2
    %t3 = index i8 %t1, 8
    store i32 3, %t3
    %t4 = addr $a
    %t5 = unary decay ptr %t4
    %t6 = index i32 [projection=array_element] %t5, 1
    %t7 = load i32 %t6
    return i32 %t7
}
