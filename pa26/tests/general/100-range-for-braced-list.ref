function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $s : i32
  slot $__range1 : obj<12x4>
  slot $__idx2 : i32
  slot $x : i32

  block ^entry:
    store i32 0, $s
    %t1 = addr $__range1
    store i32 1, %t1
    %t2 = index i8 %t1, 4
    store i32 2, %t2
    %t3 = index i8 %t1, 8
    store i32 3, %t3
    store i32 0, $__idx2
    jump ^for_cond_1

  block ^for_cond_1:
    %t4 = load i32 $__idx2
    %t5 = cmp lt i32 %t4, 3
    branch %t5, ^for_body_2, ^for_end_4

  block ^for_body_2:
    %t6 = addr $__range1
    %t7 = unary decay ptr %t6
    %t8 = load i32 $__idx2
    %t9 = index i32 [projection=array_element] %t7, %t8
    %t10 = load i32 %t9
    store i32 %t10, $x
    %t11 = load i32 $s
    %t12 = load i32 $x
    %t13 = binary add i32 %t11, %t12
    store i32 %t13, $s
    jump ^for_iter_3

  block ^for_iter_3:
    %t14 = load i32 $__idx2
    %t15 = binary add i32 %t14, 1
    store i32 %t15, $__idx2
    jump ^for_cond_1

  block ^for_end_4:
    %t16 = load i32 $s
    return i32 %t16
}
