function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $b : obj<1x1>

  block ^entry:
    %t1 = addr $b
    %t2 = addr $b
    %t3 = call i32 @Box_int___f(%t2)
    return i32 %t3
}
function @Box_int___f(%this : ptr) -> i32 [binding=weak, object=_ZN3BoxIiE1fEv] {
  slot $this : ptr
  slot $xs : obj<8x4>
  slot $total : i32
  slot $__idx1 : i32
  slot $x : i32

  block ^entry:
    store ptr %this, $this
    %t1 = addr $xs
    store i32 1, %t1
    %t2 = index i8 %t1, 4
    store i32 2, %t2
    store i32 0, $total
    store i32 0, $__idx1
    jump ^for_cond_1

  block ^for_cond_1:
    %t3 = load i32 $__idx1
    %t4 = cmp lt i32 %t3, 2
    branch %t4, ^for_body_2, ^for_end_4

  block ^for_body_2:
    %t5 = addr $xs
    %t6 = unary decay ptr %t5
    %t7 = load i32 $__idx1
    %t8 = index i32 [projection=array_element] %t6, %t7
    %t9 = load i32 %t8
    store i32 %t9, $x
    %t10 = load i32 $total
    %t11 = load i32 $x
    %t12 = binary add i32 %t10, %t11
    store i32 %t12, $total
    jump ^for_iter_3

  block ^for_iter_3:
    %t13 = load i32 $__idx1
    %t14 = binary add i32 %t13, 1
    store i32 %t14, $__idx1
    jump ^for_cond_1

  block ^for_end_4:
    %t15 = load i32 $total
    return i32 %t15
}
