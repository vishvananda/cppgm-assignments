unsigned int float_bits(float value)
{
  unsigned int bits = 0;
  __builtin_memcpy(&bits, &value, sizeof(bits));
  return bits;
}

unsigned long long double_bits(double value)
{
  unsigned long long bits = 0;
  __builtin_memcpy(&bits, &value, sizeof(bits));
  return bits;
}

bool is_x87_signaling_nan(long double value, bool negative)
{
#if __LDBL_MANT_DIG__ == 64 && __LDBL_MAX_EXP__ == 16384
  unsigned char bits[sizeof(long double)] = {};
  __builtin_memcpy(bits, &value, sizeof(value));
  return bits[0] == 0x00 &&
         bits[1] == 0x00 &&
         bits[2] == 0x00 &&
         bits[3] == 0x00 &&
         bits[4] == 0x00 &&
         bits[5] == 0x00 &&
         bits[6] == 0x00 &&
         bits[7] == 0xA0 &&
         bits[8] == 0xFF &&
         bits[9] == (negative ? 0xFF : 0x7F);
#else
  (void)value;
  (void)negative;
  return true;
#endif
}

int main()
{
  double quiet_double = __builtin_nan("");
  float quiet_float = __builtin_nanf("");
  long double quiet_long_double = __builtin_nanl("");
  double signaling_double = __builtin_nans("");
  float signaling_float = __builtin_nansf("");
  long double signaling_long_double = __builtin_nansl("");
  double negative_signaling_double = -__builtin_nans("");
  float negative_signaling_float = -__builtin_nansf("");
  long double negative_signaling_long_double = -__builtin_nansl("");
  return quiet_double == quiet_double ||
         quiet_float == quiet_float ||
         quiet_long_double == quiet_long_double ||
         signaling_double == signaling_double ||
         signaling_float == signaling_float ||
         signaling_long_double == signaling_long_double ||
         float_bits(signaling_float) != 0x7FA00000U ||
         double_bits(signaling_double) != 0x7FF4000000000000ULL ||
         !is_x87_signaling_nan(signaling_long_double, false) ||
         float_bits(negative_signaling_float) != 0xFFA00000U ||
         double_bits(negative_signaling_double) != 0xFFF4000000000000ULL ||
         !is_x87_signaling_nan(negative_signaling_long_double, true) ? 1 : 0;
}
