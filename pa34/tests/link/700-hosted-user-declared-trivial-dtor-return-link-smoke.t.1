struct Result {
  bool first;
  unsigned long second;

  Result(bool first_in = false, unsigned long second_in = 0)
      : first(first_in), second(second_in) {}
  ~Result() = default;
};

extern Result host_choose(unsigned long seed);

int main()
{
  Result result = host_choose(7);
  return result.first && result.second == 8 ? 0 : 1;
}
