#include "600-hosted-std-vector-pair-abi-link-smoke.shared.h"

bool accept_std_pair_ranges(
    const std::vector<
        std::pair<unsigned long, unsigned long>,
        std::allocator<std::pair<unsigned long, unsigned long> > > & ranges)
{
  return ranges.size() == 1 &&
         ranges[0].first == 1 &&
         ranges[0].second == 2;
}
