#define CPPGM_PA34_LABEL_PREFIX
#define CPPGM_PA34_STRINGIZE_IMPL(x) #x
#define CPPGM_PA34_STRINGIZE(x) CPPGM_PA34_STRINGIZE_IMPL(x)

extern "C++" char *asm_label_probe(char *s)
    __asm(CPPGM_PA34_STRINGIZE(CPPGM_PA34_LABEL_PREFIX)
          "cppgm_pa34_asm_label_probe");
extern "C++" const char *asm_label_probe(const char *s)
    __asm(CPPGM_PA34_STRINGIZE(CPPGM_PA34_LABEL_PREFIX)
          "cppgm_pa34_asm_label_probe");

extern "C" int puts(const char *);

int main()
{
  const char * result = asm_label_probe("OK");
  puts(result);
  return result[0] == 'K' && result[1] == '\0' ? 0 : 1;
}
