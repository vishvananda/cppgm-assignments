struct alignas(16) ForwardAligned;
struct alignas(16) ForwardAligned {
  char value;
};

struct alignas(32) DeclAligned {
  char value;
};

struct alignas(long double) TypeAligned {
  char value;
};

int main()
{
  return alignof(ForwardAligned) == 16 &&
         sizeof(ForwardAligned) == 16 &&
         alignof(DeclAligned) == 32 &&
         sizeof(DeclAligned) == 32 &&
         alignof(TypeAligned) == alignof(long double) &&
         sizeof(TypeAligned) == alignof(long double) ? 0 : 1;
}
