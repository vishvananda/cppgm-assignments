function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $value : i32
  slot $source : obj<16x8>
  slot $copy : obj<16x8>

  block ^entry:
    store i32 7, $value
    %t1 = addr $source
    %t2 = addr $value
    %t3 = addr $value
    call void @RefPair_int___RefPair(%t1, %t2, %t3)
    %t4 = addr $copy
    %t5 = addr $source
    copyobj 16x8 %t5, %t4
    %t6 = addr $copy
    %t7 = index i8 [projection=reference_field] %t6, 8
    %t8 = load ptr %t7
    %t9 = load i32 %t8
    %t10 = binary sub i32 %t9, 7
    return i32 %t10
}
function @RefPair_int___RefPair(%this : ptr, %first_value : ptr, %second_value : ptr [pass=reference]) -> void [binding=weak, object=_ZN7RefPairIiEC1EPiRi] {
  slot $this : ptr
  slot $first_value : ptr
  slot $second_value : ptr

  block ^entry:
    store ptr %this, $this
    store ptr %first_value, $first_value
    store ptr %second_value, $second_value
    %t1 = load ptr $first_value
    %t2 = load ptr $this
    %t3 = index i8 [projection=field] %t2, 0
    store ptr %t1, %t3
    %t4 = load ptr $second_value
    %t5 = load ptr $this
    %t6 = index i8 [projection=field] %t5, 8
    store ptr %t4, %t6
    return void
}
