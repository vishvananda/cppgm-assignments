function @get(%b : obj<4x4>) -> i32 [binding=weak, object=_Z3get3Box] {
  slot $b : obj<4x4>

  block ^entry:
    %t1 = addr $b
    copyobj 4x4 %b, %t1
    %t2 = addr $b
    %t3 = index i8 [projection=field] %t2, 0
    %t4 = load i32 %t3
    return i32 %t4
}
function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $b : obj<4x4>
  slot $cond__1 : i32
  slot $argobj__2 : obj<4x4>

  block ^entry:
    %t1 = addr $b
    %t2 = addr $b
    %t3 = index i8 [projection=field] %t2, 0
    store i32 7, %t3
    %t4 = addr $argobj__2
    %t5 = addr $b
    copyobj 4x4 %t5, %t4
    %t6 = call i32 @get($argobj__2)
    %t7 = cmp eq i32 %t6, 7
    branch %t7, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i32 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i32 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t8 = load i32 $cond__1
    return i32 %t8
}
