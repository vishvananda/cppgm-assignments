function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $box : obj<4x4>

  block ^entry:
    %t1 = addr $box
    %t2 = addr $box
    %t3 = index i8 [projection=field] %t2, 0
    store i32 7, %t3
    %t4 = addr $box
    %t5 = call i32 @Box_int___get(%t4)
    %t6 = binary sub i32 %t5, 7
    return i32 %t6
}
function @Box_int___get(%this : ptr) -> i32 [binding=weak, object=_ZN3BoxIiE3getEv] {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    %t1 = load ptr $this
    %t2 = index i8 [projection=field] %t1, 0
    %t3 = load i32 %t2
    return i32 %t3
}
