function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $x : i64
  slot $cond__1 : i32

  block ^entry:
    %t1 = convert sext i64 i32 5
    store i64 %t1, $x
    %t2 = load i64 $x
    %t3 = convert sext i64 i32 3
    %t4 = binary sub i64 %t2, %t3
    %t5 = convert sext i64 i32 2
    %t6 = cmp eq i64 %t4, %t5
    branch %t6, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i32 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i32 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t7 = load i32 $cond__1
    return i32 %t7
}
