function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $value : obj<4x4>
  slot $node : obj<4x4>

  block ^entry:
    %t1 = addr $value
    call void @Value__Value(%t1, 1)
    %t2 = addr $node
    %t3 = addr $value
    call void @Node_Value___Node__ov2(%t2, %t3)
    %t4 = addr $node
    return i32 0
}
function @Node_Value___Node__ov2(%this : ptr, %__param1 : ptr [pass=reference]) -> void [binding=weak, object=_ZN4NodeI5ValueEC1IS0_EERT_] {
  slot $this : ptr
  slot $__param1 : ptr

  block ^entry:
    store ptr %this, $this
    store ptr %__param1, $__param1
    return void
}
function @Value__Value(%this : ptr, %v : i32) -> void [binding=weak, object=_ZN5ValueC1Ei] {
  slot $this : ptr
  slot $v : i32

  block ^entry:
    store ptr %this, $this
    store i32 %v, $v
    %t1 = load i32 $v
    %t2 = load ptr $this
    %t3 = index i8 [projection=field] %t2, 0
    store i32 %t1, %t3
    return void
}
