function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $b : obj<1x1>

  block ^entry:
    %t1 = addr $b
    %t2 = addr $b
    %t3 = call i32 @box_int___f(%t2)
    return i32 %t3
}
function @box_int___f(%this : ptr) -> i32 [binding=weak, object=_ZN3boxIiE1fEv] {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    return i32 0
}
