function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $value : obj<4x4>
  slot $adl : obj<4x4>
  slot $cond__1 : i32
  slot $land__2 : i64

  block ^entry:
    %t1 = addr $value
    %t2 = addr $adl
    %t3 = addr $value
    %t4 = index i8 [projection=field] %t3, 0
    store i32 4, %t4
    %t5 = addr $adl
    %t6 = index i8 [projection=field] %t5, 0
    store i32 5, %t6
    %t7 = addr $value
    %t8 = addr $adl
    %t9 = call i32 @apply(%t7, %t8)
    %t10 = cmp eq i32 %t9, 9
    branch %t10, ^land_rhs_4, ^land_short_5

  block ^land_rhs_4:
    %t11 = addr $value
    %t12 = index i8 [projection=field] %t11, 0
    %t13 = load i32 %t12
    %t14 = cmp eq i32 %t13, 9
    %t15 = cmp ne i64 %t14, 0
    store i64 %t15, $land__2
    jump ^land_end_6

  block ^land_short_5:
    store i64 0, $land__2
    jump ^land_end_6

  block ^land_end_6:
    %t16 = load i64 $land__2
    branch %t16, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i32 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i32 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t17 = load i32 $cond__1
    return i32 %t17
}
function @apply(%value : ptr [pass=reference], %a : ptr [pass=reference]) -> i32 [binding=weak, object=_Z5applyI5ValueEiRT_RK3Adl] {
  slot $value : ptr
  slot $a : ptr

  block ^entry:
    store ptr %value, $value
    store ptr %a, $a
    %t1 = load ptr $value
    %t2 = index i8 [projection=field] %t1, 0
    %t3 = load i32 %t2
    %t4 = load ptr $a
    %t5 = index i8 [projection=field] %t4, 0
    %t6 = load i32 %t5
    %t7 = binary add i32 %t3, %t6
    %t8 = load ptr $value
    %t9 = index i8 [projection=field] %t8, 0
    store i32 %t7, %t9
    %t10 = load ptr $value
    %t11 = index i8 [projection=field] %t10, 0
    %t12 = load i32 %t11
    return i32 %t12
}
