function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $box : obj<4x4>

  block ^entry:
    %t1 = addr $box
    %t2 = addr $box
    %t3 = index i8 [projection=field] %t2, 0
    store i32 7, %t3
    %t4 = addr $box
    %t5 = index i8 [projection=field] %t4, 0
    %t6 = load i32 %t5
    %t7 = binary sub i32 %t6, 7
    return i32 %t7
}
