function @g(%x : ptr [pass=reference]) -> i64 [binding=strong, object=_Z1gRm] {
  slot $x : ptr

  block ^entry:
    store ptr %x, $x
    %t1 = load ptr $x
    %t2 = call ptr @f(%t1)
    %t3 = load i64 %t2
    return i64 %t3
}
function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $x : i64

  block ^entry:
    %t1 = convert sext i64 i32 9
    store i64 %t1, $x
    %t2 = addr $x
    %t3 = call i64 @g(%t2)
    %t4 = convert sext i64 i32 9
    %t5 = binary sub i64 %t3, %t4
    %t6 = convert trunc i32 i64 %t5
    return i32 %t6
}
function @f(%x : ptr [pass=reference]) -> ptr [binding=weak, object=_Z1fImEOT_RS0_] {
  slot $x : ptr

  block ^entry:
    store ptr %x, $x
    %t1 = load ptr $x
    return ptr %t1
}
