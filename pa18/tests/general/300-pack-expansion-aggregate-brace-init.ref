function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  block ^entry:
    %t1 = call i32 @construct()
    %t2 = call i32 @construct__ov2(1, 2)
    %t3 = binary add i32 %t1, %t2
    return i32 %t3
}
function @construct() -> i32 [binding=weak, object=_Z9constructI5emptyJEEiDpT0_] {
  slot $value : obj<1x1>

  block ^entry:
    %t1 = addr $value
    return i32 0
}
function @construct__ov2(%args : i32, %args__pack2 : i32) -> i32 [binding=weak, object=_Z9constructI10pair_valueJiiEEiDpT0_] {
  slot $args : i32
  slot $args__pack2 : i32
  slot $value : obj<8x4>

  block ^entry:
    store i32 %args, $args
    store i32 %args__pack2, $args__pack2
    %t1 = addr $value
    %t2 = load i32 $args
    %t3 = addr $value
    %t4 = index i8 [projection=field] %t3, 0
    store i32 %t2, %t4
    %t5 = load i32 $args__pack2
    %t6 = addr $value
    %t7 = index i8 [projection=field] %t6, 4
    store i32 %t5, %t7
    %t8 = addr $value
    return i32 0
}
