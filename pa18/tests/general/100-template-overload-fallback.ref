function @pick(%x : i32) -> i32 [binding=strong, object=_Z4picki] {
  slot $x : i32

  block ^entry:
    store i32 %x, $x
    return i32 2
}
function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $x : i32

  block ^entry:
    store i32 0, $x
    %t1 = addr $x
    %t2 = call i32 @pick__ov2(%t1)
    %t3 = binary sub i32 %t2, 1
    return i32 %t3
}
function @pick__ov2(%p : ptr) -> i32 [binding=weak, object=_Z4pickIiEiPT_] {
  slot $p : ptr

  block ^entry:
    store ptr %p, $p
    return i32 1
}
