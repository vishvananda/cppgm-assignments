function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $value : i32
  slot $f : obj<1x1>

  block ^entry:
    store i32 7, $value
    %t1 = addr $f
    %t2 = addr $f
    %t3 = addr $value
    %t4 = call i32 @callable____operator__(%t2, %t3)
    %t5 = binary sub i32 %t4, 7
    return i32 %t5
}
function @callable____operator__(%this : ptr, %value : ptr [pass=reference]) -> i32 [binding=weak, object=_ZNK8callableclIRiEEiOT_] {
  slot $this : ptr
  slot $value : ptr

  block ^entry:
    store ptr %this, $this
    store ptr %value, $value
    %t1 = load ptr $value
    %t2 = load i32 %t1
    return i32 %t2
}
