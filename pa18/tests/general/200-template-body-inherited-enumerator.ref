function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $d : obj<1x1>

  block ^entry:
    %t1 = addr $d
    %t2 = addr $d
    %t3 = call i32 @derived_int___f(%t2)
    return i32 %t3
}
function @derived_int___f(%this : ptr) -> i32 [binding=weak, object=_ZN7derivedIiE1fEv] {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    return i32 7
}
