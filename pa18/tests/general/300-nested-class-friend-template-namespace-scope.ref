function @force(%loc : ptr [pass=reference]) -> ptr [binding=strong, object=_Z5forceRK6Locale] {
  slot $loc : ptr

  block ^entry:
    store ptr %loc, $loc
    %t1 = load ptr $loc
    %t2 = call ptr @try_use_facet(%t1)
    return ptr %t2
}
function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  block ^entry:
    return i32 0
}
function @try_use_facet(%loc : ptr [pass=reference]) -> ptr [binding=weak, object=_Z13try_use_facetI5CtypeEPKT_RK6Locale] {
  slot $loc : ptr
  slot $facets : ptr

  block ^entry:
    store ptr %loc, $loc
    %t1 = load ptr $loc
    %t2 = index i8 [projection=field] %t1, 0
    %t3 = load ptr %t2
    %t4 = index i8 [projection=field] %t3, 0
    %t5 = load ptr %t4
    store ptr %t5, $facets
    %t6 = load ptr $facets
    return ptr 0
}
