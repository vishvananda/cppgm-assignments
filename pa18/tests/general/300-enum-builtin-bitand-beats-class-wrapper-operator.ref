function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $cond__1 : i32

  block ^entry:
    %t1 = call i32 @boost__xpressive__detail__check(2048)
    %t2 = cmp eq i32 %t1, 2048
    branch %t2, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i32 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i32 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t3 = load i32 $cond__1
    return i32 %t3
}
function @boost__xpressive__detail__check(%flags : i32) -> i32 [binding=weak, object=_ZN5boost9xpressive6detail5checkIiEEiNS0_15regex_constants18syntax_option_typeE] {
  slot $flags : i32

  block ^entry:
    store i32 %flags, $flags
    %t1 = binary or i32 4096, 2048
    %t2 = load i32 $flags
    %t3 = binary and i32 %t1, %t2
    return i32 %t3
}
