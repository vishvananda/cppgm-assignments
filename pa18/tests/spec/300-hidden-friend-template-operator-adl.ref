    %t15 = load ptr $p
    %t16 = addr $s
    %t17 = cmp eq ptr %t15, %t16
    branch %t17, ^land_rhs_4, ^land_short_5

  block ^land_rhs_4:
    %t18 = addr $s
    %t19 = index i8 [projection=field] %t18, 0
    %t20 = load i32 %t19
    %t21 = cmp eq i32 %t20, 6
    %t22 = cmp ne i64 %t21, 0
    store i64 %t22, $land__2
    jump ^land_end_6

  block ^land_short_5:
    store i64 0, $land__2
    jump ^land_end_6

  block ^land_end_6:
    %t23 = load i64 $land__2
    branch %t23, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i32 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i32 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t24 = load i32 $cond__1
    return i32 %t24
}
function @operator__(%out : ptr [pass=reference], %m : ptr [pass=reference]) -> ptr [binding=weak, object=_ZlsI4sinkERT_S2_RK5manip] {
  slot $out : ptr
