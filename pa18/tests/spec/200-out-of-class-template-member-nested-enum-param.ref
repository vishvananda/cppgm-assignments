function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $box : obj<1x1>

  block ^entry:
    %t1 = addr $box
    %t2 = addr $box
    %t3 = call i32 @Box_int___call(%t2, 0)
    return i32 %t3
}
function @Box_int___call(%this : ptr, %tag : i32) -> i32 [binding=weak, object=_ZN3BoxIiE4callENS0_3TagE] {
  slot $this : ptr
  slot $tag : i32

  block ^entry:
    store ptr %this, $this
    store i32 %tag, $tag
    %t1 = load ptr $this
    %t2 = load i32 $tag
    %t3 = call i32 @Box_int___value(%t1, %t2)
    return i32 %t3
}
function @Box_int___value(%this : ptr, %tag : i32) -> i32 [binding=weak, object=_ZN3BoxIiE5valueENS0_3TagE] {
  slot $this : ptr
  slot $tag : i32

