function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $cond__1 : i32

  block ^entry:
    %t1 = call i32 @box_int___cast(3)
    %t2 = const i64 4
    %t3 = convert trunc i32 i64 %t2
    %t4 = binary add i32 %t3, 3
    %t5 = cmp eq i32 %t1, %t4
    branch %t5, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i32 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i32 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t6 = load i32 $cond__1
    return i32 %t6
}
function @box_int___cast(%u : i32) -> i32 [binding=weak, object=_ZN3boxIiE4castIiEEiT_] {
  slot $u : i32

  block ^entry:
    store i32 %u, $u
