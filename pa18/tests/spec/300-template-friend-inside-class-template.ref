function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $cond__1 : i32
  slot $argobj__2 : obj<4x4>

  block ^entry:
    %t1 = addr $argobj__2
    call void @box_int___box(%t1, 9)
    %t2 = call i32 @read($argobj__2)
    %t3 = cmp eq i32 %t2, 9
    branch %t3, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i32 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i32 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t4 = load i32 $cond__1
    return i32 %t4
}
function @box_int___box(%this : ptr, %v : i32) -> void [binding=weak, object=_ZN3boxIiEC1Ei] {
  slot $this : ptr
  slot $v : i32

  block ^entry:
    store ptr %this, $this
    store i32 %v, $v
    %t1 = load i32 $v
    %t2 = load ptr $this
    %t3 = index i8 [projection=field] %t2, 0
    store i32 %t1, %t3
    return void
}
function @read(%b : obj<4x4>) -> i32 [binding=weak, object=_Z4readIiEi3boxIT_E] {
  slot $b : obj<4x4>

  block ^entry:
    %t1 = addr $b
    copyobj 4x4 %b, %t1
    %t2 = addr $b
    %t3 = index i8 [projection=field] %t2, 0
    %t4 = load i32 %t3
    return i32 %t4
}
