function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $p : obj<1x1>
  slot $cond__1 : i32
  slot $refarg__2 : i32

  block ^entry:
    %t1 = addr $p
    %t2 = addr $p
    store i32 0, $refarg__2
    %t3 = addr $refarg__2
    %t4 = call i32 @probe__find(%t2, %t3)
    %t5 = cmp eq i32 %t4, 2
    branch %t5, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i32 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i32 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t6 = load i32 $cond__1
    return i32 %t6
}
function @probe__find(%this : ptr, %value : ptr [pass=reference]) -> i32 [binding=weak, object=_ZNK5probe4findIiEEiRKT_] {
  slot $this : ptr
  slot $value : ptr

  block ^entry:
