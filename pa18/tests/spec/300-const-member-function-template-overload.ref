    store ptr %value, $value
    %t1 = load ptr $this
    %t2 = load ptr $value
    %t3 = call i32 @probe__tag__ov2(%t1, %t2)
    return i32 %t3
}
function @probe__tag__ov2(%this : ptr, %__param1 : ptr [pass=reference]) -> i32 [binding=weak, object=_ZNK5probe3tagIiEEiRKT_] {
  slot $this : ptr
