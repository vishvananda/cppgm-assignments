function @h(%x : i32, %y : i8) -> i32 [binding=strong, object=_Z1hic] {
  slot $x : i32
  slot $y : i8

  block ^entry:
    store i32 %x, $x
    store i8 %y, $y
    %t1 = load i32 $x
    %t2 = load i8 $y
    %t3 = convert sext i32 i8 %t2
    %t4 = binary add i32 %t1, %t3
    return i32 %t4
}
function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $cond__1 : i32

  block ^entry:
    %t1 = call i32 @g(1, 97)
    %t2 = cmp eq i32 %t1, 98
    branch %t2, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i32 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i32 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t3 = load i32 $cond__1
    return i32 %t3
}
function @g(%args : i32, %args__pack2 : i8) -> i32 [binding=weak, object=_Z1gIJicEEiDpT_] {
  slot $args : i32
  slot $args__pack2 : i8

  block ^entry:
    store i32 %args, $args
    store i8 %args__pack2, $args__pack2
    %t1 = load i32 $args
    %t2 = load i8 $args__pack2
    %t3 = call i32 @h(%t1, %t2)
    return i32 %t3
}
