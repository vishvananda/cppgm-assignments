global @pmask : ptr [binding=strong, object=_Z5pmask] = zero
global @pnode : ptr [binding=strong, object=_Z5pnode] = zero

function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $cond__1 : i32
  slot $land__2 : i64

  block ^entry:
    %t1 = load ptr @pmask
    %t2 = cmp eq ptr %t1, 0
    branch %t2, ^land_rhs_4, ^land_short_5

  block ^land_rhs_4:
    %t3 = load ptr @pnode
    %t4 = cmp eq ptr %t3, 0
    %t5 = cmp ne i64 %t4, 0
    store i64 %t5, $land__2
    jump ^land_end_6

  block ^land_short_5:
    store i64 0, $land__2
    jump ^land_end_6

  block ^land_end_6:
    %t6 = load i64 $land__2
    branch %t6, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i32 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i32 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t7 = load i32 $cond__1
    return i32 %t7
}
