template<class T, int N>
struct sized_value {
  T value;
};

template<class T>
struct width {
  static const int value = sizeof(T);
};

template<class T>
using sized_value_t = sized_value<T, width<T>::value>;

template<class T>
T read_value(sized_value_t<T> value) {
  return value.value;
}

int main() {
  sized_value_t<int> value = {7};
  return read_value<int>(value) == 7 ? 0 : 1;
}
