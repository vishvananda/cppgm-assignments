extern "C" int puts(const char *);
extern "C" int vsnprintf(char *, unsigned long, const char *, __builtin_va_list);

int render(char *out, int marker, ...)
{
  __builtin_va_list args;
  __builtin_va_start(args, marker);
  int n = vsnprintf(out, 64, "%d:%.1f", args);
  __builtin_va_end(args);
  return n;
}

int same(const char *a, const char *b)
{
  for (int i = 0;; ++i)
  {
    if (a[i] != b[i])
      return 0;
    if (a[i] == 0)
      return 1;
  }
}

int main()
{
  char buf[64];
  int n = render(buf, 0, 17, 2.5);
  if (n != 6)
    return 1;
  if (!same(buf, "17:2.5"))
    return 2;
  puts(buf);
  return 0;
}
