struct BaseError
{
  int code;

  BaseError() : code(7) {}
};

struct DerivedError : BaseError
{
  DerivedError() : BaseError() {}
};

void throw_derived_error();

int main()
{
  try
  {
    throw_derived_error();
  }
  catch (BaseError & error)
  {
    return error.code == 7 ? 0 : 2;
  }
  return 1;
}
