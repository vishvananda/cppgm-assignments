struct LeftBase {
  virtual ~LeftBase() {}
};

struct RightBase {
  virtual int value()
  {
    return 4;
  }
};

struct MultiDerived : LeftBase, RightBase {
  int value()
  {
    return 7;
  }
};

int main()
{
  MultiDerived derived;
  RightBase * right = &derived;
  return right->value() == 7 ? 0 : 1;
}
