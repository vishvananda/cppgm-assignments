start:
	move64 bp sp;
	call fn__main;
	syscall1 t64 60 x64;

fn__scale:
	isub64 sp sp 8;
	move64 [sp] bp;
	move64 bp sp;
	isub64 sp sp 24;
	move64 [bp-8] x64;
fn__scale__entry:
	move64 x64 2.0;
	move64 [bp-16] x64;
	move64 y64 [bp-8];
	move64 x64 [bp-16];
	fmul64 x64 y64 x64;
	move64 [bp-24] x64;
	move64 x64 [bp-24];
	jump fn__scale__epilogue;
fn__scale__epilogue:
	move64 sp bp;
	move64 bp [sp];
	iadd64 sp sp 8;
	ret;

fn__main:
	isub64 sp sp 8;
	move64 [sp] bp;
	move64 bp sp;
	isub64 sp sp 32;
fn__main__entry:
	move64 x64 3.0;
	move64 [bp-8] x64;
	move64 x64 [bp-8];
	call fn__scale;
	move64 [bp-16] x64;
	move64 x64 6.0;
	move64 [bp-24] x64;
	move64 y64 [bp-16];
	move64 x64 [bp-24];
	feq64 z8 y64 x64;
	move64 x64 0;
	move8 x8 z8;
	move64 [bp-32] x64;
	move64 x64 [bp-32];
	jump fn__main__epilogue;
fn__main__epilogue:
	move64 sp bp;
	move64 bp [sp];
	iadd64 sp sp 8;
	ret;
