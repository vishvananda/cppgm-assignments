start:
	move64 bp sp;
	call fn__main;
	syscall1 t64 60 x64;

fn__f:
	isub64 sp sp 8;
	move64 [sp] bp;
	move64 bp sp;
	isub64 sp sp 96;
fn__f__entry:
	move64 x64 2;
	move64 [bp-16] x64;
	move64 x64 [bp-16];
	move64 [bp-8] x64;
	jump fn__f__cond;
fn__f__cond:
	move64 x64 [bp-8];
	move64 [bp-24] x64;
	move64 x64 0;
	move64 [bp-32] x64;
	move64 y64 [bp-24];
	move64 x64 [bp-32];
	sgt64 z8 y64 x64;
	move64 x64 0;
	move8 x8 z8;
	move64 [bp-40] x64;
	move64 x64 [bp-40];
	ieq64 z8 x64 0;
	jumpif z8 fn__f__end;
	jump fn__f__body;
fn__f__body:
	move64 x64 [bp-8];
	move64 [bp-48] x64;
	move64 x64 1;
	move64 [bp-56] x64;
	move64 y64 [bp-48];
	move64 x64 [bp-56];
	isub64 x64 y64 x64;
	move64 [bp-64] x64;
	move64 x64 [bp-64];
	move64 [bp-8] x64;
	move64 x64 [bp-8];
	move64 [bp-72] x64;
	move64 x64 1;
	move64 [bp-80] x64;
	move64 y64 [bp-72];
	move64 x64 [bp-80];
	ieq64 z8 y64 x64;
	move64 x64 0;
	move8 x8 z8;
	move64 [bp-88] x64;
	move64 x64 [bp-88];
	ieq64 z8 x64 0;
	jumpif z8 fn__f__cont;
	jump fn__f__end;
fn__f__cont:
	jump fn__f__cond;
fn__f__end:
	move64 x64 [bp-8];
	move64 [bp-96] x64;
	move64 x64 [bp-96];
	jump fn__f__epilogue;
fn__f__epilogue:
	move64 sp bp;
	move64 bp [sp];
	iadd64 sp sp 8;
	ret;

fn__main:
	isub64 sp sp 8;
	move64 [sp] bp;
	move64 bp sp;
	isub64 sp sp 8;
fn__main__entry:
	call fn__f;
	move64 [bp-8] x64;
	move64 x64 [bp-8];
	jump fn__main__epilogue;
fn__main__epilogue:
	move64 sp bp;
	move64 bp [sp];
	iadd64 sp sp 8;
	ret;
