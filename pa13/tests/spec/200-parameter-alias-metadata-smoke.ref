start:
	move64 bp sp;
	call fn__main;
	syscall1 t64 60 x64;

fn__copy:
	isub64 sp sp 8;
	move64 [sp] bp;
	move64 bp sp;
	isub64 sp sp 24;
	move64 [bp-8] x64;
	move64 [bp-16] y64;
	move64 [bp-24] z64;
fn__copy__entry:
	jump fn__copy__epilogue;
fn__copy__epilogue:
	move64 sp bp;
	move64 bp [sp];
	iadd64 sp sp 8;
	ret;

fn__helper:
	isub64 sp sp 8;
	move64 [sp] bp;
	move64 bp sp;
	isub64 sp sp 32;
	move64 [bp-8] x64;
	move64 [bp-16] y64;
	move64 [bp-24] z64;
fn__helper__entry:
	move64 x64 4;
	move64 [bp-32] x64;
	move64 x64 [bp-8];
	isub64 sp sp 8;
	move64 [sp] x64;
	move64 x64 [bp-16];
	move64 y64 [bp-24];
	move64 z64 [bp-32];
	call [sp];
	iadd64 sp sp 8;
	jump fn__helper__epilogue;
fn__helper__epilogue:
	move64 sp bp;
	move64 bp [sp];
	iadd64 sp sp 8;
	ret;

fn__main:
	isub64 sp sp 8;
	move64 [sp] bp;
	move64 bp sp;
	isub64 sp sp 24;
	move64 [bp-8] x64;
	move64 [bp-16] y64;
fn__main__entry:
	move64 x64 4;
	move64 [bp-24] x64;
	move64 x64 [bp-8];
	move64 y64 [bp-16];
	move64 z64 [bp-24];
	call fn__copy;
	move64 x64 0;
	jump fn__main__epilogue;
fn__main__epilogue:
	move64 sp bp;
	move64 bp [sp];
	iadd64 sp sp 8;
	ret;
