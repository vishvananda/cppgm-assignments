start:
	move64 bp sp;
	call fn__main;
	syscall1 t64 60 x64;

fn__main:
	isub64 sp sp 8;
	move64 [sp] bp;
	move64 bp sp;
fn__main__entry:
	move64 x64 0;
	jump fn__main__epilogue;
fn__main__epilogue:
	move64 sp bp;
	move64 bp [sp];
	iadd64 sp sp 8;
	ret;

g__coeffs:
	data32 1.5f;
	data8 0;
	data8 0;
	data8 0;
	data8 0;
	data64 2.25;
