start:
	move64 bp sp;
	call fn__main;
	syscall1 t64 60 x64;

fn__add:
	isub64 sp sp 8;
	move64 [sp] bp;
	move64 bp sp;
	isub64 sp sp 24;
fn__add__entry:
	move64 x64 [g__g];
	move64 [bp-8] x64;
	move64 x64 3;
	move64 [bp-16] x64;
	move64 y64 [bp-8];
	move64 x64 [bp-16];
	iadd64 x64 y64 x64;
	move64 [bp-24] x64;
	move64 x64 [bp-24];
	jump fn__add__epilogue;
fn__add__epilogue:
	move64 sp bp;
	move64 bp [sp];
	iadd64 sp sp 8;
	ret;

fn__main:
	isub64 sp sp 8;
	move64 [sp] bp;
	move64 bp sp;
	isub64 sp sp 8;
fn__main__entry:
	call fn__add;
	move64 [bp-8] x64;
	move64 x64 [bp-8];
	jump fn__main__epilogue;
fn__main__epilogue:
	move64 sp bp;
	move64 bp [sp];
	iadd64 sp sp 8;
	ret;

g__g:
	data64 4;
