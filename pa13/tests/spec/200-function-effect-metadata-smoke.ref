start:
	move64 bp sp;
	call fn__main;
	syscall1 t64 60 x64;

fn__callee:
	isub64 sp sp 8;
	move64 [sp] bp;
	move64 bp sp;
	isub64 sp sp 8;
	move64 [bp-8] x64;
fn__callee__entry:
	move64 x64 [bp-8];
	jump fn__callee__epilogue;
fn__callee__epilogue:
	move64 sp bp;
	move64 bp [sp];
	iadd64 sp sp 8;
	ret;

fn__helper:
	isub64 sp sp 8;
	move64 [sp] bp;
	move64 bp sp;
	isub64 sp sp 24;
	move64 [bp-8] x64;
	move64 [bp-16] y64;
fn__helper__entry:
	move64 x64 [bp-8];
	isub64 sp sp 8;
	move64 [sp] x64;
	move64 x64 [bp-16];
	call [sp];
	iadd64 sp sp 8;
	move64 [bp-24] x64;
	move64 x64 [bp-24];
	jump fn__helper__epilogue;
fn__helper__epilogue:
	move64 sp bp;
	move64 bp [sp];
	iadd64 sp sp 8;
	ret;

fn__main:
	isub64 sp sp 8;
	move64 [sp] bp;
	move64 bp sp;
	isub64 sp sp 8;
fn__main__entry:
	move64 x64 7;
	call fn__callee;
	move64 [bp-8] x64;
	move64 x64 [bp-8];
	jump fn__main__epilogue;
fn__main__epilogue:
	move64 sp bp;
	move64 bp [sp];
	iadd64 sp sp 8;
	ret;
