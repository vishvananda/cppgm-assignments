start:
	move64 bp sp;
	call fn__main;
	syscall1 t64 60 x64;

fn__main:
	isub64 sp sp 8;
	move64 [sp] bp;
	move64 bp sp;
	isub64 sp sp 8;
fn__main__entry:
	move64 x64 [g__tls_value];
	move64 [bp-8] x64;
	move64 x64 [bp-8];
	jump fn__main__epilogue;
fn__main__epilogue:
	move64 sp bp;
	move64 bp [sp];
	iadd64 sp sp 8;
	ret;

g__tls_value:
	data64 7;
