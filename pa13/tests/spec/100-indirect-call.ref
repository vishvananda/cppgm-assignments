start:
	move64 bp sp;
	call fn__main;
	syscall1 t64 60 x64;

fn__g:
	isub64 sp sp 8;
	move64 [sp] bp;
	move64 bp sp;
	isub64 sp sp 24;
	move64 [bp-8] x64;
fn__g__entry:
	move64 x64 1;
	move64 [bp-16] x64;
	move64 y64 [bp-8];
	move64 x64 [bp-16];
	iadd64 x64 y64 x64;
	move64 [bp-24] x64;
	move64 x64 [bp-24];
	jump fn__g__epilogue;
fn__g__epilogue:
	move64 sp bp;
	move64 bp [sp];
	iadd64 sp sp 8;
	ret;

fn__call:
	isub64 sp sp 8;
	move64 [sp] bp;
	move64 bp sp;
	isub64 sp sp 24;
	move64 [bp-8] x64;
fn__call__entry:
	move64 x64 4;
	move64 [bp-16] x64;
	move64 x64 [bp-8];
	isub64 sp sp 8;
	move64 [sp] x64;
	move64 x64 [bp-16];
	call [sp];
	iadd64 sp sp 8;
	move64 [bp-24] x64;
	move64 x64 [bp-24];
	jump fn__call__epilogue;
fn__call__epilogue:
	move64 sp bp;
	move64 bp [sp];
	iadd64 sp sp 8;
	ret;

fn__main:
	isub64 sp sp 8;
	move64 [sp] bp;
	move64 bp sp;
	isub64 sp sp 16;
fn__main__entry:
	move64 x64 fn__g;
	move64 [bp-8] x64;
	move64 x64 [bp-8];
	call fn__call;
	move64 [bp-16] x64;
	move64 x64 [bp-16];
	jump fn__main__epilogue;
fn__main__epilogue:
	move64 sp bp;
	move64 bp [sp];
	iadd64 sp sp 8;
	ret;
