start:
	move64 bp sp;
	call fn__main;
	syscall1 t64 60 x64;

fn__main:
	isub64 sp sp 8;
	move64 [sp] bp;
	move64 bp sp;
	isub64 sp sp 72;
fn__main__entry:
	isub64 x64 bp 8;
	move64 [bp-16] x64;
	move64 y64 [bp-16];
	move64 x64 4;
	iadd64 x64 y64 x64;
	move64 [bp-24] x64;
	move64 y64 [bp-24];
	move64 x64 0;
	iadd64 x64 y64 x64;
	move64 [bp-32] x64;
	move64 y64 [bp-32];
	move64 x64 8;
	iadd64 x64 y64 x64;
	move64 [bp-40] x64;
	move64 y64 [bp-16];
	move64 x64 1;
	move64 z64 8;
	smul64 x64 x64 z64;
	iadd64 x64 y64 x64;
	move64 [bp-48] x64;
	move64 y64 [bp-40];
	move64 x64 0;
	ine64 z8 y64 x64;
	move64 x64 0;
	move8 x8 z8;
	move64 [bp-56] x64;
	move64 y64 [bp-48];
	move64 x64 0;
	ine64 z8 y64 x64;
	move64 x64 0;
	move8 x8 z8;
	move64 [bp-64] x64;
	move64 y64 [bp-56];
	move64 x64 [bp-64];
	and64 x64 y64 x64;
	move64 [bp-72] x64;
	move64 x64 [bp-72];
	jump fn__main__epilogue;
fn__main__epilogue:
	move64 sp bp;
	move64 bp [sp];
	iadd64 sp sp 8;
	ret;
