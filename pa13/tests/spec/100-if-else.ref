start:
	move64 bp sp;
	call fn__main;
	syscall1 t64 60 x64;

fn__main:
	isub64 sp sp 8;
	move64 [sp] bp;
	move64 bp sp;
	isub64 sp sp 40;
fn__main__entry:
	move64 x64 1;
	move64 [bp-8] x64;
	move64 x64 2;
	move64 [bp-16] x64;
	move64 y64 [bp-8];
	move64 x64 [bp-16];
	slt64 z8 y64 x64;
	move64 x64 0;
	move8 x8 z8;
	move64 [bp-24] x64;
	move64 x64 [bp-24];
	ieq64 z8 x64 0;
	jumpif z8 fn__main__else;
	jump fn__main__then;
fn__main__then:
	move64 x64 1;
	move64 [bp-32] x64;
	move64 x64 [bp-32];
	jump fn__main__epilogue;
fn__main__else:
	move64 x64 2;
	move64 [bp-40] x64;
	move64 x64 [bp-40];
	jump fn__main__epilogue;
fn__main__epilogue:
	move64 sp bp;
	move64 bp [sp];
	iadd64 sp sp 8;
	ret;
