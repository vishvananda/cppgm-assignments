machine_ir x86_64 linux

startup
    call @main
    mov rdi, rax
    exit

function @main
  abi
    return i32 -> rax
  frame
    stack_size 0
    scratch_bytes 0

  block ^entry
    mov r8, 40 !dbg(tests/debuginfo/machine/100-lowir2native-machine-add.t, 3, 10)
    add r8, 2 !dbg(tests/debuginfo/machine/100-lowir2native-machine-add.t, 3, 10)
    sext.i32 r8 !dbg(tests/debuginfo/machine/100-lowir2native-machine-add.t, 3, 10)
    mov rax, r8
    ret rax
