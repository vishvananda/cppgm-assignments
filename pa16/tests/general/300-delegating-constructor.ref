function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $v : obj<4x4>
  slot $cond__1 : i32

  block ^entry:
    %t1 = addr $v
    call void @Value__Value(%t1)
    %t2 = addr $v
    %t3 = index i8 [projection=field] %t2, 0
    %t4 = load i32 %t3
    %t5 = cmp eq i32 %t4, 7
    branch %t5, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i32 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i32 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t6 = load i32 $cond__1
    return i32 %t6
}
function @Value__Value(%this : ptr) -> void [binding=weak, object=_ZN5ValueC1Ev] {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    %t1 = load ptr $this
