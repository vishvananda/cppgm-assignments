function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $a : obj<4x4>
  slot $cond__1 : i32

  block ^entry:
    %t1 = addr $a
    call void @A__A(%t1)
    %t2 = addr $a
    %t3 = index i8 [projection=field] %t2, 0
    %t4 = index i8 [projection=field] %t3, 0
    %t5 = load i32 %t4
    %t6 = cmp eq i32 %t5, 7
    branch %t6, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i32 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i32 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t7 = load i32 $cond__1
    return i32 %t7
}
function @A__A(%this : ptr) -> void [binding=weak, object=_ZN1AC1Ev] {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    %t1 = load ptr $this
    %t2 = index i8 [projection=field] %t1, 0
    call void @B__B(%t2)
    return void
}
function @B__B(%this : ptr) -> void [binding=weak, object=_ZN1BC1Ev] {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    %t1 = load ptr $this
    %t2 = index i8 [projection=field] %t1, 0
    store i32 7, %t2
    return void
}
