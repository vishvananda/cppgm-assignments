function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $arr : obj<8x4>
  slot $cond__1 : i32

  block ^entry:
    %t1 = addr $arr
    call void @C__C(%t1)
    %t2 = index i8 %t1, 4
    call void @C__C(%t2)
    %t3 = addr $arr
    %t4 = unary decay ptr %t3
    %t5 = binary mul i64 1, 4
    %t6 = index i8 [projection=array_element] %t4, %t5
    %t7 = index i8 [projection=field] %t6, 0
    %t8 = load i32 %t7
    %t9 = cmp eq i32 %t8, 7
    branch %t9, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i32 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i32 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t10 = load i32 $cond__1
    return i32 %t10
}
function @C__C(%this : ptr) -> void [binding=weak, object=_ZN1CC1Ev] {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    %t1 = load ptr $this
    %t2 = index i8 [projection=field] %t1, 0
    store i32 7, %t2
    return void
}
