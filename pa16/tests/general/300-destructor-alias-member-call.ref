declare function @operatornew(%arg0 : i64, %arg1 : ptr) -> ptr [binding=strong, object=_ZnwmPv]

global @gx : i32 [binding=strong, object=_Z2gx] = 0

function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $buf : obj<1x1>
  slot $p : ptr
  slot $cond__1 : i32

  block ^entry:
    %t1 = convert sext i64 i32 1
    %t2 = addr $buf
    %t3 = unary decay ptr %t2
    %t4 = call ptr @operatornew(%t1, %t3)
    call void @S__S(%t4)
    store ptr %t4, $p
    %t5 = load ptr $p
    call void @S___S(%t5)
    %t6 = load i32 @gx
    %t7 = cmp eq i32 %t6, 1
    branch %t7, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i32 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i32 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t8 = load i32 $cond__1
    return i32 %t8
}
function @S__S(%this : ptr) -> void [binding=weak, object=_ZN1SC1Ev] {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    return void
}
function @S___S(%this : ptr) -> void [binding=weak, object=_ZN1SD1Ev] {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    %t1 = load i32 @gx
    %t2 = binary add i32 %t1, 1
    store i32 %t2, @gx
    return void
}
