    return i32 %t10
}
function @Y__operator_(%this : ptr, %r : ptr [pass=reference]) -> ptr [binding=weak, object=_ZN1YaSERKS_] {
  slot $this : ptr
  slot $r : ptr

  block ^entry:
    store ptr %this, $this
