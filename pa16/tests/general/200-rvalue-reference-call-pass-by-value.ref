function @take(%s : obj<4x4>) -> i32 [binding=strong, object=_Z4take1S] {
  slot $s : obj<4x4>

  block ^entry:
    %t1 = addr $s
    copyobj 4x4 %s, %t1
    %t2 = addr $s
    %t3 = index i8 [projection=field] %t2, 0
    %t4 = load i32 %t3
    return i32 %t4
}
function @pass(%s : ptr [pass=reference]) -> ptr [binding=strong, object=_Z4passO1S] {
  slot $s : ptr

  block ^entry:
    store ptr %s, $s
    %t1 = load ptr $s
    return ptr %t1
}
function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $argobj__1 : obj<4x4>
  slot $arg__2 : obj<4x4>

  block ^entry:
    %t1 = addr $argobj__1
    %t2 = addr $arg__2
    call void @S__S(%t2, 7)
    %t3 = call ptr @pass(%t2)
    copyobj 4x4 %t3, %t1
    %t4 = call i32 @take($argobj__1)
    %t5 = binary sub i32 %t4, 7
    return i32 %t5
}
function @S__S(%this : ptr, %v : i32) -> void [binding=weak, object=_ZN1SC1Ei] {
  slot $this : ptr
  slot $v : i32

  block ^entry:
    store ptr %this, $this
    store i32 %v, $v
    %t1 = load i32 $v
    %t2 = load ptr $this
    %t3 = index i8 [projection=field] %t2, 0
    store i32 %t1, %t3
    return void
}
