function @make() -> obj<8x4> [binding=strong, object=_Z4makev] {
  slot $p : obj<8x4>
  slot $retobj__1 : obj<8x4>

  block ^entry:
    %t1 = addr $p
    call void @P__P(%t1)
    %t2 = addr $retobj__1
    %t3 = addr $p
    copyobj 8x4 %t3, %t2
    return obj<8x4> $retobj__1
}
function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $tmpobj__1 : obj<8x4>

  block ^entry:
    %t1 = addr $tmpobj__1
    %t2 = call obj<8x4> @make()
    copyobj 8x4 %t2, %t1
    %t3 = index i8 [projection=field] %t1, 4
    %t4 = load i32 %t3
    return i32 %t4
}
function @P__P(%this : ptr) -> void [binding=weak, object=_ZN1PC1Ev] {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    %t1 = load ptr $this
    %t2 = index i8 [projection=field] %t1, 0
    store i32 1, %t2
    %t3 = load ptr $this
    %t4 = index i8 [projection=field] %t3, 4
    store i32 7, %t4
    return void
}
