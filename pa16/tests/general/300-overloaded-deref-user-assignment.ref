global @g : i32 [binding=strong, object=_Z1g] = 0

function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $it : obj<1x1>

  block ^entry:
    %t1 = addr $it
    %t2 = addr $it
    %t3 = call ptr @Iter__operator___ov2(%t2)
    %t4 = call ptr @Iter__operator_(%t3, 7)
    %t5 = load i32 @g
    %t6 = binary sub i32 %t5, 7
    return i32 %t6
}
function @Iter__operator___ov2(%this : ptr) -> ptr [binding=weak, object=_ZN4IterdeEv] {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    %t1 = load ptr $this
    return ptr %t1
}
function @Iter__operator_(%this : ptr, %n : i32) -> ptr [binding=weak, object=_ZN4IteraSEi] {
  slot $this : ptr
  slot $n : i32

  block ^entry:
    store ptr %this, $this
    store i32 %n, $n
    %t1 = load i32 $n
    store i32 %t1, @g
    %t2 = load ptr $this
    return ptr %t2
}
