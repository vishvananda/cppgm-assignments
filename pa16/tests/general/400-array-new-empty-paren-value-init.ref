    %t2 = call ptr @operator_new__(%t1)
    %t3 = load i64 $array_new_size__1
    store i64 0, $zeroinit_offset__2
    jump ^zeroinit_cond_1

  block ^zeroinit_cond_1:
    %t4 = load i64 $zeroinit_offset__2
    %t5 = cmp ult i64 %t4, %t3
    branch %t5, ^zeroinit_body_2, ^zeroinit_end_3

  block ^zeroinit_body_2:
    %t6 = index i8 %t2, %t4
    store i8 0, %t6
    %t7 = binary add i64 %t4, 1
