declare function @operator_delete__(%arg0 : ptr) -> void [unwind=no, binding=strong, object=cppgm_builtin_operator_delete_array]
declare function @operator_new__(%arg0 : i64) -> ptr [binding=strong, object=cppgm_builtin_operator_new_array]

function @count() -> i64 [binding=strong, object=_Z5countv] {
  block ^entry:
    %t1 = convert sext i64 i32 4
