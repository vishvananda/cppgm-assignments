function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $x : i32
  slot $p : ptr
  slot $b : u8
  slot $cond__1 : i32

  block ^entry:
    store i32 0, $x
    %t1 = addr $x
    store ptr %t1, $p
    %t2 = load ptr $p
    %t3 = cmp ne ptr %t2, 0
    %t4 = copy u8 %t3
    store u8 %t4, $b
    %t5 = load u8 $b
    %t6 = convert zext i32 u8 %t5
    %t7 = cmp eq i32 %t6, 1
    branch %t7, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i32 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    %t8 = load u8 $b
    %t9 = convert zext i32 u8 %t8
    store i32 %t9, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t10 = load i32 $cond__1
    return i32 %t10
}
