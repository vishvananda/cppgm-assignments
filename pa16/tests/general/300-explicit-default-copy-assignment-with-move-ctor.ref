  block ^entry:
    %t1 = addr $a
    call void @Item__Item(%t1)
    %t2 = addr $a
    %t3 = index i8 [projection=field] %t2, 0
    store i32 7, %t3
    %t4 = addr $b
    call void @Item__Item(%t4)
