function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $a : obj<4x4>
  slot $b : obj<4x4>

  block ^entry:
    %t1 = addr $a
    %t2 = addr $b
    %t3 = addr $a
    %t4 = index i8 [projection=field] %t3, 0
    store i32 9, %t4
    %t5 = addr $b
    %t6 = addr $a
    %t7 = call ptr @Y__operator_(%t5, %t6)
    %t8 = addr $b
    %t9 = index i8 [projection=field] %t8, 0
    %t10 = load i32 %t9
    return i32 %t10
}
function @Y__operator_(%this : ptr, %other : ptr [pass=reference]) -> ptr [unwind=no, binding=weak, object=_ZN1YaSERKS_] {
  slot $this : ptr
  slot $other : ptr

  block ^entry:
    store ptr %this, $this
    store ptr %other, $other
    %t1 = load ptr $this
    %t2 = load ptr $other
    copyobj 4x4 %t2, %t1
    %t3 = load ptr $this
    return ptr %t3
}
