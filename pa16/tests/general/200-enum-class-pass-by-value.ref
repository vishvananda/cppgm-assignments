function @f(%e : i32) -> i32 [binding=strong, object=_Z1f1E] {
  slot $e : i32

  block ^entry:
    store i32 %e, $e
    %t1 = load i32 $e
    return i32 %t1
}
function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  block ^entry:
    %t1 = call i32 @f(8)
    %t2 = binary sub i32 %t1, 8
    return i32 %t2
}
