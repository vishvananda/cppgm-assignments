function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $d : obj<1x1>

  block ^entry:
    %t1 = addr $d
    %t2 = addr $d
    %t3 = index i8 [projection=base_subobject] %t2, 0
    %t4 = call i32 @Base__f(%t3)
    %t5 = binary sub i32 %t4, 7
    return i32 %t5
}
function @Base__f(%this : ptr) -> i32 [binding=weak, object=_ZNK4Base1fEv] {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    return i32 7
}
