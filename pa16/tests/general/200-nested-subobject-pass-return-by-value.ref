function @make() -> obj<8x4> [binding=strong, object=_Z4makev] {
  slot $o : obj<8x4>
  slot $retobj__1 : obj<8x4>

  block ^entry:
    %t1 = addr $o
    %t2 = addr $o
    %t3 = index i8 [projection=field] %t2, 0
    %t4 = index i8 [projection=field] %t3, 0
    store i32 7, %t4
    %t5 = addr $o
    %t6 = index i8 [projection=field] %t5, 4
    store i32 3, %t6
    %t7 = addr $retobj__1
    %t8 = addr $o
    copyobj 8x4 %t8, %t7
    return obj<8x4> $retobj__1
}
function @read(%o : obj<8x4>) -> i32 [binding=strong, object=_Z4read5Outer] {
  slot $o : obj<8x4>

  block ^entry:
    %t1 = addr $o
    copyobj 8x4 %o, %t1
    %t2 = addr $o
    %t3 = index i8 [projection=field] %t2, 0
    %t4 = index i8 [projection=field] %t3, 0
    %t5 = load i32 %t4
    return i32 %t5
}
function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $argobj__1 : obj<8x4>

  block ^entry:
    %t1 = addr $argobj__1
    %t2 = call obj<8x4> @make()
    copyobj 8x4 %t2, %t1
    %t3 = call i32 @read($argobj__1)
    %t4 = binary sub i32 %t3, 7
    return i32 %t4
}
