global @N__K : i32 [binding=internal, object=_ZN1N1KE] = 3

function @g() -> i32 [binding=strong, object=_Z1gv] {
  block ^entry:
    %t1 = binary add i32 3, 1
    return i32 %t1
}
function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  block ^entry:
    %t1 = call i32 @g()
    %t2 = binary sub i32 %t1, 4
    return i32 %t2
}
