function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $x : obj<1x1>
  slot $cond__1 : i32

  block ^entry:
    %t1 = addr $x
    %t2 = addr $x
    %t3 = addr $x
    %t4 = call u8 @X__same(%t2, %t3)
    branch %t4, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i32 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i32 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t5 = load i32 $cond__1
    return i32 %t5
}
function @X__same(%this : ptr, %other : ptr [pass=reference]) -> u8 [binding=weak, object=_ZNK1X4sameERKS_] {
  slot $this : ptr
  slot $other : ptr

  block ^entry:
    store ptr %this, $this
    store ptr %other, $other
    %t1 = load ptr $this
    %t2 = load ptr $other
    %t3 = cmp eq ptr %t1, %t2
    return u8 %t3
}
