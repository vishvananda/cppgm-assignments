declare function @move_ref(%arg0 : ptr [pass=reference]) -> ptr [binding=strong, object=_Z8move_refR1S]

function @read_ref(%s : ptr [pass=reference]) -> i32 [binding=strong, object=_Z8read_refRK1S] {
  slot $s : ptr

  block ^entry:
    store ptr %s, $s
    %t1 = load ptr $s
    %t2 = index i8 [projection=field] %t1, 0
    %t3 = load i32 %t2
    return i32 %t3
}
function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $s : obj<4x4>

  block ^entry:
    %t1 = addr $s
    %t2 = addr $s
    %t3 = index i8 [projection=field] %t2, 0
    store i32 7, %t3
    %t4 = addr $s
    %t5 = call ptr @move_ref(%t4)
    %t6 = call i32 @read_ref(%t5)
    return i32 %t6
}
