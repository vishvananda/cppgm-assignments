function @get(%y : obj<4x4>) -> i32 [binding=strong, object=_Z3get1Y] {
  slot $y : obj<4x4>

  block ^entry:
    %t1 = addr $y
    copyobj 4x4 %y, %t1
    %t2 = addr $y
    %t3 = index i8 [projection=field] %t2, 0
    %t4 = load i32 %t3
    return i32 %t4
}
function @id(%y : obj<4x4>) -> obj<4x4> [binding=strong, object=_Z2id1Y] {
  slot $y : obj<4x4>
  slot $retobj__1 : obj<4x4>

  block ^entry:
    %t1 = addr $y
    copyobj 4x4 %y, %t1
    %t2 = addr $retobj__1
    %t3 = addr $y
    copyobj 4x4 %t3, %t2
    return obj<4x4> $retobj__1
}
function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $a : obj<4x4>
  slot $argobj__1 : obj<4x4>
  slot $argobj__2 : obj<4x4>

  block ^entry:
    %t1 = addr $a
    %t2 = addr $a
    %t3 = index i8 [projection=field] %t2, 0
    store i32 6, %t3
    %t4 = addr $argobj__1
    %t5 = addr $argobj__2
    %t6 = addr $a
    copyobj 4x4 %t6, %t5
    %t7 = call obj<4x4> @id($argobj__2)
    copyobj 4x4 %t7, %t4
    %t8 = call i32 @get($argobj__1)
    return i32 %t8
}
