function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $x : obj<4x4>

  block ^entry:
    %t1 = addr $x
    %t2 = addr $x
    %t3 = index i8 [projection=field] %t2, 0
    store i32 4, %t3
    %t4 = addr $x
    %t5 = call ptr @X__operator__(%t4)
    %t6 = addr $x
    %t7 = index i8 [projection=field] %t6, 0
    %t8 = load i32 %t7
    %t9 = binary sub i32 %t8, 3
    return i32 %t9
}
function @X__operator__(%this : ptr) -> ptr [binding=weak, object=_ZN1XmmEv] {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    %t1 = load ptr $this
    %t2 = index i8 [projection=field] %t1, 0
    %t3 = load i32 %t2
    %t4 = binary sub i32 %t3, 1
    %t5 = load ptr $this
    %t6 = index i8 [projection=field] %t5, 0
    store i32 %t4, %t6
    %t7 = load ptr $this
    return ptr %t7
}
