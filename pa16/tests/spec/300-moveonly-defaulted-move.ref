function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $source : obj<4x4>
  slot $dest : obj<4x4>
  slot $cond__1 : i32

  block ^entry:
    %t1 = addr $source
    call void @MoveOnly__MoveOnly(%t1)
    %t2 = addr $dest
    %t3 = addr $source
    call void @MoveOnly__MoveOnly__ov3(%t2, %t3)
    %t4 = addr $dest
    %t5 = index i8 [projection=field] %t4, 0
    %t6 = load i32 %t5
    %t7 = cmp eq i32 %t6, 5
    branch %t7, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i32 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i32 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t8 = load i32 $cond__1
    return i32 %t8
}
function @MoveOnly__MoveOnly(%this : ptr) -> void [binding=weak, object=_ZN8MoveOnlyC1Ev] {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    %t1 = load ptr $this
    %t2 = index i8 [projection=field] %t1, 0
    store i32 5, %t2
    return void
}
function @MoveOnly__MoveOnly__ov3(%this : ptr, %__param1 : ptr [pass=reference]) -> void [unwind=no, binding=weak, object=_ZN8MoveOnlyC1EOS_] {
  slot $this : ptr
  slot $__param1 : ptr

  block ^entry:
    store ptr %this, $this
    store ptr %__param1, $__param1
    %t1 = load ptr $this
    %t2 = load ptr $__param1
    copyobj 4x4 %t2, %t1
    return void
}
