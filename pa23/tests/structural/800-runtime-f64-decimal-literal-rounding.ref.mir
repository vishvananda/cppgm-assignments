machine_ir x86_64 linux

startup
    call @main
    mov rdi, rax
    exit

function @main
  abi
    return i32 -> rax
  frame
    stack_size 48
    scratch_bytes 48

  block ^entry
    fmov.f64 xmm0, 623e+100
    fmov.f64 xmm1, 0x1.640a62f3a83dfp+341
    fcmp.f64 xmm0, xmm1
    jp ^bad
    je ^ok
    jmp ^bad

  block ^bad
    mov rax, 1
    ret rax

  block ^ok
    mov rax, 0
    ret rax
