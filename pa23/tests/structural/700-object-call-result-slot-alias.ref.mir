machine_ir x86_64 linux

startup
    call @main
    mov rdi, rax
    exit

function @make_value
  abi
    return obj<8x8> -> rax
  frame
    stack_size 16
    scratch_bytes 0
    slot $tmp -> [rbp-8] : obj<8x8>

  block ^entry
    mov rax, 7
    lea rcx, [rbp-8]
    store.i64 [rcx], rax
    lea r11, [rbp-8]
    load.i64 rax, [r11]
    ret

function @unwrap
  abi
    return i64 -> rax
  frame
    stack_size 16
    scratch_bytes 0
    slot $x -> [rbp-8] : obj<8x8>

  block ^entry
    call @make_value
    lea r11, [rbp-8]
    store.i64 [r11], rax
    lea rcx, [rbp-8]
    load.i64 rax, [rcx]
    ret rax

function @main
  abi
    return i64 -> rax
  frame
    stack_size 0
    scratch_bytes 0

  block ^entry
    call @unwrap
    ret rax
