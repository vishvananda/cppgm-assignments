machine_ir x86_64 <host-target>

startup
    call @main
    mov rdi, rax
    exit

function @id
  abi
    param %a -> rdi : i64
    return i64 -> rax
  frame
    stack_size 16
    scratch_bytes 0

  block ^entry
    mov rax, rdi
    ret rax

function @main
  abi
    return i64 -> rax
  frame
    stack_size 16
    scratch_bytes 0
    preserve <gpr0>

  block ^entry
    mov <gpr0>, 7
    mov rdi, <gpr0>
    call @id
    mov rax, <gpr0>
    ret rax
