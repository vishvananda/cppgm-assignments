machine_ir x86_64 <host-target>

startup
    call @main
    mov rdi, rax
    exit

function @main
  abi
    return i64 -> rax
  frame
    stack_size 16
    scratch_bytes 0
    slot $x -> [rbp-1] : i8

  block ^entry
    mov rax, -1
    store.i8 [rbp-1], rax
    lea rcx, [rbp-1]
    load.i8 r8, [rcx]
    sext.i8 r8
    mov rdx, -1
    cmp.i64 r8, rdx
    sete r8
    movzx r8, r8
    mov rax, r8
    ret rax
