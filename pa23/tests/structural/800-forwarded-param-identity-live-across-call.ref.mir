machine_ir x86_64 linux

startup
    call @main
    mov rdi, rax
    exit

global @cell
  storage data
  item i64 41

function @touch
  abi
    param %p -> rdi : ptr
    param %n -> rsi : i64
    return i64 -> rax
  frame
    stack_size 16
    scratch_bytes 0
    param-slot %p -> [rbp-8] : ptr

  block ^entry
    store.ptr [rbp-8], rdi
    mov rax, rsi
    ret rax

function @load_value
  abi
    param %p -> rdi : ptr
    return i64 -> rax
  frame
    stack_size 16
    scratch_bytes 0

  block ^entry
    mov r8, rdi
    load.i64 rax, [r8]
    ret rax

function @read_after_call
  abi
    param %this -> rdi : ptr
    param %n -> rsi : i64
    return i64 -> rax
  frame
    stack_size 16
    scratch_bytes 0
    preserve rbx

  block ^entry
    mov rbx, rdi
    mov r8, rsi
    mov rdi, rbx
    mov rsi, r8
    call @touch
    mov rdi, rbx
    call @load_value
    ret rax

function @main
  abi
    return i64 -> rax
  frame
    stack_size 16
    scratch_bytes 0
    preserve rbx

  block ^entry
    mov r8, @cell
    mov r9, 7
    mov rdi, r8
    mov rsi, r9
    call @read_after_call
    mov rbx, rax
    cmp.i64 rbx, 41
    je ^good
    jmp ^bad

  block ^good
    mov rax, 0
    ret rax

  block ^bad
    mov rax, 1
    ret rax
