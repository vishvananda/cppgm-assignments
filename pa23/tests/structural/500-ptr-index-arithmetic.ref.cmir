machine_ir x86_64 <host-target>

startup
    call @main
    mov rdi, rax
    exit

global @cells
  storage data
  item i64 11
  item i64 13

function @main
  abi
    return i64 -> rax
  frame
    stack_size 16
    scratch_bytes 0
    preserve <gpr0>

  block ^entry
    mov r8, @cells
    mov r9, r8
    lea r9, [r9+<off0>]
    mov <gpr0>, r9
    sub <gpr0>, r8
    load.i64 r8, [r9]
    mov rdx, 1
    cmp.i64 <gpr0>, rdx
    sete <gpr0>
    movzx <gpr0>, <gpr0>
    mov rdx, 13
    cmp.i64 r8, rdx
    sete r8
    movzx r8, r8
    and <gpr0>, r8
    mov rax, <gpr0>
    ret rax
