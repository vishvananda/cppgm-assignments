machine_ir x86_64 <host-target>

startup
    call @main
    mov rdi, rax
    exit

function @g
  abi
    param %a -> rdi : ptr
    param %b -> rsi : ptr
    return ptr -> rax
  frame
    stack_size 16
    scratch_bytes 0
    param-slot %b -> [rbp-<off0>] : ptr

  block ^entry
    store.ptr [rbp-<off0>], rsi
    mov rax, rdi
    ret rax

function @f
  abi
    param %this -> rdi : ptr
    param %rhs -> rsi : ptr
    return ptr -> rax
  frame
    stack_size 16
    scratch_bytes 0
    preserve <gpr0>

  block ^entry
    mov <gpr0>, rdi
    mov r8, rsi
    mov rdi, <gpr0>
    lea rdi, [rdi+<off0>]
    mov rsi, r8
    lea rsi, [rsi+<off0>]
    call @g
    mov rax, <gpr0>
    ret rax

function @main
  abi
    return i64 -> rax
  frame
    stack_size 0
    scratch_bytes 0

  block ^entry
    mov rax, 0
    ret rax
