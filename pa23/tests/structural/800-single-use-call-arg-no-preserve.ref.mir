machine_ir x86_64 linux

startup
    call @main
    mov rdi, rax
    exit

function @one
  abi
    return i64 -> rax
  frame
    stack_size 0
    scratch_bytes 0

  block ^entry
    mov rax, 1
    ret rax

function @foo
  abi
    param %a -> rdi : i64
    param %b -> rsi : i64
    param %c -> rdx : i64
    param %d -> rcx : i64
    param %e -> r8 : i64
    param %f -> r9 : i64
    return i64 -> rax
  frame
    stack_size 64
    scratch_bytes 0
    param-slot %a -> [rbp-8] : i64
    param-slot %b -> [rbp-16] : i64
    param-slot %c -> [rbp-24] : i64
    param-slot %d -> [rbp-32] : i64
    param-slot %e -> [rbp-40] : i64
    param-slot %f -> [rbp-48] : i64

  block ^entry
    store.i64 [rbp-8], rdi
    store.i64 [rbp-16], rsi
    store.i64 [rbp-24], rdx
    store.i64 [rbp-32], rcx
    store.i64 [rbp-40], r8
    store.i64 [rbp-48], r9
    mov rax, 0
    ret rax

function @main
  abi
    return i64 -> rax
  frame
    stack_size 16
    scratch_bytes 0
    preserve rbx

  block ^entry
    call @one
    mov rdi, rax
    mov rsi, 20
    mov rdx, 30
    mov rcx, 40
    mov r8, 50
    mov r9, 60
    call @foo
    mov rax, 0
    ret rax
