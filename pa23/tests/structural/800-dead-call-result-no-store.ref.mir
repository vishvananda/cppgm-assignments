machine_ir x86_64 linux

startup
    call @main
    mov rdi, rax
    exit

function @id
  abi
    param %a -> rdi : i64
    return i64 -> rax
  frame
    stack_size 16
    scratch_bytes 0

  block ^entry
    mov rax, rdi
    ret rax

function @main
  abi
    return i64 -> rax
  frame
    stack_size 16
    scratch_bytes 0
    preserve rbx

  block ^entry
    mov rbx, 7
    mov rdi, rbx
    call @id
    mov rax, rbx
    ret rax
