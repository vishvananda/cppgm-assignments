machine_ir x86_64 <host-target>

startup
    call @main
    mov rdi, rax
    exit

function @g
  abi
    param %this -> rdi : ptr
    param %__i -> rsi : i64
    return ptr -> rax
  frame
    stack_size 32
    scratch_bytes 0
    preserve <gpr0> <gpr1>

  block ^entry
    mov <gpr0>, rdi
    load.ptr <gpr1>, [<gpr0>]
    mov rdx, rsi
    imul rdx, 8
    add <gpr1>, rdx
    mov rax, <gpr1>
    ret rax

function @main
  abi
    return i64 -> rax
  frame
    stack_size 0
    scratch_bytes 0

  block ^entry
    mov rax, 0
    ret rax
