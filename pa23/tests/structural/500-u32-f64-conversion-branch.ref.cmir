machine_ir x86_64 <host-target>

startup
    call @main
    mov rdi, rax
    exit

function @main
  abi
    return i64 -> rax
  frame
    stack_size 48
    scratch_bytes 48

  block ^entry
    uitofp.i32.f64 xmm0, 7
    fptoui.f64.i32 r8, xmm0
    cmp.u32 r8, 7
    je ^ok
    jmp ^bad

  block ^bad
    mov rax, 1
    ret rax

  block ^ok
    mov rax, 0
    ret rax
