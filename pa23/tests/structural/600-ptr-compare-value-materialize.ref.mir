machine_ir x86_64 linux

startup
    call @main
    mov rdi, rax
    exit

global @cells
  storage data
  item i64 11
  item i64 13

function @main
  abi
    return i64 -> rax
  frame
    stack_size 16
    scratch_bytes 0
    preserve rbx

  block ^entry
    mov r8, @cells
    mov r9, r8
    lea r9, [r9+8]
    mov rbx, r9
    cmp.ptr rbx, r9
    sete rbx
    movzx rbx, rbx
    cmp.ptr r9, r8
    setne r9
    movzx r9, r9
    add rbx, r9
    mov rax, rbx
    ret rax
