machine_ir x86_64 linux

startup
    call @main
    mov rdi, rax
    exit

function @add
  abi
    param %a -> xmm0 : f64
    param %b -> xmm1 : f64
    return f64 -> xmm0
  frame
    stack_size 64
    scratch_bytes 48
    param-slot %a -> [rbp-8] : f64
    param-slot %b -> [rbp-16] : f64

  block ^entry
    fmov.f64 [rbp-8], xmm0
    fmov.f64 [rbp-16], xmm1
    fadd.f64 xmm0, [rbp-8], [rbp-16]
    fmov.f64 xmm0, xmm0
    ret

function @main
  abi
    return i64 -> rax
  frame
    stack_size 48
    scratch_bytes 48

  block ^entry
    fmov.f64 xmm0, 1.5
    fmov.f64 xmm1, 2.25
    fmov.f64 xmm0, xmm0
    fmov.f64 xmm1, xmm1
    call @add
    fmov.f64 xmm2, xmm0
    fmov.f64 xmm0, 3.75
    feq.f64 rax, xmm2, xmm0
    ret rax
