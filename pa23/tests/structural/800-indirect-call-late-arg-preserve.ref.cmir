machine_ir x86_64 macos

startup
    call @main
    mov rdi, rax
    exit

global @box
  storage scalar i8
  init i8 7

global @strlit
  storage data
  item i8 0

global @dispatch readonly
  storage data
  item ptr addr @sink

global @g_num
  storage scalar i64
  init i64 0

global @g_type
  storage scalar i32
  init i32 0

global @g_nbytes
  storage scalar i64
  init i64 0

function @data
  abi
    param %this -> rdi : ptr
    return ptr -> rax
  frame
    stack_size 16
    scratch_bytes 0

  block ^entry
    mov rax, rdi
    ret rax

function @size
  abi
    param %this -> rdi : ptr
    return i64 -> rax
  frame
    stack_size 16
    scratch_bytes 0
    param-slot %this -> [rbp-8] : ptr

  block ^entry
    store.ptr [rbp-8], rdi
    mov rax, 1
    ret rax

function @sink
  abi
    param %this -> rdi : ptr
    param %src -> rsi : ptr
    param %num -> rdx : i64
    param %type -> rcx : i32
    param %data -> r8 : ptr
    param %nbytes -> r9 : i64
    return void -> void
  frame
    stack_size 48
    scratch_bytes 0
    preserve rbx
    param-slot %this -> [rbp-8] : ptr
    param-slot %src -> [rbp-16] : ptr
    param-slot %data -> [rbp-24] : ptr

  block ^entry
    store.ptr [rbp-8], rdi
    store.ptr [rbp-16], rsi
    store.ptr [rbp-24], r8
    mov rbx, rcx
    store.i64 @g_num, rdx
    store.i32 @g_type, rbx
    store.i64 @g_nbytes, r9
    ret

function @main
  abi
    return i64 -> rax
  frame
    stack_size 48
    scratch_bytes 0
    preserve rbx r12 r13 r14 r15

  block ^entry
    mov rbx, @box
    mov r12, @strlit
    mov r13, 1
    mov rdi, rbx
    call @data
    mov r14, rax
    mov rdi, rbx
    call @size
    mov r8, rax
    mov r9, @dispatch
    load.ptr r15, [r9]
    store.i64 [rbp-8], r8
    mov r10, r15
    mov rdi, rbx
    mov rsi, r12
    mov rdx, r13
    mov rcx, 13
    mov r8, r14
    load.i64 r9, [rbp-8]
    call *r10
    cmp.i64 @g_num, 1
    je ^rhs
    jmp ^short

  block ^rhs
    load.i32 r8, @g_type
    sext.i32 r8
    mov rdx, 13
    cmp.i32 r8, rdx
    sete r8
    movzx r8, r8
    cmp.i64 r8, 0
    jne ^rhs2
    jmp ^short

  block ^rhs2
    load.i64 r8, @g_nbytes
    mov rdx, 1
    cmp.i64 r8, rdx
    sete r8
    movzx r8, r8
    mov rdx, 0
    cmp.i64 r8, rdx
    setne r8
    movzx r8, r8
    mov rax, r8
    ret rax

  block ^short
    mov rax, 0
    ret rax
