machine_ir x86_64 linux

startup
    call @main
    mov rdi, rax
    exit

function @main
  abi
    return i64 -> rax
  frame
    stack_size 48
    scratch_bytes 48

  block ^entry
    fmov.f32 xmm0, 1.5f
    fmov.f32 xmm1, 2.0f
    fadd.f32 xmm2, xmm0, xmm1
    fmul.f32 xmm0, xmm2, 4.0f
    fcmp.f32 xmm0, 14.0f
    jp ^bad
    je ^ok
    jmp ^bad

  block ^bad
    mov rax, 1
    ret rax

  block ^ok
    mov rax, 0
    ret rax
