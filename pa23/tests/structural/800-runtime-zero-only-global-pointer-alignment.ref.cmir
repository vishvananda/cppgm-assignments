machine_ir x86_64 <host-target>

startup
    call @main
    mov rdi, rax
    exit

global @byte
  storage scalar u8
  init u8 0

global @table
  storage data
  item zero 16

function @main
  abi
    return i64 -> rax
  frame
    stack_size 16
    scratch_bytes 0
    preserve <gpr0>

  block ^entry
    mov r8, @table
    mov r9, r8
    mov rdx, 1
    or r9, rdx
    mov <gpr0>, 1
    not <gpr0>
    and r9, <gpr0>
    cmp.i64 r9, r8
    je ^ok
    jmp ^bad

  block ^bad
    mov rax, 1
    ret rax

  block ^ok
    mov rax, 0
    ret rax
