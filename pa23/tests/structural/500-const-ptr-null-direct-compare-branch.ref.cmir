machine_ir x86_64 <host-target>

startup
    call @main
    mov rdi, rax
    exit

function @main
  abi
    return i64 -> rax
  frame
    stack_size 0
    scratch_bytes 0

  block ^entry
    mov r8, 0
    cmp.ptr r8, 0
    je ^good
    jmp ^bad

  block ^bad
    mov rax, 0
    ret rax

  block ^good
    mov rax, 1
    ret rax
