machine_ir x86_64 linux

startup
    call @main
    mov rdi, rax
    exit

function @main
  abi
    return i64 -> rax
  frame
    stack_size 96
    scratch_bytes 48
    temp %a -> [rbp-16] : f80
    temp %b -> [rbp-32] : f80
    temp %sum -> [rbp-48] : f80

  block ^entry
    fmov.f80 [rbp-16], 1.25L
    fmov.f80 [rbp-32], 2.5L
    fadd.f80 [rbp-48], [rbp-16], [rbp-32]
    feq.f80 rax, [rbp-48], 3.75L
    ret rax
