machine_ir x86_64 linux

startup
    call @main
    mov rdi, rax
    exit

global @box
  storage scalar i64
  init i64 7

function @id
  abi
    param %x -> rdi : ptr
    return ptr -> rax
  frame
    stack_size 16
    scratch_bytes 0

  block ^entry
    mov rax, rdi
    ret rax

function @wrap
  abi
    param %this -> rdi : ptr
    param %pf -> rsi : ptr
    return ptr -> rax
  frame
    stack_size 32
    scratch_bytes 0
    preserve rbx r12 r13

  block ^entry
    mov r9, rdi
    mov r8, rsi
    mov rbx, rdi
    mov r10, rsi
    mov rdi, rbx
    call *r10
    ret rax

function @main
  abi
    return i64 -> rax
  frame
    stack_size 16
    scratch_bytes 0
    preserve rbx

  block ^entry
    mov rbx, @box
    mov r8, @id
    mov rdi, rbx
    mov rsi, r8
    call @wrap
    mov r9, rax
    cmp.ptr r9, rbx
    sete r9
    movzx r9, r9
    mov rax, r9
    ret rax
