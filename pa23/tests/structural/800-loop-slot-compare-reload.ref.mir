machine_ir x86_64 linux

startup
    call @main
    mov rdi, rax
    exit

global @cells
  storage data
  item i64 11
  item i64 13
  item i64 17

function @main
  abi
    return i64 -> rax
  frame
    stack_size 16
    scratch_bytes 0
    slot $first -> [rbp-8] : ptr
    slot $last -> [rbp-16] : ptr

  block ^entry
    mov r8, @cells
    store.ptr [rbp-8], r8
    lea r8, [r8+16]
    store.ptr [rbp-16], r8
    jmp ^loop

  block ^loop
    load.ptr r8, [rbp-8]
    cmp.ptr r8, [rbp-16]
    je ^done
    jmp ^body

  block ^body
    mov r9, r8
    lea r9, [r9+8]
    store.ptr [rbp-8], r9
    jmp ^loop

  block ^done
    mov rax, 0
    ret rax
