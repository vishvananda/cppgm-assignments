machine_ir x86_64 <host-target>

startup
    call @main
    mov rdi, rax
    exit

global @box
  storage scalar i64
  init i64 7

function @id
  abi
    param %x -> rdi : ptr
    return ptr -> rax
  frame
    stack_size 16
    scratch_bytes 0

  block ^entry
    mov rax, rdi
    ret rax

function @wrap
  abi
    param %this -> rdi : ptr
    param %pf -> rsi : ptr
    return ptr -> rax
  frame
    stack_size 32
    scratch_bytes 0
    preserve <gpr0> <gpr1> <gpr2>

  block ^entry
    mov r9, rdi
    mov r8, rsi
    mov <gpr0>, rdi
    mov <gpr3>, rsi
    mov rdi, <gpr0>
    call *<gpr3>
    ret rax

function @main
  abi
    return i64 -> rax
  frame
    stack_size 16
    scratch_bytes 0
    preserve <gpr0>

  block ^entry
    mov <gpr0>, @box
    mov r8, @id
    mov rdi, <gpr0>
    mov rsi, r8
    call @wrap
    mov r9, rax
    cmp.ptr r9, <gpr0>
    sete r9
    movzx r9, r9
    mov rax, r9
    ret rax
