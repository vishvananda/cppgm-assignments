machine_ir x86_64 linux

startup
    call @main
    mov rdi, rax
    exit

function @probe
  abi
    param %a -> rdi : ptr
    param %b -> rsi : ptr
    param %c -> rdx : ptr
    param %d -> rcx : ptr
    return u8 -> rax
  frame
    stack_size 48
    scratch_bytes 0
    param-slot %a -> [rbp-8] : ptr
    param-slot %b -> [rbp-16] : ptr
    param-slot %c -> [rbp-24] : ptr
    param-slot %d -> [rbp-32] : ptr

  block ^entry
    store.ptr [rbp-8], rdi
    store.ptr [rbp-16], rsi
    store.ptr [rbp-24], rdx
    store.ptr [rbp-32], rcx
    mov rax, 0
    ret rax

function @clobber
  abi
    return void -> void
  frame
    stack_size 0
    scratch_bytes 0

  block ^entry
    ret

function @main
  abi
    return i64 -> rax
  frame
    stack_size 144
    scratch_bytes 0
    preserve rbx r12 r13 r14 r15
    slot $value -> [rbp-24] : obj<24x8>
    slot $ud_suffix -> [rbp-48] : obj<24x8>
    slot $literal_type -> [rbp-52] : i32
    slot $call__1 -> [rbp-53] : u8
    slot $k0 -> [rbp-64] : i64
    slot $k1 -> [rbp-72] : i64
    slot $k2 -> [rbp-80] : i64
    slot $k3 -> [rbp-88] : i64
    slot $k4 -> [rbp-96] : i64
    temp %t6 -> [rbp-97] : u8

  block ^entry
    mov rax, 1
    store.i32 [rbp-52], rax
    mov rax, 10
    store.i64 [rbp-64], rax
    mov rax, 11
    store.i64 [rbp-72], rax
    mov rax, 12
    store.i64 [rbp-80], rax
    mov rax, 13
    store.i64 [rbp-88], rax
    mov rax, 14
    store.i64 [rbp-96], rax
    lea rdi, [rbp-24]
    lea rsi, [rbp-48]
    lea rdx, [rbp-52]
    lea rcx, [rbp-48]
    call @probe
    mov r8, rax
    zext.i8 r8
    store.u8 [rbp-53], r8
    load.i64 rbx, [rbp-64]
    load.i64 r12, [rbp-72]
    load.i64 r13, [rbp-80]
    load.i64 r14, [rbp-88]
    load.i64 r15, [rbp-96]
    load.u8 rax, [rbp-53]
    store.u8 [rbp-97], rax
    call @clobber
    load.u8 rax, [rbp-97]
    cmp.i64 rax, 0
    je ^then
    jmp ^else

  block ^then
    mov r8, rbx
    add r8, r12
    mov r9, r13
    add r9, r14
    add r8, r9
    add r8, r15
    mov rax, r8
    ret rax

  block ^else
    mov rax, 0
    ret rax
