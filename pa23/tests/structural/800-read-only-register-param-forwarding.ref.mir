machine_ir x86_64 linux

startup
    call @main
    mov rdi, rax
    exit

function @g
  abi
    param %this -> rdi : ptr
    param %__i -> rsi : i64
    return ptr -> rax
  frame
    stack_size 32
    scratch_bytes 0
    preserve rbx r12

  block ^entry
    mov rbx, rdi
    load.ptr r12, [rbx]
    mov rdx, rsi
    imul rdx, 8
    add r12, rdx
    mov rax, r12
    ret rax

function @main
  abi
    return i64 -> rax
  frame
    stack_size 0
    scratch_bytes 0

  block ^entry
    mov rax, 0
    ret rax
