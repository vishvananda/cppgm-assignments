machine_ir x86_64 <host-target>

startup
    call @main
    mov rdi, rax
    exit

function @one
  abi
    return i64 -> rax
  frame
    stack_size 0
    scratch_bytes 0

  block ^entry
    mov rax, 1
    ret rax

function @foo
  abi
    param %a -> rdi : i64
    param %b -> rsi : i64
    param %c -> rdx : i64
    param %d -> rcx : i64
    param %e -> r8 : i64
    param %f -> r9 : i64
    return i64 -> rax
  frame
    stack_size 64
    scratch_bytes 0
    param-slot %a -> [rbp-<off0>] : i64
    param-slot %b -> [rbp-<off1>] : i64
    param-slot %c -> [rbp-<off2>] : i64
    param-slot %d -> [rbp-<off3>] : i64
    param-slot %e -> [rbp-<off4>] : i64
    param-slot %f -> [rbp-<off5>] : i64

  block ^entry
    store.i64 [rbp-<off0>], rdi
    store.i64 [rbp-<off1>], rsi
    store.i64 [rbp-<off2>], rdx
    store.i64 [rbp-<off3>], rcx
    store.i64 [rbp-<off4>], r8
    store.i64 [rbp-<off5>], r9
    mov rax, 0
    ret rax

function @main
  abi
    return i64 -> rax
  frame
    stack_size 16
    scratch_bytes 0
    preserve <gpr0>

  block ^entry
    call @one
    mov rdi, rax
    mov rsi, 20
    mov rdx, 30
    mov rcx, 40
    mov r8, 50
    mov r9, 60
    call @foo
    mov rax, 0
    ret rax
