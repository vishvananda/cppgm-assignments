machine_ir x86_64 linux

startup
    call @main
    mov rdi, rax
    exit

global @g
  storage scalar i64
  init i64 7

function @main
  abi
    return i64 -> rax
  frame
    stack_size 0
    scratch_bytes 0

  block ^entry
    mov r8, @g
    cmp.ptr r8, 0
    jne ^good
    jmp ^bad

  block ^bad
    mov rax, 1
    ret rax

  block ^good
    mov rax, 0
    ret rax
