machine_ir x86_64 <host-target>

startup
    call @main
    mov rdi, rax
    exit

function @probe
  abi
    param %a -> rdi : ptr
    param %b -> rsi : ptr
    param %c -> rdx : ptr
    param %d -> rcx : ptr
    return u8 -> rax
  frame
    stack_size 48
    scratch_bytes 0
    param-slot %a -> [rbp-<off0>] : ptr
    param-slot %b -> [rbp-<off1>] : ptr
    param-slot %c -> [rbp-<off2>] : ptr
    param-slot %d -> [rbp-<off3>] : ptr

  block ^entry
    store.ptr [rbp-<off0>], rdi
    store.ptr [rbp-<off1>], rsi
    store.ptr [rbp-<off2>], rdx
    store.ptr [rbp-<off3>], rcx
    mov rax, 0
    ret rax

function @clobber
  abi
    return void -> void
  frame
    stack_size 0
    scratch_bytes 0

  block ^entry
    ret

function @main
  abi
    return i64 -> rax
  frame
    stack_size 144
    scratch_bytes 0
    preserve <gpr0> <gpr1> <gpr2> <gpr3> <gpr4>
    slot $value -> [rbp-<off2>] : obj<24x8>
    slot $ud_suffix -> [rbp-<off4>] : obj<24x8>
    slot $literal_type -> [rbp-<off5>] : i32
    slot $call__1 -> [rbp-<off6>] : u8
    slot $k0 -> [rbp-<off7>] : i64
    slot $k1 -> [rbp-<off8>] : i64
    slot $k2 -> [rbp-<off9>] : i64
    slot $k3 -> [rbp-<off10>] : i64
    slot $k4 -> [rbp-<off11>] : i64
    temp %t6 -> [rbp-<off12>] : u8

  block ^entry
    mov rax, 1
    store.i32 [rbp-<off5>], rax
    mov rax, 10
    store.i64 [rbp-<off7>], rax
    mov rax, 11
    store.i64 [rbp-<off8>], rax
    mov rax, 12
    store.i64 [rbp-<off9>], rax
    mov rax, 13
    store.i64 [rbp-<off10>], rax
    mov rax, 14
    store.i64 [rbp-<off11>], rax
    lea rdi, [rbp-<off2>]
    lea rsi, [rbp-<off4>]
    lea rdx, [rbp-<off5>]
    lea rcx, [rbp-<off4>]
    call @probe
    mov r8, rax
    zext.i8 r8
    store.u8 [rbp-<off6>], r8
    load.i64 <gpr0>, [rbp-<off7>]
    load.i64 <gpr1>, [rbp-<off8>]
    load.i64 <gpr2>, [rbp-<off9>]
    load.i64 <gpr3>, [rbp-<off10>]
    load.i64 <gpr4>, [rbp-<off11>]
    load.u8 rax, [rbp-<off6>]
    store.u8 [rbp-<off12>], rax
    call @clobber
    load.u8 rax, [rbp-<off12>]
    cmp.i64 rax, 0
    je ^then
    jmp ^else

  block ^then
    mov r8, <gpr0>
    add r8, <gpr1>
    mov r9, <gpr2>
    add r9, <gpr3>
    add r8, r9
    add r8, <gpr4>
    mov rax, r8
    ret rax

  block ^else
    mov rax, 0
    ret rax
