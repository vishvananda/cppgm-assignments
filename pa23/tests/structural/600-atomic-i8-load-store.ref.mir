machine_ir x86_64 linux

startup
    call @main
    mov rdi, rax
    exit

global @g
  storage scalar i8
  init i8 7

function @main
  abi
    return i64 -> rax
  frame
    stack_size 16
    scratch_bytes 0
    preserve rbx

  block ^entry
    mov r8, @g
    load.i8 r9, [r8]
    sext.i8 r9
    mov rbx, 1
    sext.i8 rbx
    add r9, rbx
    sext.i8 r9
    store.i8 [r8], r9
    load.i8 r9, [r8]
    sext.i8 r9
    mov rdx, 8
    cmp.i8 r9, rdx
    sete r9
    movzx r9, r9
    mov rax, r9
    ret rax
