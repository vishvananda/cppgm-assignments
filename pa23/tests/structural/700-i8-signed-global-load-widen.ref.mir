machine_ir x86_64 linux

startup
    call @main
    mov rdi, rax
    exit

global @g
  storage scalar i8
  init i8 -1

function @main
  abi
    return i64 -> rax
  frame
    stack_size 0
    scratch_bytes 0

  block ^entry
    load.i8 r8, @g
    sext.i8 r8
    mov rdx, -1
    cmp.i64 r8, rdx
    sete r8
    movzx r8, r8
    mov rax, r8
    ret rax
