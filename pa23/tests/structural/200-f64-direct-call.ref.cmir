machine_ir x86_64 <host-target>

startup
    call @main
    mov rdi, rax
    exit

function @add
  abi
    param %a -> xmm0 : f64
    param %b -> xmm1 : f64
    return f64 -> xmm0
  frame
    stack_size 64
    scratch_bytes 48
    param-slot %a -> [rbp-<off0>] : f64
    param-slot %b -> [rbp-<off1>] : f64

  block ^entry
    fmov.f64 [rbp-<off0>], xmm0
    fmov.f64 [rbp-<off1>], xmm1
    fadd.f64 xmm0, [rbp-<off0>], [rbp-<off1>]
    fmov.f64 xmm0, xmm0
    ret

function @main
  abi
    return i64 -> rax
  frame
    stack_size 48
    scratch_bytes 48

  block ^entry
    fmov.f64 xmm0, 1.5
    fmov.f64 xmm1, 2.25
    fmov.f64 xmm0, xmm0
    fmov.f64 xmm1, xmm1
    call @add
    fmov.f64 <xmm0>, xmm0
    fmov.f64 xmm0, 3.75
    feq.f64 rax, <xmm0>, xmm0
    ret rax
