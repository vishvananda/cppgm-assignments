machine_ir x86_64 linux

startup
    call @main
    mov rdi, rax
    exit

function @main
  abi
    return i64 -> rax
  frame
    stack_size 96
    scratch_bytes 48
    preserve rbx r12
    temp %4 -> [rbp-16] : f80
    temp %7 -> [rbp-32] : f80

  block ^entry
    fptosi.f64.i64 r8, -42.75
    mov rdx, -42
    cmp.i64 r8, rdx
    sete r8
    movzx r8, r8
    fptoui.f64.i64 r9, 42.75
    mov rdx, 42
    cmp.i64 r9, rdx
    sete r9
    movzx r9, r9
    sitofp.i64.f80 [rbp-16], -42
    fptosi.f80.i64 rbx, [rbp-16]
    mov rdx, -42
    cmp.i64 rbx, rdx
    sete rbx
    movzx rbx, rbx
    uitofp.i64.f80 [rbp-32], -1
    fptoui.f80.i64 r12, [rbp-32]
    mov rdx, -1
    cmp.i64 r12, rdx
    sete r12
    movzx r12, r12
    add r8, r9
    add r8, rbx
    add r8, r12
    mov rax, r8
    ret rax
