machine_ir x86_64 linux

startup
    call @main
    mov rdi, rax
    exit

function @main
  abi
    return i64 -> rax
  frame
    stack_size 16
    scratch_bytes 0
    slot $i -> [rbp-8] : i64
    slot $sum -> [rbp-16] : i64

  block ^entry
    mov rax, 1
    store.i64 [rbp-8], rax
    mov rax, 0
    store.i64 [rbp-16], rax
    jmp ^cond

  block ^cond
    load.i64 r8, [rbp-8]
    mov r9, r8
    sub r9, 1
    store.i64 [rbp-8], r9
    cmp.i64 r8, 0
    jg ^body
    jmp ^end

  block ^body
    load.i64 r8, [rbp-16]
    add r8, 17
    store.i64 [rbp-16], r8
    jmp ^cond

  block ^end
    cmp.i64 [rbp-16], 17
    je ^pass
    jmp ^fail

  block ^pass
    mov rax, 0
    ret rax

  block ^fail
    mov rax, 1
    ret rax
