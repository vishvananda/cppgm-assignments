machine_ir x86_64 <host-target>

startup
    call @main
    mov rdi, rax
    exit

function @make_value
  abi
    return obj<8x8> -> rax
  frame
    stack_size 16
    scratch_bytes 0
    slot $tmp -> [rbp-<off0>] : obj<8x8>

  block ^entry
    mov rax, 7
    lea rcx, [rbp-<off0>]
    store.i64 [rcx], rax
    lea <gpr0>, [rbp-<off0>]
    load.i64 rax, [<gpr0>]
    ret

function @unwrap
  abi
    return i64 -> rax
  frame
    stack_size 16
    scratch_bytes 0
    slot $x -> [rbp-<off0>] : obj<8x8>

  block ^entry
    call @make_value
    lea <gpr0>, [rbp-<off0>]
    store.i64 [<gpr0>], rax
    lea rcx, [rbp-<off0>]
    load.i64 rax, [rcx]
    ret rax

function @main
  abi
    return i64 -> rax
  frame
    stack_size 0
    scratch_bytes 0

  block ^entry
    call @unwrap
    ret rax
