machine_ir x86_64 linux

startup
    call @main
    mov rdi, rax
    exit

global @cells
  storage data
  item i64 11
  item i64 13
  item i64 17

function @main
  abi
    return i64 -> rax
  frame
    stack_size 0
    scratch_bytes 0

  block ^entry
    mov r8, @cells
    lea r8, [r8+8]
    lea r8, [r8+8]
    load.i64 r9, [r8]
    mov rdx, 17
    cmp.i64 r9, rdx
    sete r9
    movzx r9, r9
    mov rax, r9
    ret rax
