machine_ir x86_64 <host-target>

startup
    call @main
    mov rdi, rax
    exit

function @main
  abi
    return i64 -> rax
  frame
    stack_size 48
    scratch_bytes 48

  block ^entry
    fcmp.f32 1.0f, 2.0f
    jp ^right
    jb ^wrong
    jmp ^right

  block ^wrong
    mov rax, 1
    ret rax

  block ^right
    mov rax, 0
    ret rax
