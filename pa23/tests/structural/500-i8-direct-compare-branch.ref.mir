machine_ir x86_64 linux

startup
    call @main
    mov rdi, rax
    exit

function @main
  abi
    return i64 -> rax
  frame
    stack_size 0
    scratch_bytes 0

  block ^entry
    mov rax, 7
    mov rdx, 7
    cmp.i8 rax, rdx
    je ^ok
    jmp ^bad

  block ^bad
    mov rax, 1
    ret rax

  block ^ok
    mov rax, 0
    ret rax
