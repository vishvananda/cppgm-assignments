machine_ir x86_64 <host-target>

startup
    call @main
    mov rdi, rax
    exit

function @mix
  abi
    param %a -> rdi : i64
    param %b -> xmm0 : f64
    param %c -> rsi : i64
    param %d -> xmm1 : f64
    return i64 -> rax
  frame
    stack_size 96
    scratch_bytes 48
    preserve <gpr0> <gpr1> <gpr2>
    param-slot %b -> [rbp-<off0>] : f64
    param-slot %d -> [rbp-<off1>] : f64

  block ^entry
    fmov.f64 [rbp-<off0>], xmm0
    fmov.f64 [rbp-<off1>], xmm1
    mov <gpr0>, rsi
    fptosi.f64.i64 r9, [rbp-<off0>]
    fptosi.f64.i64 <gpr1>, [rbp-<off1>]
    mov <gpr2>, rdi
    add <gpr2>, <gpr0>
    add r9, <gpr1>
    add <gpr2>, r9
    mov rax, <gpr2>
    ret rax

function @main
  abi
    return i64 -> rax
  frame
    stack_size 64
    scratch_bytes 48
    preserve <gpr0>

  block ^entry
    mov r8, 4
    add r8, 6
    mov r9, 8
    add r9, 12
    sitofp.i64.f64 xmm0, r8
    sitofp.i64.f64 xmm1, r9
    mov rdi, r8
    fmov.f64 xmm0, xmm0
    mov rsi, r9
    fmov.f64 xmm1, xmm1
    call @mix
    mov <gpr0>, rax
    mov rdx, 50
    cmp.i64 <gpr0>, rdx
    sete <gpr0>
    movzx <gpr0>, <gpr0>
    mov rax, <gpr0>
    ret rax
