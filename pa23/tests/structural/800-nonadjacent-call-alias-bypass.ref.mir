machine_ir x86_64 linux

startup
    call @main
    mov rdi, rax
    exit

function @g
  abi
    param %a -> rdi : ptr
    return ptr -> rax
  frame
    stack_size 16
    scratch_bytes 0

  block ^entry
    mov rax, rdi
    ret rax

function @f
  abi
    param %a -> rdi : ptr
    param %b -> rsi : ptr
    param %c -> rdx : ptr
    param %src -> rcx : ptr
    return ptr -> rax
  frame
    stack_size 48
    scratch_bytes 0
    preserve rbx
    param-slot %a -> [rbp-8] : ptr
    param-slot %b -> [rbp-16] : ptr
    param-slot %c -> [rbp-24] : ptr
    slot $tmp -> [rbp-32] : obj<8x8>

  block ^entry
    store.ptr [rbp-8], rdi
    store.ptr [rbp-16], rsi
    store.ptr [rbp-24], rdx
    mov r9, rcx
    mov r8, rcx
    lea rdi, [rbp-32]
    mov rsi, rcx
    copy_bytes 8x8, rdi, rsi
    mov rdi, r8
    call @g
    ret rax

function @main
  abi
    return i64 -> rax
  frame
    stack_size 0
    scratch_bytes 0

  block ^entry
    mov rax, 0
    ret rax
