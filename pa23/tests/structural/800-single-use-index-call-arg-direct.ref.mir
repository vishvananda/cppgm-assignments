machine_ir x86_64 linux

startup
    call @main
    mov rdi, rax
    exit

function @g
  abi
    param %a -> rdi : ptr
    param %b -> rsi : ptr
    return ptr -> rax
  frame
    stack_size 16
    scratch_bytes 0
    param-slot %b -> [rbp-8] : ptr

  block ^entry
    store.ptr [rbp-8], rsi
    mov rax, rdi
    ret rax

function @f
  abi
    param %this -> rdi : ptr
    param %rhs -> rsi : ptr
    return ptr -> rax
  frame
    stack_size 16
    scratch_bytes 0
    preserve rbx

  block ^entry
    mov rbx, rdi
    mov r8, rsi
    mov rdi, rbx
    lea rdi, [rdi+128]
    mov rsi, r8
    lea rsi, [rsi+128]
    call @g
    mov rax, rbx
    ret rax

function @main
  abi
    return i64 -> rax
  frame
    stack_size 0
    scratch_bytes 0

  block ^entry
    mov rax, 0
    ret rax
