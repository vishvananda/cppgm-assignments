machine_ir x86_64 linux

startup
    call @main
    mov rdi, rax
    exit

global @table
  storage data
  item ptr addr @mix

function @mix
  abi
    param %a -> rdi : i64
    param %b -> xmm0 : f64
    param %c -> rsi : i64
    param %d -> xmm1 : f64
    return i64 -> rax
  frame
    stack_size 96
    scratch_bytes 48
    preserve rbx r12 r13
    param-slot %b -> [rbp-8] : f64
    param-slot %d -> [rbp-16] : f64

  block ^entry
    fmov.f64 [rbp-8], xmm0
    fmov.f64 [rbp-16], xmm1
    mov rbx, rsi
    fptosi.f64.i64 r9, [rbp-8]
    fptosi.f64.i64 r12, [rbp-16]
    mov r13, rdi
    add r13, rbx
    add r9, r12
    add r13, r9
    mov rax, r13
    ret rax

function @main
  abi
    return i64 -> rax
  frame
    stack_size 48
    scratch_bytes 48

  block ^entry
    load.ptr r8, @table
    mov r10, r8
    mov rdi, 10
    fmov.f64 xmm0, 1.5
    mov rsi, 20
    fmov.f64 xmm1, 2.5
    call *r10
    mov r9, rax
    mov rdx, 33
    cmp.i64 r9, rdx
    sete r9
    movzx r9, r9
    mov rax, r9
    ret rax
