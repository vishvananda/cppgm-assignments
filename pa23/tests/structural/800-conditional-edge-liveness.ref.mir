machine_ir x86_64 linux

startup
    call @__cppgm_406d61696e
    mov rdi, rax
    exit

function @f
  abi
    param %cond -> rdi : i64
    param %x -> rsi : i64
    return i64 -> rax
  frame
    stack_size 32
    scratch_bytes 0
    preserve rbx r12

  block ^entry
    mov r8, rdi
    mov r9, rsi
    cmp.i64 r8, 0
    jne ^then
    jmp ^else

  block ^then
    mov rax, r9
    ret rax

  block ^else
    mov rax, 0
    ret rax

function @__cppgm_406d61696e
  abi
    return i32 -> rax
  frame
    stack_size 16
    scratch_bytes 0
    preserve rbx

  block ^entry
    mov r8, 1
    mov r9, 41
    mov rdi, r8
    mov rsi, r9
    call @f
    mov rbx, rax
    cmp.i64 rbx, 41
    je ^good
    jmp ^bad

  block ^good
    mov rax, 0
    ret rax

  block ^bad
    mov rax, 1
    ret rax
