machine_ir x86_64 <host-target>

startup
    call @main
    mov rdi, rax
    exit

global @fp
  storage scalar ptr
  init addr @ret3

function @ret3
  abi
    return i64 -> rax
  frame
    stack_size 0
    scratch_bytes 0

  block ^entry
    mov rax, 3
    ret rax

function @main
  abi
    return i64 -> rax
  frame
    stack_size 0
    scratch_bytes 0

  block ^entry
    mov r8, @fp
    load.ptr <gpr0>, @fp
    call *<gpr0>
    ret rax
