machine_ir x86_64 linux

startup
    call @main
    mov rdi, rax
    exit

function @makef
  abi
    return f32 -> xmm0
  frame
    stack_size 48
    scratch_bytes 48

  block ^entry
    fmov.f32 xmm0, 1.5f
    ret

function @main
  abi
    return i64 -> rax
  frame
    stack_size 48
    scratch_bytes 48

  block ^entry
    call @makef
    fmov.f32 xmm0, xmm0
    fcmp.f32 xmm0, 1.5f
    jp ^wrong
    je ^right
    jmp ^wrong

  block ^wrong
    mov rax, 1
    ret rax

  block ^right
    mov rax, 0
    ret rax
