machine_ir x86_64 <host-target>

startup
    call @main
    mov rdi, rax
    exit

function @lhs_false
  abi
    return i64 -> rax
  frame
    stack_size 0
    scratch_bytes 0

  block ^entry
    mov rax, 0
    ret rax

function @rhs_true
  abi
    return i64 -> rax
  frame
    stack_size 0
    scratch_bytes 0

  block ^entry
    mov rax, 1
    ret rax

function @main
  abi
    return i64 -> rax
  frame
    stack_size 0
    scratch_bytes 0

  block ^entry
    call @lhs_false
    mov r8, rax
    cmp.i64 rax, 0
    jne ^true
    jmp ^rhs

  block ^rhs
    call @rhs_true
    cmp.i64 rax, 0
    jne ^true
    jmp ^false

  block ^true
    mov rax, 0
    ret rax

  block ^false
    mov rax, 1
    ret rax
