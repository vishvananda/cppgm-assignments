machine_ir x86_64 linux

startup
    call @main
    mov rdi, rax
    exit

function @g
  abi
    param %a -> rdi : ptr
    param %b -> rsi : i64
    return ptr -> rax
  frame
    stack_size 16
    scratch_bytes 0
    param-slot %b -> [rbp-8] : i64

  block ^entry
    store.i64 [rbp-8], rsi
    mov rax, rdi
    ret rax

function @f
  abi
    param %this -> rdi : ptr
    param %hash -> rsi : i64
    return ptr -> rax
  frame
    stack_size 32
    scratch_bytes 0
    preserve rbx r12 r13

  block ^entry
    mov r9, rdi
    mov r8, rsi
    call @g
    ret rax

function @main
  abi
    return i64 -> rax
  frame
    stack_size 0
    scratch_bytes 0

  block ^entry
    mov rax, 0
    ret rax
