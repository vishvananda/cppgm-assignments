machine_ir x86_64 linux

startup
    call @main
    mov rdi, rax
    exit

global @cells
  storage data
  item i64 11
  item i64 13

function @main
  abi
    return i64 -> rax
  frame
    stack_size 16
    scratch_bytes 0
    preserve rbx

  block ^entry
    mov r8, @cells
    mov r9, r8
    lea r9, [r9+8]
    mov rbx, r9
    sub rbx, r8
    load.i64 r8, [r9]
    mov rdx, 1
    cmp.i64 rbx, rdx
    sete rbx
    movzx rbx, rbx
    mov rdx, 13
    cmp.i64 r8, rdx
    sete r8
    movzx r8, r8
    and rbx, r8
    mov rax, rbx
    ret rax
