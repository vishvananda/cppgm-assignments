machine_ir x86_64 macos

startup
    call @main
    mov rdi, rax
    exit

function @main
  abi
    return i64 -> rax
  frame
    stack_size 16
    scratch_bytes 0
    slot $x -> [rbp-8] : i64

  block ^entry
    mov rax, 0
    store.i64 [rbp-8], rax
    lea rax, [rbp-8]
    lea rdx, [rbp-8]
    cmp.ptr rax, rdx
    je ^same
    jmp ^different

  block ^same
    mov rax, 0
    ret rax

  block ^different
    mov rax, 1
    ret rax
