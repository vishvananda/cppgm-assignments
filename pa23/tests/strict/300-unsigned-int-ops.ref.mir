machine_ir x86_64 linux

startup
    call @main
    mov rdi, rax
    exit

function @main
  abi
    return i64 -> rax
  frame
    stack_size 16
    scratch_bytes 0
    preserve rbx

  block ^entry
    mov r8, -1
    mov rdx, 2
    mov rcx, rdx
    mov rax, r8
    mov rdx, 0
    div rcx
    mov r8, rax
    mov rdx, 9223372036854775807
    cmp.i64 r8, rdx
    sete r8
    movzx r8, r8
    mov r9, -1
    mov rdx, 7
    mov rcx, rdx
    mov rax, r9
    mov rdx, 0
    div rcx
    mov r9, rdx
    mov rdx, 1
    cmp.i64 r9, rdx
    sete r9
    movzx r9, r9
    mov rbx, -16
    mov rdx, 2
    mov rcx, rdx
    shr rbx, cl
    mov rdx, 4611686018427387900
    cmp.i64 rbx, rdx
    sete rbx
    movzx rbx, rbx
    add r8, r9
    add r8, rbx
    mov rax, r8
    ret rax
