machine_ir x86_64 linux

startup
    call @main
    mov rdi, rax
    exit

global @YB__vtable
  storage data
  item ptr addr @YB__f
  item ptr addr @YB___YB

global @YD__vtable
  storage data
  item ptr addr @YD__f
  item ptr addr @YD___YD

function @YB__f
  abi
    param %this -> rdi : ptr
    return i64 -> rax
  frame
    stack_size 16
    scratch_bytes 0

  block ^entry
    mov rax, 1
    ret rax

function @YB___YB
  abi
    param %this -> rdi : ptr
    return void -> void
  frame
    stack_size 16
    scratch_bytes 0
    preserve rbx

  block ^entry
    mov r9, rdi
    mov rbx, @YB__vtable
    store.ptr [r9], rbx
    ret

function @YB__YB
  abi
    param %this -> rdi : ptr
    return void -> void
  frame
    stack_size 16
    scratch_bytes 0
    preserve rbx

  block ^entry
    mov r9, rdi
    mov rbx, @YB__vtable
    store.ptr [r9], rbx
    ret

function @YD__f
  abi
    param %this -> rdi : ptr
    return i64 -> rax
  frame
    stack_size 16
    scratch_bytes 0

  block ^entry
    mov rax, 2
    ret rax

function @YD__YD
  abi
    param %this -> rdi : ptr
    return void -> void
  frame
    stack_size 16
    scratch_bytes 0
    preserve rbx

  block ^entry
    mov rbx, rdi
    mov r8, rdi
    call @YB__YB
    mov r8, rbx
    mov r9, @YD__vtable
    store.ptr [r8], r9
    ret

function @YD___YD
  abi
    param %this -> rdi : ptr
    return void -> void
  frame
    stack_size 16
    scratch_bytes 0
    preserve rbx

  block ^entry
    mov r8, rdi
    mov r9, rdi
    mov rbx, @YD__vtable
    store.ptr [r9], rbx
    mov r9, rdi
    mov rdi, r8
    call @YB___YB
    ret

function @g
  abi
    param %b -> rdi : ptr
    return i64 -> rax
  frame
    stack_size 32
    scratch_bytes 0
    preserve rbx r12

  block ^entry
    mov r8, rdi
    mov r9, rdi
    load.ptr rbx, [r9]
    load.ptr r10, [rbx]
    mov rdi, r9
    call *r10
    ret rax

function @main
  abi
    return i64 -> rax
  frame
    stack_size 16
    scratch_bytes 0
    preserve rbx
    slot $d__0 -> [rbp-8] : i64

  block ^entry
    lea rdi, [rbp-8]
    call @YD__YD
    lea rdi, [rbp-8]
    call @g
    mov rbx, rax
    lea rdi, [rbp-8]
    call @YD___YD
    mov rax, rbx
    ret rax
