machine_ir x86_64 linux

startup
    call @main
    mov rdi, rax
    exit

function @helper
  abi
    param %x -> rdi : i64
    return i64 -> rax
  frame
    stack_size 16
    scratch_bytes 0

  block ^entry
    mov rax, rdi
    ret rax

function @main
  abi
    return i64 -> rax
  frame
    stack_size 0
    scratch_bytes 0

  block ^entry
    mov r8, 1
    mov rax, r8
    cmp.i64 rax, 0
    jne ^then
    jmp ^else

  block ^then
    mov r8, 7
    mov rdi, r8
    call @helper
    ret rax

  block ^else
    mov rax, 0
    ret rax
