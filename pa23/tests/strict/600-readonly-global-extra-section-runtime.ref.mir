machine_ir x86_64 linux

startup
    call @main
    mov rdi, rax
    exit

global @g readonly
  storage scalar i64
  init i64 7

function @main
  abi
    return i32 -> rax
  frame
    stack_size 0
    scratch_bytes 0

  block ^entry
    load.i64 r8, @g
    mov rdx, 4294967295
    and r8, rdx
    sext.i32 r8
    mov rax, r8
    ret rax
