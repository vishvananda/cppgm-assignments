machine_ir x86_64 linux

startup
    call @main
    mov rdi, rax
    exit

global @cell
  storage data
  item i64 7

function @read
  abi
    param %p -> rdi : ptr
    return i64 -> rax
  frame
    stack_size 16
    scratch_bytes 0
    preserve rbx

  block ^entry
    mov r9, rdi
    load.i64 rax, [r9]
    ret rax

function @main
  abi
    return i64 -> rax
  frame
    stack_size 0
    scratch_bytes 0

  block ^entry
    mov r8, @cell
    mov rdi, r8
    call @read
    ret rax
