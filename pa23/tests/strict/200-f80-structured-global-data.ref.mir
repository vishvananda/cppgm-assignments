machine_ir x86_64 linux

startup
    call @main
    mov rdi, rax
    exit

global @table
  storage data
  item f80 4.5L
  item zero 16

function @main
  abi
    return i64 -> rax
  frame
    stack_size 80
    scratch_bytes 48
    temp %x -> [rbp-16] : f80
    temp %y -> [rbp-32] : f80

  block ^entry
    mov r8, @table
    fmov.f80 [rbp-16], [r8]
    fmov.f80 [rbp-32], 4.5L
    feq.f80 rax, [rbp-16], [rbp-32]
    ret rax
