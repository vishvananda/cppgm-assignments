machine_ir x86_64 linux

startup
    call @main
    mov rdi, rax
    exit

function @main
  abi
    return i64 -> rax
  frame
    stack_size 48
    scratch_bytes 48

  block ^entry
    mov r8, 305419896
    bswap r8
    zext.i32 r8
    mov r9, r8
    mov rdx, 2018915346
    cmp.u32 r9, rdx
    sete r9
    movzx r9, r9
    uitofp.i32.f64 xmm0, r8
    fptoui.f64.i32 r8, xmm0
    mov rdx, 2018915346
    cmp.u32 r8, rdx
    sete r8
    movzx r8, r8
    add r9, r8
    mov rdx, 2
    cmp.i64 r9, rdx
    sete r9
    movzx r9, r9
    mov rdx, 0
    cmp.i64 r9, rdx
    sete r9
    movzx r9, r9
    mov rax, r9
    ret rax
