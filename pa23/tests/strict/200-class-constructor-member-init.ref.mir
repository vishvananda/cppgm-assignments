machine_ir x86_64 linux

startup
    call @main
    mov rdi, rax
    exit

function @YP__YP
  abi
    param %this -> rdi : ptr
    return void -> void
  frame
    stack_size 16
    scratch_bytes 0

  block ^entry
    mov r9, rdi
    mov rax, 3
    store.i32 [r9], rax
    ret

function @YP___YP
  abi
    param %this -> rdi : ptr
    return void -> void
  frame
    stack_size 16
    scratch_bytes 0

  block ^entry
    ret

function @main
  abi
    return i64 -> rax
  frame
    stack_size 16
    scratch_bytes 0
    preserve rbx
    slot $p__0 -> [rbp-8] : i64

  block ^entry
    lea rdi, [rbp-8]
    call @YP__YP
    lea rcx, [rbp-8]
    load.i32 rbx, [rcx]
    sext.i32 rbx
    lea rdi, [rbp-8]
    call @YP___YP
    mov rax, rbx
    ret rax
