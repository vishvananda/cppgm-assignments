machine_ir x86_64 linux

startup
    call @main
    mov rdi, rax
    exit

global @g
  storage scalar i64
  init i64 7

function @main
  abi
    return i64 -> rax
  frame
    stack_size 32
    scratch_bytes 0
    preserve rbx r12 r13
    slot $expected -> [rbp-8] : i64

  block ^entry
    mov r8, @g
    mov r9, 5
    store.i64 [rbp-8], r9
    mov r9, 9
    mov rcx, r8
    lea rdx, [rbp-8]
    load.i64 rax, [rdx]
    mov rsi, r9
    lock_cmpxchg.i64 [rcx], rsi
    store.i64 [rdx], rax
    sete rax
    movzx rax, rax
    mov rbx, rax
    load.i64 r9, [r8]
    load.i64 r8, [rbp-8]
    mov r12, 0
    mov r13, 7
    cmp.i64 rbx, r12
    sete rbx
    movzx rbx, rbx
    cmp.i64 r9, r13
    sete r9
    movzx r9, r9
    cmp.i64 r8, r13
    sete r8
    movzx r8, r8
    and rbx, r9
    and rbx, r8
    mov rax, rbx
    ret rax
