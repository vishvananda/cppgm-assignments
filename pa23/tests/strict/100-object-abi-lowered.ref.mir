machine_ir x86_64 linux

startup
    call @main
    mov rdi, rax
    exit

global @out
  storage data
  item i64 0
  item i64 0

function @make_pair
  abi
    param %ret -> rdi : ptr
    param %a -> rsi : i64
    param %b -> rdx : i64
    return void -> void
  frame
    stack_size 32
    scratch_bytes 0
    preserve rbx r12

  block ^entry
    mov rbx, rdi
    mov r9, rdx
    store.i64 [rbx], rsi
    mov r12, rbx
    lea r12, [r12+8]
    store.i64 [r12], r9
    ret

function @main
  abi
    return i64 -> rax
  frame
    stack_size 16
    scratch_bytes 0
    preserve rbx

  block ^entry
    mov rbx, @out
    mov rdi, rbx
    mov rsi, 4
    mov rdx, 5
    call @make_pair
    load.i64 r8, @out
    lea rbx, [rbx+8]
    load.i64 r9, [rbx]
    add r8, r9
    mov rax, r8
    ret rax
