machine_ir x86_64 linux

startup
    call @main
    mov rdi, rax
    exit

global @g
  storage scalar i64
  init i64 7

function @main
  abi
    return i64 -> rax
  frame
    stack_size 48
    scratch_bytes 0
    preserve rbx r12 r13 r14
    slot $expected -> [rbp-8] : i64

  block ^entry
    mov r8, @g
    mov r9, 7
    store.i64 [rbp-8], r9
    mov rbx, 9
    mov rcx, r8
    lea rdx, [rbp-8]
    load.i64 rax, [rdx]
    mov rsi, rbx
    lock_cmpxchg.i64 [rcx], rsi
    store.i64 [rdx], rax
    sete rax
    movzx rax, rax
    mov r12, rax
    load.i64 r13, [r8]
    load.i64 r8, [rbp-8]
    mov r14, 1
    cmp.i64 r12, r14
    sete r12
    movzx r12, r12
    cmp.i64 r13, rbx
    sete r13
    movzx r13, r13
    cmp.i64 r8, r9
    sete r8
    movzx r8, r8
    and r12, r13
    and r12, r8
    mov rax, r12
    ret rax
