machine_ir x86_64 linux

startup
    call @main
    mov rdi, rax
    exit

global @g
  storage scalar i32
  init i32 7

function @main
  abi
    return i64 -> rax
  frame
    stack_size 0
    scratch_bytes 0

  block ^entry
    mov r8, @g
    mov r9, 11
    sext.i32 r9
    mov rax, r9
    xchg.i32 [r8], rax
    load.i32 r9, [r8]
    sext.i32 r9
    mov rdx, 11
    cmp.i32 r9, rdx
    sete r9
    movzx r9, r9
    mov rax, r9
    ret rax
