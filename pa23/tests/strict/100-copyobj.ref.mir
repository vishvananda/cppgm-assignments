machine_ir x86_64 linux

startup
    call @main
    mov rdi, rax
    exit

global @src
  storage data
  item i64 5
  item i64 9

global @dst
  storage data
  item i64 0
  item i64 0

function @main
  abi
    return i64 -> rax
  frame
    stack_size 16
    scratch_bytes 0
    preserve rbx

  block ^entry
    mov r8, @dst
    mov r9, @src
    mov rdi, r8
    mov rsi, r9
    copy_bytes 16x8, rdi, rsi
    load.i64 r9, @dst
    lea r8, [r8+8]
    load.i64 rbx, [r8]
    add r9, rbx
    mov rax, r9
    ret rax
