machine_ir x86_64 linux

startup
    call @__cppgm_init
    call @main
    mov r12, rax
    call @__cppgm_fini
    mov rdi, r12
    exit

global @g
  storage scalar i64
  init i64 0

function @__cppgm_init
  abi
    return void -> void
  frame
    stack_size 0
    scratch_bytes 0

  block ^entry
    mov r8, 5
    store.i64 @g, r8
    ret

function @__cppgm_fini
  abi
    return void -> void
  frame
    stack_size 0
    scratch_bytes 0

  block ^entry
    mov r8, 9
    store.i64 @g, r8
    ret

function @main
  abi
    return i64 -> rax
  frame
    stack_size 0
    scratch_bytes 0

  block ^entry
    load.i64 rax, @g
    ret rax
