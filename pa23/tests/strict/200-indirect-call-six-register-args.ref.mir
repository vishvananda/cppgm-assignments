machine_ir x86_64 linux

startup
    call @main
    mov rdi, rax
    exit

global @table
  storage data
  item ptr addr @sum6

function @sum6
  abi
    param %a -> rdi : i64
    param %b -> rsi : i64
    param %c -> rdx : i64
    param %d -> rcx : i64
    param %e -> r8 : i64
    param %f -> r9 : i64
    return i64 -> rax
  frame
    stack_size 48
    scratch_bytes 0
    preserve rbx r12 r13 r14 r15

  block ^entry
    mov rbx, rdx
    mov r12, rcx
    mov r13, r8
    mov r14, r9
    mov r9, rsi
    mov r15, rdi
    add r15, r9
    add r15, rbx
    add r15, r12
    add r15, r13
    add r15, r14
    mov rax, r15
    ret rax

function @main
  abi
    return i64 -> rax
  frame
    stack_size 64
    scratch_bytes 0
    preserve rbx r12 r13 r14 r15
    temp %r -> [rbp-8] : i64

  block ^entry
    load.ptr r8, @table
    mov r9, 1
    mov rbx, 2
    mov r12, 3
    mov r13, 4
    mov r14, 5
    mov r15, 6
    store.i64 [rbp-16], r9
    mov r10, r8
    load.i64 rdi, [rbp-16]
    mov rsi, rbx
    mov rdx, r12
    mov rcx, r13
    mov r8, r14
    mov r9, r15
    call *r10
    store.i64 [rbp-8], rax
    load.i64 r8, [rbp-8]
    sub r8, 21
    mov rax, r8
    ret rax
