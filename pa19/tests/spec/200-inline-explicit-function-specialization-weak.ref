function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  block ^entry:
    %t1 = call i32 @digits(4)
    %t2 = call i32 @digits__ov2(9)
    %t3 = binary add i32 %t1, %t2
    %t4 = binary sub i32 %t3, 13
    return i32 %t4
}
function @digits(%x : u32) -> i32 [binding=weak, object=_Z6digitsIjEiT_] {
  slot $x : u32
  slot $cond__1 : i32

  block ^entry:
    store u32 %x, $x
    %t1 = load u32 $x
    %t2 = cmp eq u32 %t1, 4
    branch %t2, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i32 4, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i32 0, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t3 = load i32 $cond__1
    return i32 %t3
}
function @digits__ov2(%x : i64) -> i32 [binding=weak, object=_Z6digitsIyEiT_] {
  slot $x : i64
  slot $cond__1 : i32

  block ^entry:
    store i64 %x, $x
    %t1 = load i64 $x
    %t2 = cmp eq i64 %t1, 9
    branch %t2, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i32 9, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i32 0, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t3 = load i32 $cond__1
    return i32 %t3
}
