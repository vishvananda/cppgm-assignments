function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $b : obj<1x1>
  slot $cond__1 : i32

  block ^entry:
    %t1 = addr $b
    %t2 = addr $b
    %t3 = call i32 @box_int___get(%t2)
    %t4 = cmp eq i32 %t3, 2
    branch %t4, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i32 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i32 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t5 = load i32 $cond__1
    return i32 %t5
}
function @box_int___get(%this : ptr) -> i32 [binding=weak, object=_ZNK3boxIiE3getEv] {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    return i32 2
}
