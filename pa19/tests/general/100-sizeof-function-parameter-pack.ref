function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  block ^entry:
    %t1 = call i32 @g(1, 97)
    %t2 = cmp ne i32 %t1, 2
    %t3 = convert zext i32 u8 %t2
    return i32 %t3
}
function @g(%args2 : i32, %args2__pack2 : i8) -> i32 [binding=weak, object=_Z1gIJicEEiDpT_] {
  slot $args2 : i32
  slot $args2__pack2 : i8

  block ^entry:
    store i32 %args2, $args2
    store i8 %args2__pack2, $args2__pack2
    %t1 = const i64 2
    %t2 = convert trunc i32 i64 %t1
    return i32 %t2
}
