function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $f : obj<1x1>
  slot $a : i32
  slot $b : i32
  slot $lor__1 : i64

  block ^entry:
    %t1 = addr $f
    %t2 = addr $f
    %t3 = call i32 @foo__bar(%t2)
    store i32 %t3, $a
    %t4 = addr $f
    %t5 = call i32 @foo__bar__ov2(%t4)
    store i32 %t5, $b
    %t6 = load i32 $a
    %t7 = cmp ne i32 %t6, 0
    branch %t7, ^lor_short_2, ^lor_rhs_1

  block ^lor_rhs_1:
    %t8 = load i32 $b
    %t9 = cmp ne i32 %t8, 1
    %t10 = cmp ne i64 %t9, 0
    store i64 %t10, $lor__1
    jump ^lor_end_3

  block ^lor_short_2:
    store i64 1, $lor__1
    jump ^lor_end_3

  block ^lor_end_3:
    %t11 = load i64 $lor__1
    %t12 = convert zext i32 u8 %t11
    return i32 %t12
}
function @foo__bar(%this : ptr) -> i32 [binding=weak, object=_ZN3foo3barIcEEiv] {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    return i32 0
}
function @foo__bar__ov2(%this : ptr) -> i32 [binding=weak, object=_ZN3foo3barILi2EEEiv] {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    return i32 1
}
