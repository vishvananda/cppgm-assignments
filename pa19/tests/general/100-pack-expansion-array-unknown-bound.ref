function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  block ^entry:
    call void @run()
    return i32 0
}
function @run() -> void [binding=weak, object=_Z3runIJLi0ELi1EEEvv] {
  slot $values : obj<12x4>

  block ^entry:
    %t1 = addr $values
    store i32 0, %t1
    %t2 = index i8 %t1, 4
    store i32 1, %t2
    %t3 = index i8 %t1, 8
    store i32 0, %t3
    %t4 = addr $values
    return void
}
