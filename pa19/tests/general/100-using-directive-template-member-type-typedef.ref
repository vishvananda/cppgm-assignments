function @f() -> i32 [binding=strong, object=_Z1fv] {
  slot $storage : obj<4x1>

  block ^entry:
    %t1 = addr $storage
    %t2 = addr $storage
    %t3 = index i8 [projection=field] %t2, 0
    %t4 = unary decay ptr %t3
    %t5 = index i8 [projection=array_element] %t4, 0
    store i8 7, %t5
    %t6 = addr $storage
    %t7 = index i8 [projection=field] %t6, 0
    %t8 = unary decay ptr %t7
    %t9 = index i8 [projection=array_element] %t8, 0
    %t10 = load i8 %t9
    %t11 = convert sext i32 i8 %t10
    return i32 %t11
}
function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  block ^entry:
    %t1 = call i32 @f()
    return i32 %t1
}
