function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $cond__1 : i32

  block ^entry:
    %t1 = call u8 @read_value()
    branch %t1, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i32 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i32 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t2 = load i32 $cond__1
    return i32 %t2
}
function @read_value() -> u8 [binding=weak, object=_Z10read_valueI9TrueValueEbv] {
  block ^entry:
    return u8 1
}
