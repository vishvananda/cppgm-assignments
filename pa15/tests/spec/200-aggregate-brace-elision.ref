function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $value : obj<12x4>
  slot $cond__1 : i32
  slot $land__2 : i64
  slot $land__3 : i64

  block ^entry:
    %t1 = addr $value
    %t2 = addr $value
    %t3 = index i8 [projection=field] %t2, 0
    %t4 = index i8 [projection=field] %t3, 0
    store i32 1, %t4
    %t5 = addr $value
    %t6 = index i8 [projection=field] %t5, 0
    %t7 = index i8 [projection=field] %t6, 4
    store i32 2, %t7
    %t8 = addr $value
    %t9 = index i8 [projection=field] %t8, 8
    store i32 3, %t9
    %t10 = addr $value
    %t11 = index i8 [projection=field] %t10, 0
    %t12 = index i8 [projection=field] %t11, 0
    %t13 = load i32 %t12
    %t14 = cmp eq i32 %t13, 1
    branch %t14, ^land_rhs_7, ^land_short_8

  block ^land_rhs_7:
    %t15 = addr $value
    %t16 = index i8 [projection=field] %t15, 0
    %t17 = index i8 [projection=field] %t16, 4
    %t18 = load i32 %t17
    %t19 = cmp eq i32 %t18, 2
    %t20 = cmp ne i64 %t19, 0
    store i64 %t20, $land__3
    jump ^land_end_9

  block ^land_short_8:
    store i64 0, $land__3
    jump ^land_end_9

  block ^land_end_9:
    %t21 = load i64 $land__3
    branch %t21, ^land_rhs_4, ^land_short_5

  block ^land_rhs_4:
    %t22 = addr $value
    %t23 = index i8 [projection=field] %t22, 8
    %t24 = load i32 %t23
    %t25 = cmp eq i32 %t24, 3
    %t26 = cmp ne i64 %t25, 0
    store i64 %t26, $land__2
    jump ^land_end_6

  block ^land_short_5:
    store i64 0, $land__2
    jump ^land_end_6

  block ^land_end_6:
    %t27 = load i64 $land__2
    branch %t27, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i32 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i32 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t28 = load i32 $cond__1
    return i32 %t28
}
