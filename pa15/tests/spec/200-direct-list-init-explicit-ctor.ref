function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $s : obj<4x4>
  slot $cond__1 : i32

  block ^entry:
    %t1 = addr $s
    call void @S__S(%t1, 4)
    %t2 = addr $s
    %t3 = index i8 [projection=field] %t2, 0
    %t4 = load i32 %t3
    %t5 = cmp eq i32 %t4, 4
    branch %t5, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i32 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i32 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t6 = load i32 $cond__1
    return i32 %t6
}
function @S__S(%this : ptr, %value : i32) -> void [binding=weak, object=_ZN1SC1Ei] {
  slot $this : ptr
  slot $value : i32

  block ^entry:
    store ptr %this, $this
    store i32 %value, $value
    %t1 = load i32 $value
    %t2 = load ptr $this
    %t3 = index i8 [projection=field] %t2, 0
    store i32 %t1, %t3
    return void
}
