function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $c : obj<8x4>

  block ^entry:
    %t1 = addr $c
    %t2 = addr $c
    %t3 = index i8 [projection=field] %t2, 0
    %t4 = index i8 [projection=field] %t3, 0
    %t5 = index i8 [projection=field] %t4, 0
    store i32 5, %t5
    %t6 = addr $c
    %t7 = index i8 [projection=field] %t6, 4
    store i32 1, %t7
    %t8 = addr $c
    %t9 = index i8 [projection=field] %t8, 0
    %t10 = index i8 [projection=field] %t9, 0
    %t11 = index i8 [projection=field] %t10, 0
    %t12 = load i32 %t11
    %t13 = binary sub i32 %t12, 5
    return i32 %t13
}
