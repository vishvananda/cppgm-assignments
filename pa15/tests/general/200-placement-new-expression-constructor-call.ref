declare function @S__S(%arg0 : ptr, %arg1 : i32) -> void [binding=strong, object=_ZN1SC1Ei]
declare function @operatornew(%arg0 : i64, %arg1 : ptr) -> ptr [binding=strong, object=_ZnwmPv]

function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $buf : obj<8x1>
  slot $p : ptr

  block ^entry:
    %t1 = convert sext i64 i32 1
    %t2 = addr $buf
    %t3 = unary decay ptr %t2
    %t4 = call ptr @operatornew(%t1, %t3)
    call void @S__S(%t4, 7)
    store ptr %t4, $p
    %t5 = load ptr $p
    %t6 = cmp eq ptr %t5, 0
    %t7 = convert zext i32 u8 %t6
    return i32 %t7
}
