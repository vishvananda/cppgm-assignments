function @X__flags(%this : ptr) -> u32 [binding=weak, object=_ZNK1X5flagsEv] {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    %t1 = load ptr $this
    %t2 = index i8 [projection=field] %t1, 0
    %t3 = load u32 %t2
    return u32 %t3
}
function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
