  block ^entry:
    %t1 = addr $x
    %t2 = addr $x
    %t3 = index i8 [projection=field] %t2, 0
    store u32 1, %t3
    %t4 = addr $x
    %t5 = call u32 @X__flags(%t4)
    %t6 = cmp eq u32 %t5, 1
    branch %t6, ^cond_then_1, ^cond_else_2

