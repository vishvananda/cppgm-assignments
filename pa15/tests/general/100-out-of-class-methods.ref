function @YP__set(%this : ptr, %v : i32) -> void [binding=strong, object=_ZN2YP3setEi] {
  slot $this : ptr
  slot $v : i32

  block ^entry:
    store ptr %this, $this
    store i32 %v, $v
    %t1 = load i32 $v
    %t2 = load ptr $this
    %t3 = index i8 [projection=field] %t2, 0
    store i32 %t1, %t3
    return void
}
function @YP__get(%this : ptr) -> i32 [binding=strong, object=_ZN2YP3getEv] {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    %t1 = load ptr $this
    %t2 = index i8 [projection=field] %t1, 0
    %t3 = load i32 %t2
    return i32 %t3
}
function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $p : obj<4x4>

  block ^entry:
    %t1 = addr $p
    %t2 = addr $p
    call void @YP__set(%t2, 7)
    %t3 = addr $p
    %t4 = call i32 @YP__get(%t3)
    return i32 %t4
}
