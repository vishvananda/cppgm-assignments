function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $x : obj<4x4>
  slot $cond__1 : i32

  block ^entry:
    %t1 = addr $x
    call void @X__X(%t1)
    %t2 = addr $x
    %t3 = index i8 [projection=field] %t2, 0
    %t4 = index i8 [projection=field] %t3, 0
    %t5 = load i32 %t4
    %t6 = cmp eq i32 %t5, 3
    branch %t6, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i32 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i32 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t7 = load i32 $cond__1
    return i32 %t7
}
function @X__X(%this : ptr) -> void [binding=weak, object=_ZN1XC1Ev] {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    %t1 = load ptr $this
    %t2 = index i8 [projection=field] %t1, 0
    call void @Y__Y(%t2)
    return void
}
function @Y__Y(%this : ptr) -> void [binding=weak, object=_ZN1YC1Ev] {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    %t1 = load ptr $this
    %t2 = index i8 [projection=field] %t1, 0
    store i32 3, %t2
    return void
}
