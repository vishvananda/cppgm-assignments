function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $x : obj<4x4>

  block ^entry:
    %t1 = addr $x
    call void @X__X(%t1)
    %t2 = addr $x
    %t3 = index i8 [projection=field] %t2, 0
    %t4 = load i32 %t3
    %t5 = binary sub i32 %t4, 7
    return i32 %t5
}
function @X__X(%this : ptr) -> void [binding=weak, object=_ZN1XC1Ev] {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    %t1 = load ptr $this
    %t2 = index i8 [projection=field] %t1, 0
    store i32 7, %t2
    return void
}
