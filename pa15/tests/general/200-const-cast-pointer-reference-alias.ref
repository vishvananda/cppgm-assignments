function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $x : i32
  slot $p : ptr
  slot $cond__1 : i32

  block ^entry:
    store i32 0, $x
    %t1 = addr $x
    store ptr %t1, $p
    %t2 = addr $p
    %t3 = call ptr @S__pass(%t2)
    %t4 = addr $x
    %t5 = cmp eq ptr %t3, %t4
    branch %t5, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i32 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i32 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t6 = load i32 $cond__1
    return i32 %t6
}
function @S__pass(%p : ptr [pass=reference]) -> ptr [binding=weak, object=_ZN1S4passERKPi] {
  slot $p : ptr
  slot $q : ptr

  block ^entry:
    store ptr %p, $p
    %t1 = load ptr $p
    store ptr %t1, $q
    %t2 = load ptr $q
    %t3 = load ptr %t2
    return ptr %t3
}
