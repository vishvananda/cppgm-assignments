function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $m : obj<1x1>
  slot $cond__1 : i32

  block ^entry:
    %t1 = addr $m
    %t2 = call i32 @Map__g(%t1)
    %t3 = cmp eq i32 %t2, 2
    branch %t3, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i32 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i32 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t4 = load i32 $cond__1
    return i32 %t4
}
function @Map__g(%this : ptr) -> i32 [binding=weak, object=_ZNK3Map1gEv] {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    %t1 = load ptr $this
    %t2 = index i8 [projection=field] %t1, 0
    %t3 = call i32 @Table__f__ov2(%t2)
    return i32 %t3
}
function @Table__f__ov2(%this : ptr) -> i32 [binding=weak, object=_ZNK5Table1fEv] {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    return i32 2
}
