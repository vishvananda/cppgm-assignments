declare function @__builtin_memcpy(%arg0 : ptr [capture=nocapture, access=write, alias=noalias], %arg1 : ptr [capture=nocapture, access=read, alias=noalias], %arg2 : i64) -> ptr [effects=readwrite, unwind=no, binding=strong, object=cppgm_builtin_memcpy]

function @copy4(%dst : ptr, %src : ptr) -> void [binding=strong, object=_Z5copy4PcPKc] {
  slot $dst : ptr
  slot $src : ptr

  block ^entry:
    store ptr %dst, $dst
    store ptr %src, $src
    %t1 = load ptr $dst
    %t2 = load ptr $src
    %t3 = convert sext i64 i32 4
    %t4 = call ptr @__builtin_memcpy(%t1, %t2, %t3)
    return void
}
