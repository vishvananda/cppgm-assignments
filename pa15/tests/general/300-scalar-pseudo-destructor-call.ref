function @f(%p : ptr) -> void [binding=strong, object=_Z1fPi] {
  slot $p : ptr

  block ^entry:
    store ptr %p, $p
    %t1 = load ptr $p
    return void
}
function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $x : i32

  block ^entry:
    store i32 0, $x
    %t1 = addr $x
    call void @f(%t1)
    return i32 0
}
