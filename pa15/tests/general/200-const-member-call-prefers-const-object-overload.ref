function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $s : obj<16x8>

  block ^entry:
    %t1 = addr $s
    call void @S__S(%t1)
    %t2 = addr $s
    %t3 = call i32 @S__g(%t2)
    %t4 = binary sub i32 %t3, 7
    return i32 %t4
}
function @S__S(%this : ptr) -> void [binding=weak, object=_ZN1SC1Ev] {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    %t1 = load ptr $this
    %t2 = index i8 [projection=field] %t1, 0
    store i32 7, %t2
    %t3 = load ptr $this
    %t4 = index i8 [projection=field] %t3, 0
    %t5 = load ptr $this
    %t6 = index i8 [projection=field] %t5, 8
    store ptr %t4, %t6
    return void
}
function @S__g(%this : ptr) -> i32 [binding=weak, object=_ZNK1S1gEv] {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    %t1 = load ptr $this
    %t2 = load ptr $this
    %t3 = index i8 [projection=field] %t2, 8
    %t4 = load ptr %t3
