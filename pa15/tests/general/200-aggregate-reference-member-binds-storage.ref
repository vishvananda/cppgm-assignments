function @f() -> i32 [binding=strong, object=_Z1fv] {
  slot $x : i32
  slot $sb : obj<8x8>
  slot $cond__1 : i32

  block ^entry:
    store i32 0, $x
    %t1 = addr $sb
    %t2 = addr $x
    %t3 = addr $sb
    %t4 = index i8 [projection=field] %t3, 0
    store ptr %t2, %t4
    %t5 = addr $sb
    %t6 = index i8 [projection=reference_field] %t5, 0
    %t7 = load ptr %t6
    %t8 = addr $x
    %t9 = cmp eq ptr %t7, %t8
    branch %t9, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i32 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i32 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t10 = load i32 $cond__1
    return i32 %t10
}
function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  block ^entry:
    %t1 = call i32 @f()
    return i32 %t1
}
