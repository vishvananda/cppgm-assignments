function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $m : obj<4x4>
  slot $lk : obj<4x4>

  block ^entry:
    %t1 = addr $m
    call void @M__M(%t1)
    %t2 = addr $lk
    %t3 = addr $m
    call void @Lock__Lock(%t2, %t3)
    %t4 = addr $lk
    %t5 = index i8 [projection=field] %t4, 0
    %t6 = load i32 %t5
    %t7 = binary sub i32 %t6, 7
    return i32 %t7
}
function @M__M(%this : ptr) -> void [binding=weak, object=_ZN1MC1Ev] {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    %t1 = load ptr $this
    %t2 = index i8 [projection=field] %t1, 0
    store i32 7, %t2
    return void
}
function @Lock__Lock(%this : ptr, %m : ptr [pass=reference]) -> void [binding=weak, object=_ZN4LockC1ER1M] {
  slot $this : ptr
  slot $m : ptr

  block ^entry:
    store ptr %this, $this
    store ptr %m, $m
    %t1 = load ptr $m
    %t2 = index i8 [projection=field] %t1, 0
    %t3 = load i32 %t2
    %t4 = load ptr $this
    %t5 = index i8 [projection=field] %t4, 0
    store i32 %t3, %t5
    return void
}
