function @Y__get(%this : ptr) -> i32 [binding=strong, object=_ZN1Y3getEv] {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    %t1 = load ptr $this
    %t2 = index i8 [projection=field] %t1, 0
    %t3 = load i32 %t2
    return i32 %t3
}
function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $p : obj<4x4>
  slot $cond__1 : i32

  block ^entry:
    %t1 = addr $p
    %t2 = addr $p
    %t3 = index i8 [projection=field] %t2, 0
    store i32 7, %t3
    %t4 = addr $p
    %t5 = call i32 @Y__get(%t4)
    %t6 = cmp eq i32 %t5, 7
    branch %t6, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i32 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i32 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t7 = load i32 $cond__1
    return i32 %t7
}
