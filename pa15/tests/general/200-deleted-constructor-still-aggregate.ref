function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $x : obj<4x4>

  block ^entry:
    %t1 = addr $x
    %t2 = addr $x
    %t3 = index i8 [projection=field] %t2, 0
    store i32 1, %t3
    %t4 = addr $x
    %t5 = index i8 [projection=field] %t4, 0
    %t6 = load i32 %t5
    %t7 = cmp ne i32 %t6, 1
    %t8 = convert zext i32 u8 %t7
    return i32 %t8
}
