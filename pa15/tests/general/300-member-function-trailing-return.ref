function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $b : obj<4x4>
  slot $cond__1 : i32

  block ^entry:
    %t1 = addr $b
    %t2 = addr $b
    %t3 = index i8 [projection=field] %t2, 0
    store u32 2, %t3
    %t4 = addr $b
    %t5 = call u32 @bits__remove(%t4, 1)
    %t6 = cmp eq u32 %t5, 3
    branch %t6, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i32 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i32 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t7 = load i32 $cond__1
    return i32 %t7
}
function @bits__remove(%this : ptr, %exponent_bits : u32) -> u32 [unwind=no, binding=weak, object=_ZNK4bits6removeEj] {
  slot $this : ptr
  slot $exponent_bits : u32

  block ^entry:
    store ptr %this, $this
    store u32 %exponent_bits, $exponent_bits
    %t1 = load ptr $this
    %t2 = index i8 [projection=field] %t1, 0
    %t3 = load u32 %t2
    %t4 = load u32 $exponent_bits
    %t5 = binary add u32 %t3, %t4
    return u32 %t5
}
