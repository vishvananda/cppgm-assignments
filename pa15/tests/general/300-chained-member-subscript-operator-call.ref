function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $o : obj<4x4>

  block ^entry:
    %t1 = addr $o
    %t2 = addr $o
    %t3 = call ptr @Outer__operator__(%t2, 0)
    %t4 = call ptr @Inner__operator__(%t3, 1)
    store i32 7, %t4
    %t5 = addr $o
