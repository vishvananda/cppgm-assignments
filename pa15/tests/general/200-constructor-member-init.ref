function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $p : obj<4x4>

  block ^entry:
    %t1 = addr $p
    call void @YP__YP(%t1)
    %t2 = addr $p
    %t3 = index i8 [projection=field] %t2, 0
    %t4 = load i32 %t3
    return i32 %t4
}
function @YP__YP(%this : ptr) -> void [binding=weak, object=_ZN2YPC1Ev] {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    %t1 = load ptr $this
    %t2 = index i8 [projection=field] %t1, 0
    store i32 3, %t2
    return void
}
