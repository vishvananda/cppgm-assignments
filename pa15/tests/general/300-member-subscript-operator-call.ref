function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $b : obj<4x4>

  block ^entry:
    %t1 = addr $b
    %t2 = addr $b
    %t3 = index i8 [projection=field] %t2, 0
    %t4 = unary decay ptr %t3
    %t5 = index i32 [projection=array_element] %t4, 0
    store i32 7, %t5
    %t6 = addr $b
    %t7 = call i32 @Box__operator__(%t6, 0)
    return i32 %t7
}
function @Box__operator__(%this : ptr, %i : i32) -> i32 [binding=weak, object=_ZNK3BoxixEi] {
  slot $this : ptr
  slot $i : i32

  block ^entry:
    store ptr %this, $this
    store i32 %i, $i
    %t1 = load ptr $this
    %t2 = index i8 [projection=field] %t1, 0
    %t3 = unary decay ptr %t2
    %t4 = load i32 $i
    %t5 = index i32 [projection=array_element] %t3, %t4
    %t6 = load i32 %t5
    return i32 %t6
}
