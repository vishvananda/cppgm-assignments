function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $s : obj<4x4>
  slot $r : obj<8x8>
  slot $candidate : ptr
  slot $decl_scope : ptr
  slot $condaddr__1 : ptr
  slot $cond__2 : i32

  block ^entry:
    %t1 = addr $s
    %t2 = addr $s
    %t3 = index i8 [projection=field] %t2, 0
    store i32 3, %t3
    %t4 = addr $r
    %t5 = addr $s
    call void @R__R(%t4, %t5)
    %t6 = copy ptr nullptr
    store ptr %t6, $candidate
    %t7 = load ptr $candidate
    branch %t7, ^condaddr_then_1, ^condaddr_else_2

  block ^condaddr_then_1:
    %t8 = load ptr $candidate
    store ptr %t8, $condaddr__1
    jump ^condaddr_end_3

  block ^condaddr_else_2:
    %t9 = addr $r
    %t10 = index i8 [projection=reference_field] %t9, 0
    %t11 = load ptr %t10
    store ptr %t11, $condaddr__1
    jump ^condaddr_end_3

  block ^condaddr_end_3:
    %t12 = load ptr $condaddr__1
    store ptr %t12, $decl_scope
    %t13 = load ptr $decl_scope
    %t14 = index i8 [projection=field] %t13, 0
    store i32 9, %t14
    %t15 = addr $s
    %t16 = index i8 [projection=field] %t15, 0
    %t17 = load i32 %t16
    %t18 = cmp eq i32 %t17, 9
    branch %t18, ^cond_then_4, ^cond_else_5

  block ^cond_then_4:
    store i32 0, $cond__2
    jump ^cond_end_6

  block ^cond_else_5:
    store i32 1, $cond__2
    jump ^cond_end_6

  block ^cond_end_6:
    %t19 = load i32 $cond__2
    return i32 %t19
}
function @R__R(%this : ptr, %x : ptr [pass=reference]) -> void [binding=weak, object=_ZN1RC1ER1S] {
  slot $this : ptr
  slot $x : ptr

  block ^entry:
    store ptr %this, $this
    store ptr %x, $x
    %t1 = load ptr $x
    %t2 = load ptr $this
    %t3 = index i8 [projection=field] %t2, 0
    store ptr %t1, %t3
    return void
}
