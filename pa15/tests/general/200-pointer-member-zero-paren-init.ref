function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $s : obj<8x8>
  slot $cond__1 : i32

  block ^entry:
    %t1 = addr $s
    call void @S__S(%t1)
    %t2 = addr $s
    %t3 = index i8 [projection=field] %t2, 0
    %t4 = load ptr %t3
    %t5 = cmp eq ptr %t4, 0
    branch %t5, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i32 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i32 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t6 = load i32 $cond__1
    return i32 %t6
}
function @S__S(%this : ptr) -> void [binding=weak, object=_ZN1SC1Ev] {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    %t1 = load ptr $this
    %t2 = index i8 [projection=field] %t1, 0
    store ptr 0, %t2
    return void
}
