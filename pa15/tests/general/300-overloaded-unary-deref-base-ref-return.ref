function @f(%box : ptr [pass=reference]) -> ptr [binding=strong, object=_Z1fR3Box] {
  slot $box : ptr

  block ^entry:
    store ptr %box, $box
    %t1 = load ptr $box
    %t2 = call ptr @Box__operator_(%t1)
    %t3 = index i8 [projection=base_subobject] %t2, 0
    return ptr %t3
}
function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $box : obj<4x4>
  slot $ref : ptr
  slot $cond__1 : i32

  block ^entry:
    %t1 = addr $box
    %t2 = addr $box
    %t3 = index i8 [projection=field] %t2, 0
    %t4 = index i8 [projection=base_subobject] %t3, 0
    %t5 = index i8 [projection=field] %t4, 0
    store i32 1, %t5
    %t6 = addr $box
    %t7 = call ptr @f(%t6)
    store ptr %t7, $ref
    %t8 = load ptr $ref
    %t9 = index i8 [projection=field] %t8, 0
    store i32 7, %t9
    %t10 = addr $box
    %t11 = index i8 [projection=field] %t10, 0
    %t12 = index i8 [projection=base_subobject] %t11, 0
    %t13 = index i8 [projection=field] %t12, 0
    %t14 = load i32 %t13
    %t15 = cmp eq i32 %t14, 7
    branch %t15, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i32 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i32 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t16 = load i32 $cond__1
    return i32 %t16
}
function @Box__operator_(%this : ptr) -> ptr [binding=weak, object=_ZN3BoxdeEv] {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    %t1 = load ptr $this
    %t2 = index i8 [projection=field] %t1, 0
    return ptr %t2
}
