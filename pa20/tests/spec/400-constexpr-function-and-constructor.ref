    %t1 = load i32 $v
    %t2 = load ptr $this
    %t3 = index i8 [projection=field] %t2, 0
    store i32 %t1, %t3
    return void
}
function @__cppgm_init() -> void [role=init, binding=internal] {
  block ^entry:
    %t1 = addr @p
    %t2 = call i32 @square(3)
    call void @Point__Point(%t1, %t2)
