global @p [binding=internal, object=_Z1p] = {
  zero 4
}

function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  block ^entry:
    return i32 0
}
function @square(%x : i32) -> i32 [binding=weak, object=_Z6squarei] {
  slot $x : i32

  block ^entry:
    store i32 %x, $x
    %t1 = load i32 $x
    %t2 = load i32 $x
    %t3 = binary mul i32 %t1, %t2
    return i32 %t3
}
function @Point__Point(%this : ptr, %v : i32) -> void [binding=weak, object=_ZN5PointC1Ei] {
  slot $this : ptr
  slot $v : i32

  block ^entry:
    store ptr %this, $this
