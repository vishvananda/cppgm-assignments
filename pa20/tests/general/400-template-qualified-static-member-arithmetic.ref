function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $cond__1 : i32

  block ^entry:
    %t1 = call i32 @f()
    %t2 = const i64 8
    %t3 = convert sext i64 i32 8
    %t4 = binary mul i64 %t2, %t3
    %t5 = convert sext i64 i32 1
    %t6 = binary sub i64 %t4, %t5
    %t7 = convert trunc i32 i64 %t6
    %t8 = cmp eq i32 %t1, %t7
    branch %t8, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i32 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i32 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t9 = load i32 $cond__1
    return i32 %t9
}
function @f() -> i32 [binding=weak, object=_Z1fv] {
  block ^entry:
    %t1 = binary sub i32 64, 1
    return i32 %t1
}
