function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $d : obj<1x1>
  slot $cond__1 : i32

  block ^entry:
    %t1 = addr $d
    %t2 = addr $d
    %t3 = call u32 @derived__f(%t2)
    %t4 = cmp eq u32 %t3, 3
    branch %t4, ^cond_then_1, ^cond_else_2

  block ^cond_then_1:
    store i32 0, $cond__1
    jump ^cond_end_3

  block ^cond_else_2:
    store i32 1, $cond__1
    jump ^cond_end_3

  block ^cond_end_3:
    %t5 = load i32 $cond__1
    return i32 %t5
}
function @derived__f(%this : ptr) -> u32 [binding=weak, object=_ZN7derived1fEv] {
  slot $this : ptr

  block ^entry:
    store ptr %this, $this
    %t1 = const i64 12
    %t2 = const i64 4
    %t3 = binary udiv i64 %t1, %t2
    %t4 = convert trunc u32 i64 %t3
    return u32 %t4
}
