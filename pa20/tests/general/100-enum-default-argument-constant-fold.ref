function @f(%x : i32) -> i32 [binding=strong, object=_Z1f1E] {
  slot $x : i32

  block ^entry:
    store i32 %x, $x
    %t1 = load i32 $x
    %t2 = cmp eq i32 %t1, 0
    %t3 = convert zext i32 u8 %t2
    return i32 %t3
}
function @g() -> i32 [binding=strong, object=_Z1gv] {
  block ^entry:
    %t1 = call i32 @f(0)
    return i32 %t1
}
function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  block ^entry:
    %t1 = call i32 @g()
    return i32 %t1
}
