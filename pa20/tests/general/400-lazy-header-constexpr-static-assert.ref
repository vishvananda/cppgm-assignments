function @main() -> i32 [role=entry, binding=strong, keep_alias=yes] {
  slot $s : obj<1x1>

  block ^entry:
    %t1 = addr $s
    %t2 = addr $s
    call void @S__g(%t2)
    return i32 0
}
function @S__g(%this : ptr) -> void [binding=weak, object=_ZN1S1gEv] {
  slot $this : ptr
  slot $x : i32

  block ^entry:
    store ptr %this, $this
    %t1 = const i64 1
    %t2 = convert trunc i32 i64 %t1
    store i32 %t2, $x
    %t3 = load i32 $x
    return void
}
