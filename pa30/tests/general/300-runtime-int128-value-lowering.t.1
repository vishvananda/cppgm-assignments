typedef __int128_t I128;
typedef __uint128_t U128;

unsigned long long low_i128(I128 value)
{
  return (unsigned long long)value;
}

long long high_i128(I128 value)
{
  return (long long)(value >> 64);
}

unsigned long long low_u128(U128 value)
{
  return (unsigned long long)value;
}

unsigned long long high_u128(U128 value)
{
  return (unsigned long long)(value >> 64);
}

I128 make_signed()
{
  return (((I128)1) << 66) + 5;
}

U128 make_unsigned()
{
  return (((U128)1) << 68) + 9;
}

int main()
{
  I128 a = make_signed();
  if(low_i128(a) != 5ULL || high_i128(a) != 4LL) {
    return 1;
  }

  I128 b = a * 3;
  if(low_i128(b) != 15ULL || high_i128(b) != 12LL) {
    return 2;
  }

  I128 c = b / 3;
  if(low_i128(c) != 5ULL || high_i128(c) != 4LL) {
    return 3;
  }

  I128 d = b % 3;
  if(low_i128(d) != 0ULL || high_i128(d) != 0LL) {
    return 4;
  }

  U128 u = make_unsigned();
  if(low_u128(u) != 9ULL || high_u128(u) != 16ULL) {
    return 5;
  }

  U128 v = u >> 2;
  if(low_u128(v) != 2ULL || high_u128(v) != 4ULL) {
    return 6;
  }

  U128 w = v << 1;
  if(low_u128(w) != 4ULL || high_u128(w) != 8ULL) {
    return 7;
  }

  U128 x = w / 4;
  if(low_u128(x) != 1ULL || high_u128(x) != 2ULL) {
    return 8;
  }

  U128 y = w % 4;
  if(low_u128(y) != 0ULL || high_u128(y) != 0ULL) {
    return 9;
  }

  return 0;
}
