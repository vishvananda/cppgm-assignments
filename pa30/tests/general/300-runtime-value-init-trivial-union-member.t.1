typedef unsigned long size_t;

void *operator new(size_t, void *p)
{
  return p;
}

struct Holder {
  union Rep {
    unsigned long tag;
    char bytes[sizeof(unsigned long)];

    Rep() = default;
  } rep;

  Holder() : rep() {}
};

int main()
{
  union Storage {
    unsigned long align;
    char bytes[sizeof(Holder)];
  } storage;

  for(size_t i = 0; i < sizeof(storage.bytes); ++i) {
    storage.bytes[i] = (char)0x7f;
  }

  Holder *holder = new (storage.bytes) Holder();
  return holder->rep.tag == 0 ? 0 : 1;
}
