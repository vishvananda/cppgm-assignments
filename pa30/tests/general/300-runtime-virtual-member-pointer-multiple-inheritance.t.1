struct A {
  int a;
  virtual int foo() { return a + 10; }
  int bar() { return a + 1; }
};

struct B {
  int b;
  virtual int foo() { return b + 20; }
  int bar() { return b + 2; }
};

struct C : A, B {
  int c;
  int foo() { return c + 30; }
  int bar() { return c + 3; }
};

template <class T> int invoke(C &c, int (T::*fn)()) {
  return (c.*fn)();
}

int main() {
  C c;
  c.a = 1;
  c.b = 2;
  c.c = 3;
  return invoke(c, &A::foo) == 33 &&
         invoke(c, &A::bar) == 2 &&
         invoke(c, &B::foo) == 33 &&
         invoke(c, &B::bar) == 4 &&
         invoke(c, &C::foo) == 33 &&
         invoke(c, &C::bar) == 6 ? 0 : 1;
}
