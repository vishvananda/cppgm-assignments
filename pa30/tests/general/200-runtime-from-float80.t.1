#include "pa29-runtime-support.inc"

int main()
{
  if(cppgm_test_init_io() != 0)
  {
    return 1;
  }

  cppgm_u64 count = cppgm_test_take_count_line();
  cppgm_test_out_unsigned_decimal(count);
  cppgm_test_out_char('\n');

  while(count != 0)
  {
    char kind = cppgm_test_take_char();
    char size_ch = cppgm_test_take_char();
    int bytes = size_ch - '0';
    cppgm_test_take_char();

    cppgm_test_out_char(kind);
    cppgm_test_out_char(size_ch);
    cppgm_test_out_char(' ');

    long double value = cppgm_test_take_f80();
    cppgm_test_take_char();

    if(kind == 's')
    {
      if(bytes == 1)
      {
        cppgm_test_out_hex_le((cppgm_u64)(cppgm_u8)(signed char)value, 1);
      }
      else if(bytes == 2)
      {
        cppgm_test_out_hex_le((cppgm_u64)(cppgm_u16)(short)value, 2);
      }
      else if(bytes == 4)
      {
        cppgm_test_out_hex_le((cppgm_u64)(cppgm_u32)(int)value, 4);
      }
      else
      {
        cppgm_test_out_hex_le((cppgm_u64)(long long)value, 8);
      }
    }
    else if(kind == 'u')
    {
      if(bytes == 1)
      {
        cppgm_test_out_hex_le((cppgm_u64)(cppgm_u8)value, 1);
      }
      else if(bytes == 2)
      {
        cppgm_test_out_hex_le((cppgm_u64)(cppgm_u16)value, 2);
      }
      else if(bytes == 4)
      {
        cppgm_test_out_hex_le((cppgm_u64)(cppgm_u32)value, 4);
      }
      else
      {
        cppgm_test_out_hex_le((cppgm_u64)value, 8);
      }
    }
    else if(bytes == 4)
    {
      cppgm_test_out_f32((float)value);
    }
    else
    {
      cppgm_test_out_f64((double)value);
    }

    cppgm_test_out_char('\n');
    --count;
  }

  return cppgm_test_flush_output();
}
