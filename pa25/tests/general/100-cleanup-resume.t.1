global @g : i64 = zero

function @f() -> i64 {
  block ^entry:
    eh_cleanup ^cleanup
    throw i64 9

  block ^cleanup:
    store i64 1, @g
    resume
}

function @main() -> i64 {
  block ^entry:
    eh_try ^catch
    %0 = call i64 @f()
    eh_end
    return i64 %0

  block ^catch:
    %1 = exception i64
    %2 = load i64 @g
    %3 = binary add i64 %1, %2
    return i64 %3
}
